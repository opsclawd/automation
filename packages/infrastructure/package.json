{
  "name": "@ai-sdlc/infrastructure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./artifacts/file-tailer.js": {
      "development": "./src/artifacts/file-tailer.ts",
      "types": "./dist/artifacts/file-tailer.d.ts",
      "import": "./dist/artifacts/file-tailer.js"
    },
    "./agent/implement-artifact-guard": {
      "development": "./src/agent/implement-artifact-guard.ts",
      "types": "./dist/agent/implement-artifact-guard.d.ts",
      "import": "./dist/agent/implement-artifact-guard.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdlc/application": "workspace:*",
    "@ai-sdlc/domain": "workspace:*",
    "@ai-sdlc/shared": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "execa": "^9.5.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
