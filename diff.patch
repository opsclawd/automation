+_validate_arbiter_result() {
+  ARBITER_VALID="false"
+  ARBITER_OUTCOME=""
+  ARBITER_DEFECT_CLASSIFICATION=""
+  ARBITER_EVIDENCE=""
+  ARBITER_RATIONALE=""
+  ARBITER_AMENDED_VERIFICATION=""
+  ARBITER_ORIGINAL_VERIFICATION=""
+  local result_file="${WORKTREE_DIR}/arbiter-result.json"
+  if [[ ! -f "$result_file" ]]; then
+    warn "Arbiter result file not found: $result_file"
+    return 1
+  fi
+  if ! jq -e '.' "$result_file" > /dev/null 2>&1; then
+    warn "Arbiter result is not valid JSON: $result_file"
+    return 1
+  fi
+  local outcome defect_class evidence
+  outcome=$(jq -r '.outcome // ""' "$result_file")
+  defect_class=$(jq -r '.defect_classification // ""' "$result_file")
+  evidence=$(jq -r '.evidence // ""' "$result_file")
+  local valid_outcomes="RESOLVED_TIEBREAK RESOLVED_AMENDED DEVIATION_PROCEED BLOCKED_IMPL_DEFECT"
+  local found=0
+  for vo in $valid_outcomes; do
+    [[ "$outcome" == "$vo" ]] && found=1 && break
+  done
+  if [[ "$found" -eq 0 ]]; then
+    warn "Arbiter outcome '${outcome}' is not a recognized value"
+    return 1
+  fi
+  if [[ -z "$evidence" ]]; then
+    warn "Arbiter evidence field is empty — treating as BLOCKED_IMPL_DEFECT (guardrail G1)"
+    ARBITER_OUTCOME="BLOCKED_IMPL_DEFECT"
+    ARBITER_DEFECT_CLASSIFICATION="implementation_defect"
+    return 1
+  fi
+  if [[ "$defect_class" != "verification_spec_defect" && "$defect_class" != "implementation_defect" ]]; then
+    warn "Arbiter defect_classification '${defect_class}' is invalid"
+    return 1
+  fi
+  if [[ "$outcome" == "DEVIATION_PROCEED" && "$defect_class" == "implementation_defect" ]]; then
+    warn "Arbiter DEVIATION_PROCEED with implementation_defect — auto-proceed forbidden (guardrail G4)"
+    return 1
+  fi
+  if [[ "$outcome" == "RESOLVED_AMENDED" ]]; then
+    local amended original
+    amended=$(jq -r '.amended_verification // ""' "$result_file")
+    original=$(jq -r '.original_verification // ""' "$result_file")
+    if [[ -z "$amended" ]]; then
+      warn "Arbiter RESOLVED_AMENDED but amendment is empty — deleting a check is forbidden (guardrail G2)"
+      return 1
+    fi
+    if [[ -z "$original" ]]; then
+      warn "Arbiter RESOLVED_AMENDED but original command is empty — cannot validate narrowing"
+      return 1
+    fi
+  fi
+  ARBITER_OUTCOME="$outcome"
+  ARBITER_DEFECT_CLASSIFICATION="$defect_class"
+  ARBITER_EVIDENCE="$evidence"
+  ARBITER_RATIONALE=$(jq -r '.rationale // ""' "$result_file")
+  ARBITER_AMENDED_VERIFICATION=$(jq -r '.amended_verification // ""' "$result_file")
+  ARBITER_ORIGINAL_VERIFICATION=$(jq -r '.original_verification // ""' "$result_file")
+  ARBITER_VALID="true"
+  return 0
+}
+
+_record_deviation() {
+  local task_num="$1"
+  local defect_classification="$2"
+  local outcome="$3"
+  local evidence="$4"
+  local rationale="$5"
+  local deviation_md="${WORKTREE_DIR}/deviation-record.md"
+  local deviation_json="${WORKTREE_DIR}/deviation-record.json"
+  log "Recording deviation for task ${task_num}: ${outcome} (${defect_classification})"
+  cat > "$deviation_md" << EOF
+# Deviation Record — Issue #${ISSUE_NUM:-unknown}
+
+## Task
+${task_num}
+
+## Defect Classification
+${defect_classification}
+
+## Outcome
+${outcome}
+
+## Evidence
+${evidence}
+
+## Rationale
+${rationale}
+
+## Recorded At
+$(date -Iseconds 2>/dev/null || date)
+EOF
+  jq -n \
+    --arg task "${task_num}" \
+    --arg defect_classification "${defect_classification}" \
+    --arg outcome "${outcome}" \
+    --arg evidence "${evidence}" \
+    --arg rationale "${rationale}" \
+    --arg issue "${ISSUE_NUM:-unknown}" \
+    --arg recorded_at "$(date -Iseconds 2>/dev/null || date)" \
+    '{task: $task, defect_classification: $defect_classification, outcome: $outcome, evidence: $evidence, rationale: $rationale, issue: $issue, recorded_at: $recorded_at}' \
+    > "$deviation_json"
+  emit_event "arbitrate" "info" "arbiter.deviation_recorded" "deviation recorded for task ${task_num}" \
+    task="${task_num}" \
+    defect_classification="${defect_classification}" \
+    outcome="${outcome}" \
+    path="${deviation_md}"
+}
+
