#!/usr/bin/env bash
# =============================================================================
# ai-run-issue-v2.sh — Non-interactive GitHub issue-to-PR orchestrator
#
# Usage: pnpm ai:run-issue <issue-number>
#
# State labels: ai:blocked | ai:failed | ai:needs-human-review | ai:pr-ready
# Idempotent: rerunning resumes or safely fails (no duplicate branches/PRs)
# =============================================================================
#
# NOTE: All agent invocations now route through run-agent.ts via
# AgentRuntimeRouter. Profile selection and env-var overrides
# (AI_AGENT_PROVIDER, AI_AGENT_MODEL) are handled centrally.
#
set -euo pipefail
# SIGPIPE gotcha: with `set -e -o pipefail`, a `producer | head -N`
# pattern inside a command substitution can crash the script silently
# when the producer is large enough to outrun head. head closes the
# pipe early, the producer (echo, cat, find, etc.) gets SIGPIPE → 141,
# pipefail propagates that to the pipeline's exit code, errexit fires.
# Prefer `head -N <<< "$str"` (herestring) or `head -N "$file"`
# (head reads the file directly so there's no producer to SIGPIPE).
# See read_result_value() below for the canonical pattern.

ISSUE_NUM="${1:-}"
export ISSUE_NUM

if [[ -z "$ISSUE_NUM" ]]; then
  echo "Usage: pnpm ai:run-issue <issue-number>" >&2
  exit 1
fi

# ── env / defaults ────────────────────────────────────────────────────────────
REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
cd "$REPO_ROOT"

declare -r _TSX_LOADER="${REPO_ROOT}/apps/cli/node_modules/tsx/dist/loader.mjs"
if [[ ! -f "$_TSX_LOADER" ]]; then
  echo "FATAL: tsx loader not found at $_TSX_LOADER (run 'pnpm ai:run-issue' to set up)" >&2; exit 1
fi

BASE_BRANCH="${BASE_BRANCH:-main}"
BRANCH="ai/issue-${ISSUE_NUM}"
# Derived from current repo; override with OWNER_REPO env var for cross-repo runs.
OWNER_REPO="${OWNER_REPO:-$(cd "$REPO_ROOT" && gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")}"
if [[ -z "$OWNER_REPO" ]]; then
  echo "FATAL: could not determine owner/repo. Set OWNER_REPO=<owner>/<repo> and retry." >&2
  exit 1
fi
PROMPTS_DIR="automation/prompts"

# Generate a unique run ID for agent invocation plumbing
# NOTE: The `date +%s%N` fallback is NOT UUID-guaranteed unique; uuidgen or python3
# should be available in production environments to avoid potential ID collisions.
RUN_ID="${AI_RUN_UUID:-${RUN_ID:-$(uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || date +%s%N)}}"
REPO_ID="${REPO_ID:-$OWNER_REPO}"

# Phase timeouts (seconds)
TIMEOUT_BRAINSTORM=600
TIMEOUT_PLAN_WRITE=600
TIMEOUT_IMPLEMENT=1800
TIMEOUT_VALIDATE=300
TIMEOUT_REVIEW=600
TIMEOUT_FIX=900
TIMEOUT_PR_FIX=1200
TIMEOUT_COMPOUND=600

# All artifacts live in the worktree (no cross-directory permission needed for sub-agents)
WORKTREE_DIR="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}"
ISSUES_DIR="${WORKTREE_DIR}"

# ── helpers (functions) ───────────────────────────────────────────────────────
log()  { echo "[$(date +%H:%M:%S)] $*" | tee -a "${ISSUES_DIR}/orchestrator.log" >&2; }
info() { log "INFO: $*"; }
warn() { log "WARN: $*" >&2; }

# Structured event helper — emits JSON lines to $AI_RUN_EVENTS_FILE.
# When AI_RUN_EVENTS_FILE is unset (standalone Bash run), emit_event is a no-op.
# shellcheck source=lib/emit_event.sh
source "${REPO_ROOT}/scripts/lib/emit_event.sh"

# shellcheck source=lib/guard-main-checkout.sh
source "${REPO_ROOT}/scripts/lib/guard-main-checkout.sh"

# ── Per-phase wall-clock tracking ─────────────────────────────────────────────
# Invariant: _emit_phase_started must always be called before _emit_phase_done
# in the same phase block. orchestrator_fail always exits the script, so a
# missing _emit_phase_done on failure paths is acceptable (phase.failed
# supersedes phase.completed). _LAST_PHASE_START_MS holds the start time of the
# current (most recently started) phase only.
_LAST_PHASE_START_MS=0
_HAS_NANOSECONDS=false
if date +%N >/dev/null 2>&1 && [[ "$(date +%N)" != "N" ]]; then
  _HAS_NANOSECONDS=true
fi
_now_ms() {
  if [[ "$_HAS_NANOSECONDS" == "true" ]]; then
    echo $(( $(date +%s%N) / 1000000 ))
  else
    echo $(( $(date +%s) * 1000 ))
  fi
}
_emit_phase_started() {
  local phase=$1
  _LAST_PHASE_START_MS=$(_now_ms)
  emit_event "$phase" "info" "phase.started" "phase ${phase} started"
}
_emit_phase_done() {
  local phase=$1
  local now ms_dur=0
  now=$(_now_ms)
  ms_dur=$(( now - _LAST_PHASE_START_MS ))
  (( ms_dur < 0 )) && ms_dur=0
  emit_event "$phase" "info" "phase.completed" "phase ${phase} completed" durationMs="$ms_dur"
}
_emit_phase_skipped() {
  local phase=$1 reason=${2:-resume-detected}
  emit_event "$phase" "warn" "phase.skipped" "phase ${phase} skipped" reason="$reason"
}
_emit_skipped_until() {
  local target=$1
  local p found=false
  for p in read_issue plan-design plan-write implement validate whole-pr-review fix-review compound create-pr; do
    if [[ "$p" == "$target" ]]; then found=true; break; fi
    _emit_phase_skipped "$p" "resume-detected"
  done
  if [[ "$found" == "false" ]]; then
    warn "_emit_skipped_until did not find phase '$target' in canonical list"
  fi
}
_emit_artifact() {
  local phase=$1 path=$2 kind=$3
  if [[ -f "$path" ]]; then
    emit_event "$phase" "info" "artifact.created" "artifact ${kind} written" path="$path" kind="$kind"
  fi
}

orchestrator_fail() {
  reason="$1"
  log "FAIL: $reason"
  emit_event "${LAST_PHASE:-unknown}" "error" "phase.failed" "$reason" reason="$reason"
  emit_event "" "error" "run.failed" "$reason" lastPhase="${LAST_PHASE:-unknown}" reason="$reason"
  if [[ "$reason" == *"blocked"* || "$reason" == *"Blocking"* || "$reason" == *"waiting"* ]]; then
    printf '{"phase":"%s","reason":"%s","time":"%s"}\n' \
      "${LAST_PHASE:-unknown}" "$reason" "$(date -Iseconds)" \
      > "${ISSUES_DIR}/blocked.json"
  fi
  gh issue edit "$ISSUE_NUM" --remove-label "ai:in-progress" 2>/dev/null || true
  gh issue edit "$ISSUE_NUM" --add-label "ai:failed" 2>/dev/null || true
  gh issue comment "$ISSUE_NUM" --body "Automation failed: $reason" 2>/dev/null || true
  exit 1
}

# Record an arbiter deviation — writes both a human-readable markdown file
# and a machine-parseable JSON file to the worktree, plus emits an event.
_record_deviation() {
  local task_num="$1"
  local defect_classification="$2"
  local outcome="$3"
  local evidence="$4"
  local rationale="$5"
  local deviation_md="${WORKTREE_DIR}/deviation-record-${task_num}.md"
  local deviation_json="${WORKTREE_DIR}/deviation-record-${task_num}.json"
  log "Recording deviation for task ${task_num}: ${outcome} (${defect_classification})"
  cat > "$deviation_md" << EOF
# Deviation Record — Issue #${ISSUE_NUM:-unknown}

## Task
Task ${task_num}

## Defect Classification
${defect_classification}

## Arbiter Outcome
${outcome}

## Evidence
${evidence}

## Rationale
${rationale}

## Timestamp
$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
  jq -nc \
    --arg task "$task_num" \
    --arg defect_classification "$defect_classification" \
    --arg outcome "$outcome" \
    --arg evidence "$evidence" \
    --arg rationale "$rationale" \
    --arg timestamp "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg issue "${ISSUE_NUM:-unknown}" \
    '{task: $task, defect_classification: $defect_classification, outcome: $outcome, evidence: $evidence, rationale: $rationale, timestamp: $timestamp, issue: $issue}' \
    > "$deviation_json"
  emit_event "arbitrate" "info" "arbiter.deviation_recorded" \
    "Deviation recorded for task ${task_num}: ${outcome}" \
    task="${task_num}" outcome="${outcome}" defect="${defect_classification}"
}

# ── review loop history ─────────────────────────────────────────────

_append_loop_history() {
  local iteration="$1"
  local spec_status="$2"
  local quality_status="$3"
  local fix_status="$4"
  local diff_summary="$5"
  local spec_review_excerpt="$6"
  local quality_review_excerpt="$7"
  REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
  local truncated_diff truncated_spec truncated_qual
  truncated_diff=$(head -20 <<< "$diff_summary")
  truncated_spec=$(head -30 <<< "$spec_review_excerpt")
  truncated_qual=$(head -30 <<< "$quality_review_excerpt")
  local new_entry
  new_entry=$(jq -nc \
    --arg iteration "$iteration" \
    --arg spec_status "$spec_status" \
    --arg quality_status "$quality_status" \
    --arg fix_status "$fix_status" \
    --arg fix_diff_summary "$truncated_diff" \
    --arg spec_review_excerpt "$truncated_spec" \
    --arg quality_review_excerpt "$truncated_qual" \
    '{iteration: ($iteration | tonumber), spec_status: $spec_status, quality_status: $quality_status, fix_status: $fix_status, fix_diff_summary: $fix_diff_summary, spec_review_excerpt: $spec_review_excerpt, quality_review_excerpt: $quality_review_excerpt}')
  if [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]]; then
    local current
    current=$(cat "$REVIEW_LOOP_HISTORY_FILE")
    echo "$current" | jq --argjson entry "$new_entry" '. + [$entry]' > "$REVIEW_LOOP_HISTORY_FILE"
  else
    echo "[$new_entry]" > "$REVIEW_LOOP_HISTORY_FILE"
  fi
}

_detect_loop_stall() {
  LOOP_STALL_TYPE="STALL_NONE"
  REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
  [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]] || return 0
  local count
  count=$(jq '. | length' "$REVIEW_LOOP_HISTORY_FILE" 2>/dev/null || echo 0)
  [[ "$count" -ge 3 ]] || return 0
  local last3_spec last3_qual
  last3_spec=$(jq -r '.[-3:] | .[].spec_status' "$REVIEW_LOOP_HISTORY_FILE" 2>/dev/null)
  last3_qual=$(jq -r '.[-3:] | .[].quality_status' "$REVIEW_LOOP_HISTORY_FILE" 2>/dev/null)
  local s1 s2 s3 q1 q2 q3
  s1=$(echo "$last3_spec" | sed -n '1p')
  s2=$(echo "$last3_spec" | sed -n '2p')
  s3=$(echo "$last3_spec" | sed -n '3p')
  q1=$(echo "$last3_qual" | sed -n '1p')
  q2=$(echo "$last3_qual" | sed -n '2p')
  q3=$(echo "$last3_qual" | sed -n '3p')
  if [[ "$s1" == "$s3" && "$s1" != "$s2" ]] || [[ "$q1" == "$q3" && "$q1" != "$q2" ]]; then
    LOOP_STALL_TYPE="STALL_OSCILLATION"
    return 0
  fi
  if [[ "$s1" == "$s2" && "$s2" == "$s3" && "$q1" == "$q2" && "$q2" == "$q3" ]]; then
    LOOP_STALL_TYPE="STALL_NO_PROGRESS"
    return 0
  fi
  return 0
}

_validate_arbiter_result() {
  ARBITER_VALID="false"
  ARBITER_OUTCOME=""
  ARBITER_DEFECT_CLASSIFICATION=""
  ARBITER_EVIDENCE=""
  ARBITER_RATIONALE=""
  ARBITER_AMENDED_VERIFICATION=""
  ARBITER_ORIGINAL_VERIFICATION=""
  local result_file="${WORKTREE_DIR}/arbiter-result.json"
  if [[ ! -f "$result_file" ]]; then
    warn "Arbiter result file not found: $result_file"
    return 1
  fi
  if ! jq -e '.' "$result_file" > /dev/null 2>&1; then
    warn "Arbiter result is not valid JSON: $result_file"
    return 1
  fi
  local outcome defect_class evidence
  outcome=$(jq -r '.outcome // ""' "$result_file")
  defect_class=$(jq -r '.defect_classification // ""' "$result_file")
  evidence=$(jq -r '.evidence // ""' "$result_file")
  local valid_outcomes="RESOLVED_TIEBREAK RESOLVED_AMENDED DEVIATION_PROCEED BLOCKED_IMPL_DEFECT"
  local found=0
  for vo in $valid_outcomes; do
    [[ "$outcome" == "$vo" ]] && found=1 && break
  done
  if [[ "$found" -eq 0 ]]; then
    warn "Arbiter outcome '${outcome}' is not a recognized value"
    return 1
  fi
  if [[ -z "$evidence" ]]; then
    warn "Arbiter evidence field is empty — treating as BLOCKED_IMPL_DEFECT (guardrail G1)"
    ARBITER_OUTCOME="BLOCKED_IMPL_DEFECT"
    ARBITER_DEFECT_CLASSIFICATION="implementation_defect"
    return 1
  fi
  if [[ "$defect_class" != "verification_spec_defect" && "$defect_class" != "implementation_defect" ]]; then
    warn "Arbiter defect_classification '${defect_class}' is invalid"
    return 1
  fi
  if [[ "$defect_class" == "implementation_defect" && "$outcome" != "BLOCKED_IMPL_DEFECT" ]]; then
    warn "Arbiter ${outcome} with implementation_defect — auto-proceed forbidden (guardrail G4)"
    return 1
  fi
  if [[ "$outcome" == "RESOLVED_AMENDED" ]]; then
    local amended original
    amended=$(jq -r '.amended_verification // ""' "$result_file")
    original=$(jq -r '.original_verification // ""' "$result_file")
    if [[ -z "$amended" ]]; then
      warn "Arbiter RESOLVED_AMENDED but amendment is empty — deleting a check is forbidden (guardrail G2)"
      return 1
    fi
    if [[ -z "$original" ]]; then
      warn "Arbiter RESOLVED_AMENDED but original command is empty — cannot validate narrowing"
      return 1
    fi
  fi
  ARBITER_OUTCOME="$outcome"
  ARBITER_DEFECT_CLASSIFICATION="$defect_class"
  ARBITER_EVIDENCE="$evidence"
  ARBITER_RATIONALE=$(jq -r '.rationale // ""' "$result_file")
  ARBITER_AMENDED_VERIFICATION=$(jq -r '.amended_verification // ""' "$result_file")
  ARBITER_ORIGINAL_VERIFICATION=$(jq -r '.original_verification // ""' "$result_file")
  ARBITER_VALID="true"
  return 0
}

# Verify worktree is on the correct branch; checkout if needed
ensure_branch() {
  local current
  current=$(cd "$WORKTREE_DIR" && git branch --show-current 2>/dev/null || echo "")
  if [[ "$current" != "${BRANCH}" ]]; then
    warn "Worktree on '${current}' (expected '${BRANCH}'), checking out..."
    (cd "$WORKTREE_DIR" && git checkout "${BRANCH}" 2>/dev/null) || orchestrator_fail "Failed to checkout ${BRANCH} in worktree"
  fi
}

# Verify worktree is still on the correct branch after agent execution
check_branch_after_agent() {
  local current
  current=$(cd "$WORKTREE_DIR" && git branch --show-current 2>/dev/null || echo "")
  if [[ "$current" != "${BRANCH}" ]]; then
    orchestrator_fail "Agent switched branch from ${BRANCH} to ${current}"
  fi
}
# Ensure $WORKTREE_DIR exists and is a valid git worktree on $BRANCH. Used by
# every phase after read_issue so resumes survive `git worktree prune`,
# archive pre-seeding that skips the read_issue setup path, and accidental
# rm-rf of .ai-worktrees/. Idempotent: no-op when the worktree is healthy.
ensure_worktree() {
  if [[ -e "${WORKTREE_DIR}/.git" ]]; then
    seed_excludes
    return 0
  fi

  # ISSUES_DIR == WORKTREE_DIR (see top of script), so log() can't write to its
  # usual path while the worktree is missing. Emit the recovery banner straight
  # to stderr; once recovery succeeds, normal log() resumes.
  echo "[$(date +%H:%M:%S)] WARN: Worktree missing at ${WORKTREE_DIR}, attempting recovery..." >&2

  cd "${REPO_ROOT}"
  git worktree prune 2>/dev/null || true
  git fetch origin "${BASE_BRANCH}" 2>/dev/null || true

  if git rev-parse --verify "${BRANCH}" 2>/dev/null; then
    # Local branch ref exists — attach a worktree to it.
    git worktree add "$WORKTREE_DIR" "$BRANCH" 2>&1 \
      || orchestrator_fail "Failed to attach worktree to local branch ${BRANCH}"
  elif git fetch origin "${BRANCH}" 2>/dev/null; then
    # Remote branch exists — recreate the branch from origin.
    git worktree add "$WORKTREE_DIR" -b "$BRANCH" "origin/${BRANCH}" 2>&1 \
      || orchestrator_fail "Failed to recreate worktree from origin/${BRANCH}"
  else
    orchestrator_fail "Worktree missing and no local or remote branch ${BRANCH} to recover from"
  fi

  if [[ ! -e "${WORKTREE_DIR}/.git" ]]; then
    orchestrator_fail "Worktree recovery completed but ${WORKTREE_DIR} is still not a worktree"
  fi
  log "Worktree recovered at ${WORKTREE_DIR}"
  seed_excludes
}

# Seed worktree-local exclude rules so orchestrator artifacts are never
# tracked. Skips the append when a sentinel pattern is already present, so
# the file doesn't accumulate duplicate blocks across every phase entry.
seed_excludes() {
  if [[ -z "${WORKTREE_DIR:-}" ]] || [[ ! -e "${WORKTREE_DIR}/.git" ]]; then
    return 1
  fi
  local common_dir exclude_file
  common_dir=$(cd "$WORKTREE_DIR" && git rev-parse --git-common-dir)
  exclude_file="${common_dir}/info/exclude"
  mkdir -p "${common_dir}/info"
  # Sentinel check: fix-status.txt is unique to the current block version, so
  # its presence means a previous seed_excludes call already wrote the full set.
  # Bumping the sentinel when the block changes causes a one-time re-seed in
  # existing worktrees (duplicate patterns in info/exclude are harmless).
  if [[ -f "$exclude_file" ]] && grep -qxF 'arbiter-result.json' "$exclude_file"; then
    return 0
  fi
  cat >> "$exclude_file" << 'EOF'
*.log
*.result
code-review.md
review.md
design.md
plan.md
compound.md
implementation-log.md
review-fix-log.md
validation*.md
issue*.json
issue*.md
pr-summary.md
pr-*.txt
MEMORY.md
AGENTS.md
CLAUDE.md
tsconfig.tsbuildinfo
spec-review-task-*.md
quality-review-task-*.md
review-findings-status.txt
fix-status.txt
implement-task-*.md
fix-review-task-*.md
fix-review-task-*.log
next-env.d.ts
node_modules/
.next/
.review-context/
arbiter-result.json
arbiter-task-*.log
arbiter-rationale-*.md
deviation-record-*.md
deviation-record-*.json
review-loop-history.json
EOF
}

# ── result resolution helpers ───────────────────────────────────────────────
#
# Hybrid result extraction: agent writes .result file (primary), extractor
# agent reads .md file (fallback), conservative default (tertiary).

# validate_result_file: returns 0 if file exists and contains an allowed value
# Read first non-whitespace token from a result file. Uses `head -1 file`
# (not `cat | head`) so head reads the file directly — no upstream
# producer that could be SIGPIPE'd when head closes after one line.
read_result_value() {
  head -1 "$1" 2>/dev/null | tr -d '[:space:]' || true
}

validate_result_file() {
  local result_file="$1"; shift
  local allowed_values=("$@")
  local val

  if [[ ! -f "$result_file" ]]; then
    return 1
  fi

  val=$(read_result_value "$result_file")
  if [[ -z "$val" ]]; then
    return 1
  fi

  local match=false
  for allowed in "${allowed_values[@]}"; do
    if [[ "$val" == "$allowed" ]]; then
      match=true
      break
    fi
  done

  if $match; then
    return 0
  else
    return 1
  fi
}

# validate_review_artifacts: checks that review artifacts satisfy the
# agent contract. An agent must always produce a non-empty .md findings
# file. The .result file is optional but, if present, must coexist with
# a non-empty .md. Returns 1 if the contract is broken, 0 if valid.
validate_review_artifacts() {
  local result_file="$1"
  local md_file="$2"
  if [[ ! -s "$md_file" ]]; then
    return 1
  fi
  return 0
}

# rerun_reviewer_once: re-run a single reviewer once after a contract violation
# (.result written without matching .md). Cleans up all orphaned artifacts
# from both ISSUES_DIR and WORKTREE_DIR so the re-run starts fresh.
# Uses ISSUES_DIR and WORKTREE_DIR from caller scope (dynamic bash globals
# set by the orchestrator's main loop).
rerun_reviewer_once() {
  local reviewer_type="$1"  # "spec" or "quality"
  local task_n="$2"
  local task_title="$3"
  local task_text="$4"
  local base_sha="$5"
  local head_sha="$6"

  log "  invalid_agent_contract: ${reviewer_type}-review-task-${task_n} failed to write valid review artifacts (missing/empty .md or missing both) — re-running once"

  # Clean up orphaned artifacts from both directories so the re-run starts fresh
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.md"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.md"

  if [[ "$reviewer_type" == "spec" ]]; then
    local impl_report="$7"
    SPEC_REVIEW_RERUN_WARNING=1 run_spec_reviewer "$task_n" "$task_title" "$task_text" "$impl_report"
  elif [[ "$reviewer_type" == "quality" ]]; then
    QUALITY_REVIEW_RERUN_WARNING=1 run_quality_reviewer "$task_n" "$task_title" "$task_text" "$base_sha" "$head_sha"
  fi
}

# rerun_reviewer_for_contradiction: re-run a reviewer for contradiction reconciliation.
# Same cleanup as rerun_reviewer_once but does NOT set *_RERUN_WARNING flags,
# because the prior review may be valid — it just disagrees with fix-review.
rerun_reviewer_for_contradiction() {
  local reviewer_type="$1"  # "spec" or "quality"
  local task_n="$2"
  local task_title="$3"
  local task_text="$4"
  local base_sha="$5"
  local head_sha="$6"

  log "  contradiction_retry: re-running ${reviewer_type}-review-task-${task_n} after review/fix contradiction"

  # Clean up orphaned artifacts from both directories so the re-run starts fresh
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.md"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.md"

  if [[ "$reviewer_type" == "spec" ]]; then
    local impl_report="$7"
    run_spec_reviewer "$task_n" "$task_title" "$task_text" "$impl_report"
  elif [[ "$reviewer_type" == "quality" ]]; then
    run_quality_reviewer "$task_n" "$task_title" "$task_text" "$base_sha" "$head_sha"
  fi
}

# handle_contradiction_reconciliation: when fix-review says DONE_NO_FIXES_NEEDED
# but a review says FAIL, re-run the failing review once.
# Sets CONTRADICTION_ACTION: "resolved" (both pass after re-run),
#   "retried" (re-run done but still failing — caller should orchestrator_fail),
#   "already_retried" (retry already consumed — caller should orchestrator_fail),
#   or "none" (no contradiction detected).
handle_contradiction_reconciliation() {
  local fix_status="$1"
  local spec_status="$2"
  local quality_status="$3"
  local task_num="$4"
  local task_title="$5"
  local task_text="$6"
  local base_sha="$7"
  local head_sha="$8"
  local impl_report="$9"

  CONTRADICTION_ACTION="none"

  if [[ "$fix_status" != "DONE_NO_FIXES_NEEDED" ]]; then
    return 0
  fi
  if [[ "$spec_status" == "SPEC_PASS" && "$quality_status" == "QUALITY_PASS" ]]; then
    return 0
  fi
  if [[ "$CONTRADICTION_RETRIED" -ge 1 ]]; then
    CONTRADICTION_ACTION="already_retried"
    return 0
  fi

  CONTRADICTION_RETRIED=1
  log "  Contradiction detected: review FAIL + fix-review DONE_NO_FIXES_NEEDED — re-running failing review once for task ${task_num}"
  emit_event "fix-review" "warn" "contradiction.detected" \
    "review/fix contradiction for task ${task_num}, re-running review" \
    task="${task_num}" iteration="${REVIEW_LOOPS}" spec="${spec_status}" quality="${quality_status}"

  # Preserve original review findings before rerun. If the re-run fails to
  # regenerate valid reports (timeout, contract violation), the orchestrator
  # will fail with reviews_inconsistent and the human operator needs the
  # original findings to triage — not empty or partial re-run output.
  local spec_md_backup="" quality_md_backup=""
  if [[ -f "${WORKTREE_DIR}/spec-review-task-${task_num}.md" ]]; then
    spec_md_backup="${WORKTREE_DIR}/spec-review-task-${task_num}.md.bak"
    cp "${WORKTREE_DIR}/spec-review-task-${task_num}.md" "$spec_md_backup"
  fi
  if [[ -f "${WORKTREE_DIR}/quality-review-task-${task_num}.md" ]]; then
    quality_md_backup="${WORKTREE_DIR}/quality-review-task-${task_num}.md.bak"
    cp "${WORKTREE_DIR}/quality-review-task-${task_num}.md" "$quality_md_backup"
  fi

  # Track which reviewers were re-run so restore logic only applies to them
  local spec_reran=0 quality_reran=0

  # Re-run whichever review(s) are failing (without contract-violation warning)
  if [[ "$spec_status" == "SPEC_FAIL" ]]; then
    spec_reran=1
    rerun_reviewer_for_contradiction "spec" "$task_num" "$task_title" "$task_text" "$base_sha" "$head_sha" "$impl_report"
  fi
  if [[ "$quality_status" == "QUALITY_FAIL" ]]; then
    quality_reran=1
    rerun_reviewer_for_contradiction "quality" "$task_num" "$task_title" "$task_text" "$base_sha" "$head_sha"
  fi

  # If the re-run didn't produce a valid .md, restore the original findings
  # BEFORE re-resolving statuses so the human operator has actionable evidence
  # in the reviews_inconsistent error — and so an empty rerun .md doesn't
  # produce a misleading PASS status from the stale .result file.
  # Only apply restore for reviewers that were actually re-run.
  if [[ "$spec_reran" -eq 1 && -n "$spec_md_backup" && ! -s "${WORKTREE_DIR}/spec-review-task-${task_num}.md" ]]; then
    log "  Spec review re-run produced no .md — restoring original findings from backup"
    cp "$spec_md_backup" "${WORKTREE_DIR}/spec-review-task-${task_num}.md"
    rm -f "${WORKTREE_DIR}/spec-review-task-${task_num}.result"
  fi
  if [[ "$quality_reran" -eq 1 && -n "$quality_md_backup" && ! -s "${WORKTREE_DIR}/quality-review-task-${task_num}.md" ]]; then
    log "  Quality review re-run produced no .md — restoring original findings from backup"
    cp "$quality_md_backup" "${WORKTREE_DIR}/quality-review-task-${task_num}.md"
    rm -f "${WORKTREE_DIR}/quality-review-task-${task_num}.result"
  fi

  # Clean up backup files
  rm -f "$spec_md_backup" "$quality_md_backup" 2>/dev/null || true

  # Re-resolve review statuses after re-run (and potential backup restore).
  # This must happen AFTER the backup restore so that an empty rerun .md
  # doesn't yield a PASS status from a stale .result while the .md contains
  # the original failing findings.
  SPEC_STATUS=$(resolve_result \
    "${WORKTREE_DIR}/spec-review-task-${task_num}.result" \
    "${WORKTREE_DIR}/spec-review-task-${task_num}.md" \
    SPEC_PASS SPEC_FAIL "SPEC_FAIL")
  QUALITY_STATUS=$(resolve_result \
    "${WORKTREE_DIR}/quality-review-task-${task_num}.result" \
    "${WORKTREE_DIR}/quality-review-task-${task_num}.md" \
    QUALITY_PASS QUALITY_FAIL "QUALITY_FAIL")

  # Update caller's status variables via globals (set above)
  if [[ "$SPEC_STATUS" == "SPEC_PASS" && "$QUALITY_STATUS" == "QUALITY_PASS" ]]; then
    log "  Task ${task_num}: contradiction resolved by review re-run, both reviews pass"
    CONTRADICTION_ACTION="resolved"
  else
    CONTRADICTION_ACTION="retried"
  fi
}

# extract_result: focused extractor agent that reads source .md and writes .result
extract_result() {
  local phase="$1"
  local result_file="$2"
  local source_file="$3"; shift 3
  local allowed_values=("$@")
  local allowed_regex
  allowed_regex=$(printf '|%s' "${allowed_values[@]}")
  allowed_regex="${allowed_regex:1}"

  log "  Extractor: reading ${source_file} for ${phase} result..."

  EXTRACTOR_PROMPT="You are a result extractor. Read the file below and determine the outcome.

## Source File
$(cat "$source_file" 2>/dev/null || echo "File not found: ${source_file}")

## Allowed Values
${allowed_regex}

## Your Task
Read the source file and determine which allowed value best describes the outcome.
Write EXACTLY ONE of the allowed values to the result file — nothing else, no explanation.

Result file: ${result_file}

Write the result now."

  local _extract_prompt_file
  _extract_prompt_file=$(mktemp)
  printf '%s' "$EXTRACTOR_PROMPT" > "$_extract_prompt_file"
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase extract \
    --phase-id "extract" \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --prompt-file "$_extract_prompt_file" \
    --timeout-minutes 1 \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/extract-${phase}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_extract_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for extract-${phase} (exit $_tee_ec)"
  fi
  if [[ $_agent_ec -ne 0 ]]; then
    case $_agent_ec in
      1) warn "extract-${phase} failed (contract violation)" ;;
      2) warn "extract-${phase} failed (config error or timeout)" ;;
      3) warn "extract-${phase} failed (unexpected error)" ;;
      *) warn "extract-${phase} failed (unknown exit code $_agent_ec)" ;;
    esac
    if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/extract-${phase}.log" 2>/dev/null; then
      warn "extract-${phase} is blocked (agent emitted BLOCKED)"
    fi
  fi
  check_branch_after_agent

  if validate_result_file "$result_file" "${allowed_values[@]}"; then
    log "  Extractor: successfully resolved ${phase} result"
    return 0
  else
    log "  Extractor: failed to resolve ${phase} result"
    return 1
  fi
}

# resolve_result: try .result file → extractor agent → fallback default
# Usage: resolve_result RESULT_FILE SOURCE_FILE ALLOWED_VAL1 ... ALLOWED_VALN FALLBACK
resolve_result() {
  local result_file="$1"
  local source_file="$2"; shift 2
  # Last arg is fallback, rest are allowed values
  local all_args=("$@")
  local fallback="${all_args[-1]}"
  local allowed_arr=("${all_args[@]:0:$(( ${#all_args[@]} - 1 ))}")

  # Detect invalid agent contract for review tasks: .result present but .md missing.
  # Only spec-review and quality-review require both files; implementer and
  # fix-review tasks only write .result, so the guard must not apply to them.
  local base_name
  base_name=$(basename "$result_file")
  local is_review_task=false
  if [[ "$base_name" == spec-review-task-*.result || "$base_name" == quality-review-task-*.result ]]; then
    is_review_task=true
  fi

  if $is_review_task && [[ -f "$result_file" && ! -f "$source_file" ]]; then
    log "  Result file present but source .md missing — invalid agent contract, ignoring stale .result"
    # Fall through to extractor (will fail since .md is absent), then fallback
  else
    # Primary: valid .result file
    if validate_result_file "$result_file" "${allowed_arr[@]}"; then
      local val
      val=$(read_result_value "$result_file")
      log "  Result (file): ${val}"
      echo "$val"
      return 0
    fi
  fi

  log "  Result file missing or invalid, trying extractor..."

  # Fallback: extractor agent reads .md file
  if [[ -f "$source_file" ]]; then
    if extract_result "$(basename "$result_file" .result)" "$result_file" "$source_file" "${allowed_arr[@]}"; then
      local val
      val=$(read_result_value "$result_file")
      log "  Result (extractor): ${val}"
      echo "$val"
      return 0
    fi
  fi

  # Tertiary: conservative fallback default
  log "  Result (fallback): ${fallback}"
  echo "$fallback" > "$result_file" 2>/dev/null || true
  echo "$fallback"
  return 0
}

# ── setup ─────────────────────────────────────────────────────────────────────
# Stage issue data in a temp directory outside the worktree, so it survives
# the rm-rf that happens before worktree creation on fresh runs.
ISSUE_STAGING_DIR="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}-staging"
mkdir -p "${ISSUES_DIR}"
mkdir -p "${ISSUE_STAGING_DIR}"
echo "" > "${ISSUES_DIR}/orchestrator.log"

log "=== Starting orchestrator for issue #${ISSUE_NUM} ==="

# ── auto-resume: task-level checkpoint detection ─────────────────────────────
LAST_PHASE="start"

  get_task_completion_status() {
    local task_n="$1"
    local impl_result_file="${ISSUES_DIR}/implement-task-${task_n}.result"
    local spec_result_file="${ISSUES_DIR}/spec-review-task-${task_n}.result"
    local quality_result_file="${ISSUES_DIR}/quality-review-task-${task_n}.result"
    local spec_md_file="${ISSUES_DIR}/spec-review-task-${task_n}.md"
    local quality_md_file="${ISSUES_DIR}/quality-review-task-${task_n}.md"

    local impl_result="PENDING"
    if [[ -f "$impl_result_file" ]]; then
      impl_result=$(cat "$impl_result_file" 2>/dev/null || echo "PENDING")
    fi

    # A task can only be complete if its implementation finished successfully.
    # DONE and DONE_WITH_CONCERNS are both treated as success — the original bug
    # was requiring exactly "DONE", which rewound resume past a
    # DONE_WITH_CONCERNS task whose reviews had already passed. Any other status
    # (BLOCKED / NEEDS_CONTEXT / PENDING / absent) is NOT complete, even if stale
    # SPEC_PASS/QUALITY_PASS artifacts are present: reviews alone must never let a
    # task skip a successful implementation.
    if [[ "$impl_result" != "DONE" && "$impl_result" != "DONE_WITH_CONCERNS" ]]; then
      if [[ -f "${ISSUES_DIR}/implement-task-${task_n}.log" ]]; then
        echo "implementing"
      else
        echo "pending"
      fi
      return
    fi

    # Implementation succeeded — completion is then decided by the reviews.
    if [[ ! -f "$spec_result_file" || ! -f "$quality_result_file" ]]; then
      echo "review-needed"
      return
    fi

    # A passing .result is only trustworthy alongside a valid (non-empty) review
    # report. If the reviewer wrote .result but not a real .md (killed mid-write,
    # or a contract violation), treat the task as review-needed so resume re-runs
    # the review — find_first_incomplete_task must not skip it on a bare .result.
    # Reuse the same check the in-loop path uses so the two cannot drift.
    if ! validate_review_artifacts "$spec_result_file" "$spec_md_file" \
      || ! validate_review_artifacts "$quality_result_file" "$quality_md_file"; then
      echo "review-needed"
      return
    fi

    local spec_result quality_result
    spec_result=$(cat "$spec_result_file" 2>/dev/null || echo "SPEC_FAIL")
    quality_result=$(cat "$quality_result_file" 2>/dev/null || echo "QUALITY_FAIL")

    if [[ "$spec_result" == "SPEC_PASS" && "$quality_result" == "QUALITY_PASS" ]]; then
      echo "complete"
    elif [[ -f "${ISSUES_DIR}/deviation-record-${task_n}.json" ]]; then
      local dev_outcome
      dev_outcome=$(jq -r '.outcome // ""' "${ISSUES_DIR}/deviation-record-${task_n}.json" 2>/dev/null || echo "")
      if [[ "$dev_outcome" == "DEVIATION_PROCEED" || "$dev_outcome" == "RESOLVED_TIEBREAK" ]]; then
        echo "complete"
      else
        echo "review-needed"
      fi
    else
      echo "review-needed"
    fi
  }

find_first_incomplete_task() {
  local plan_file="${ISSUES_DIR}/plan.md"
  if [[ ! -f "$plan_file" ]]; then
    echo "0"
    return
  fi

  local task_count
  task_count=$(awk '/^#{2,3} Task [0-9]+:/ {n++} END{print n+0}' "$plan_file")

  if [[ "$task_count" -eq 0 ]]; then
    echo "0"
    return
  fi

  local n=1
  while [[ $n -le "$task_count" ]]; do
    local status
    status=$(get_task_completion_status "$n")
    if [[ "$status" != "complete" ]]; then
      echo "$n"
      return
    fi
    n=$((n + 1))
  done

  echo "$((task_count + 1))"
}

detect_resume_point() {
  local first_incomplete
  first_incomplete=$(find_first_incomplete_task)

  if [[ "$first_incomplete" -eq 0 ]]; then
    echo "read_issue"
    return
  fi

  local status
  status=$(get_task_completion_status "$first_incomplete")

  case "$status" in
    complete)
      local task_count
      task_count=$(awk '/^#{2,3} Task [0-9]+:/ {n++} END{print n+0}' "${ISSUES_DIR}/plan.md")
      if [[ $first_incomplete -gt $task_count ]]; then
        echo "validate"
      else
        echo "implement"
      fi
      ;;
    implementing)    echo "implement" ;;
    pending)        echo "implement" ;;
    review-needed)  echo "spec-review" ;;
    *)              echo "implement" ;;
  esac
}

detect_phase() {
  if [[ -n "${ORCHESTRATOR_PHASE:-}" ]]; then
    echo "$ORCHESTRATOR_PHASE"
    return
  fi

  if [[ -f "${ISSUES_DIR}/pr-url.txt" ]]; then
    echo "done"
  elif [[ -f "${ISSUES_DIR}/compound.md" ]]; then
    echo "create-pr"
  elif [[ -f "${ISSUES_DIR}/review.md" ]]; then
    echo "fix-review"
  elif [[ -f "${ISSUES_DIR}/validate.log" ]]; then
    echo "whole-pr-review"
  elif [[ -f "${ISSUES_DIR}/plan.md" ]]; then
    detect_resume_point
  elif [[ -f "${ISSUES_DIR}/design.md" ]]; then
    echo "plan-write"
  elif [[ -f "${ISSUES_DIR}/issue.json" ]]; then
    echo "plan-design"
  else
    echo "read_issue"
  fi
}

# _lint_plan_verification: heuristic pre-check of plan verification commands
# after plan-write. Catches whole-file greps without line-range scoping that
# tend to produce unsatisfiable verification commands in the implement loop.
_lint_plan_verification() {
  local plan_file="${WORKTREE_DIR}/plan.md"
  [[ -f "$plan_file" ]] || return 0

  local grep_cmds
  grep_cmds=$(grep -oP '`(?:grep|rg)\s+[^`]+`' "$plan_file" 2>/dev/null || true)

  if [[ -n "$grep_cmds" ]]; then
    while IFS= read -r cmd; do
      if [[ "$cmd" =~ ^\`(grep|rg)[[:space:]]+-[a-zA-Z] ]] && ! [[ "$cmd" =~ awk|sed|head|tail|NR ]]; then
        warn "plan.lint: whole-file grep without line-range restriction in plan: ${cmd}"
        emit_event "plan-write" "warn" "plan.lint.warning" \
          "Whole-file grep without line-range restriction detected in plan" \
          command="${cmd}"
      fi
    done <<< "$grep_cmds"
  fi
}

PHASE="$(detect_phase)"
_INITIAL_PHASE="$PHASE"

log "Auto-resume: detected phase='${PHASE}'"

emit_event "" "info" "run.started" "issue-to-PR run started" \
  issueNumber="$ISSUE_NUM" baseBranch="${BASE_BRANCH:-main}" branch="$BRANCH"

if [[ "$PHASE" == "done" ]]; then
  log "Orchestrator already completed. See $(cat "${ISSUES_DIR}/pr-url.txt" 2>/dev/null || echo 'PR')."
  emit_event "" "info" "run.completed" "run already completed" \
    prUrl="$(cat "${ISSUES_DIR}/pr-url.txt" 2>/dev/null || echo '')"
  exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: read_issue
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "read_issue" ]]; then
  log "=== Phase: read_issue ==="
  _emit_phase_started "read_issue"
  LAST_PHASE="read_issue"

  # Guard: don't destroy existing progress on accidental re-entry
  if [[ -f "${ISSUES_DIR}/design.md" || -f "${ISSUES_DIR}/plan.md" ]]; then
    orchestrator_fail "read_issue phase reached but progress artifacts exist (design.md/plan.md). Likely a resume-detection bug. Use ORCHESTRATOR_PHASE=implement to force resume."
  fi

  # Fetch issue — write to staging dir (not worktree, which gets rm -rf'd below)
  gh issue view "$ISSUE_NUM" \
    --json number,title,body,url,labels,comments,state \
    > "${ISSUE_STAGING_DIR}/issue.json" \
    || orchestrator_fail "Failed to fetch issue #${ISSUE_NUM}"

  # Save issue body and comments
  gh issue view "$ISSUE_NUM" --json body --jq '.body' \
    > "${ISSUE_STAGING_DIR}/issue.md"

  # gh issue view --json comments returns at most 100 comments (GraphQL limit,
  # no auto-pagination). Use the REST endpoint with --paginate so issues with
  # hundreds of comments don't silently lose data.
  gh api --paginate "repos/${OWNER_REPO}/issues/${ISSUE_NUM}/comments" \
    --jq '.[].body' \
    > "${ISSUE_STAGING_DIR}/issue-comments.md"

  ISSUE_TITLE=$(gh issue view "$ISSUE_NUM" --json title --jq '.title')
  log "Issue #${ISSUE_NUM}: ${ISSUE_TITLE}"



  # Check for blocked label
  if gh issue view "$ISSUE_NUM" --json labels --jq '.labels[].name' | grep -qx "ai:blocked"; then
    orchestrator_fail "Issue has ai:blocked label"
  fi

  # Create worktree/branch
  info "Creating branch: ${BRANCH}"
  git fetch origin "$BASE_BRANCH" 2>/dev/null || true

  # Delete remote branch if it exists (fresh start)
  if git fetch origin "${BRANCH}" 2>/dev/null; then
    warn "Remote branch ${BRANCH} exists — deleting for fresh start"
    git push origin --delete "${BRANCH}" 2>/dev/null || true
  fi

  # Prune stale worktree admin refs, then create fresh worktree
  git worktree prune 2>/dev/null || true
  if ! git rev-parse --verify "${BRANCH}" 2>/dev/null; then
    rm -rf "$WORKTREE_DIR"
    git worktree add "$WORKTREE_DIR" -b "$BRANCH" "origin/${BASE_BRANCH}"
    if [[ ! -f "${WORKTREE_DIR}/.git" ]]; then
      orchestrator_fail "Worktree creation failed — ${WORKTREE_DIR} is not a git worktree"
    fi
  fi

  # Copy staged issue data into the worktree (survived the rm -rf above)
  cp "${ISSUE_STAGING_DIR}/issue.json" "${WORKTREE_DIR}/issue.json" 2>/dev/null || true
  cp "${ISSUE_STAGING_DIR}/issue.md" "${WORKTREE_DIR}/issue.md" 2>/dev/null || true
  cp "${ISSUE_STAGING_DIR}/issue-comments.md" "${WORKTREE_DIR}/issue-comments.md" 2>/dev/null || true
  cp "${ISSUES_DIR}/orchestrator.log" "${WORKTREE_DIR}/orchestrator.log" 2>/dev/null || true
  rm -rf "${ISSUE_STAGING_DIR}"

  # Copy prompts into worktree
  mkdir -p "${WORKTREE_DIR}/automation/prompts"
  cp -r "${REPO_ROOT}/${PROMPTS_DIR}"/*.md "${WORKTREE_DIR}/automation/prompts/" 2>/dev/null || true
  mkdir -p "${WORKTREE_DIR}/scripts"
  cp -r "${REPO_ROOT}/scripts/"*.sh "${WORKTREE_DIR}/scripts/" 2>/dev/null || true

  # Run artifacts (issue.json, issue.md, issue-comments.md) are written directly to worktree
  # Seed exclude rules so orchestrator artifacts are never tracked by git.
  seed_excludes

  # Archive pre-seeding: skip phases that already have outputs from a prior run
  ARCHIVE_DIR="${REPO_ROOT}/ai/issues/${ISSUE_NUM}"
  if [[ -f "${ARCHIVE_DIR}/plan.md" ]]; then
    info "Archive has plan.md — pre-seeding to skip plan-design and plan-write"
    cp "${ARCHIVE_DIR}/plan.md" "${WORKTREE_DIR}/plan.md"
    cp "${ARCHIVE_DIR}/design.md" "${WORKTREE_DIR}/design.md" 2>/dev/null || true
    PHASE="implement"
  elif [[ -f "${ARCHIVE_DIR}/design.md" ]]; then
    info "Archive has design.md — pre-seeding to skip plan-design"
    cp "${ARCHIVE_DIR}/design.md" "${WORKTREE_DIR}/design.md"
    PHASE="plan-write"
  else
    PHASE="plan-design"
  fi
  _emit_phase_done "read_issue"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: plan-design — brainstorm using the brainstorming skill
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "plan-design" ]]; then
  log "=== Phase: plan-design (brainstorm) ==="
  _emit_phase_started "plan-design"
  LAST_PHASE="plan-design"

  ensure_worktree

  BRAINSTORM_PROMPT="You are analyzing a GitHub issue to produce a design document.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue file: issue.md (contains the GitHub issue description)
Comments file: issue-comments.md (contains issue comments)

## TASK
1. Load the brainstorming skill: say exactly '/skill brainstorming' to activate it.
2. Read issue.md and issue-comments.md thoroughly.
3. Analyze the codebase to understand the existing patterns, types, and architecture relevant to this issue.
4. Using the brainstorming skill guidance, produce a design document at ./design.md covering:
   - The problem being solved and why it matters
   - Key design decisions and trade-offs considered
   - Proposed approach with rationale
   - Assumptions made (do not ask questions — state assumptions explicitly)
   - What is in scope and what is explicitly out of scope
   - Any risks or concerns identified from code analysis

## CRITICAL RULES
- Do NOT ask questions. Make reasonable assumptions and document them explicitly.
- Do NOT rely on agent memory. Write everything to design.md.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing design.md. Do not implement anything.

Write design.md now."

  # Write prompt to temp file for run-agent CLI
  _plan_prompt_file=$(mktemp)
  printf '%s' "$BRAINSTORM_PROMPT" > "$_plan_prompt_file"
  _main_state_before=$(_capture_main_state)
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase plan-design \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --phase-id plan-design \
    --prompt-file "$_plan_prompt_file" \
    --timeout-minutes $(( (TIMEOUT_BRAINSTORM + 59) / 60 )) \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/plan-design.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_plan_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for plan-design (exit $_tee_ec)"
  fi

  _guard_main_checkout "plan-design" "$_main_state_before"

  if [[ $_agent_ec -ne 0 ]]; then
    case $_agent_ec in
      1) orchestrator_fail "plan-design failed (contract violation)" ;;
      2) orchestrator_fail "plan-design failed (config error or timeout)" ;;
      3) orchestrator_fail "plan-design failed (unexpected error)" ;;
      *) orchestrator_fail "plan-design failed (unknown exit code $_agent_ec)" ;;
    esac
  fi

  if [[ ! -f "${WORKTREE_DIR}/design.md" ]]; then
    orchestrator_fail "Design doc not found after plan-design phase"
  fi
  info "Design doc saved to ${WORKTREE_DIR}/design.md"
  _emit_artifact "plan-design" "${WORKTREE_DIR}/design.md" "design"

  _emit_phase_done "plan-design"
  PHASE="plan-write"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: plan-write — write implementation plan using writing-plans skill
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "plan-write" ]]; then
  log "=== Phase: plan-write (implementation plan) ==="
  _emit_phase_started "plan-write"
  LAST_PHASE="plan-write"

  ensure_worktree

  # design.md lives in the worktree (written by plan-design agent) — no action needed

  PLAN_WRITE_PROMPT="You are writing an implementation plan.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Design doc: design.md (produced in the previous brainstorming step)
Issue file: issue.md
Comments file: issue-comments.md

## TASK
1. Load the writing-plans skill: say exactly '/skill writing-plans' to activate it.
2. Read design.md, issue.md, and issue-comments.md.
3. Using the writing-plans skill guidance, produce a complete implementation plan at ./plan.md.

The plan MUST include:
- goal
- non-goals
- affected files (full paths from repo root)
- ordered implementation tasks (numbered, clear description per task)
- tests to add or update
- validation commands (exact commands to verify correctness)
- risk areas
- stop conditions (what would cause you to abort instead of continue)
- Verification commands must be scoped to the files/paths explicitly changed by each task. Do NOT use whole-file grep/rg on files where the task only changes a subset — scope to specific line ranges or file sections.
- Prefer making verification an acceptance criterion of implementing tasks rather than a standalone "Full verification" task. If a standalone verification task is necessary, its verification commands must reference only files/paths explicitly in scope for that task.

## CRITICAL RULES
- Do NOT ask questions. Make reasonable assumptions and document them.
- Do NOT rely on agent memory. Write everything to plan.md.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing plan.md. Do not implement anything.
- All shell commands in the plan MUST be relative — no absolute paths, no cd to directories outside the worktree. The agent executing the plan runs inside the worktree and cannot access paths outside it. Commands like 'pnpm --filter @ai-sdlc/domain test -- --run ...' should work without any cd prefix.
- Do NOT edit any source files (*.ts, *.js, *.sh, *.py, etc.). Your ONLY output is plan.md.
- If you find yourself wanting to edit source code, STOP — that is for the implement phase.

Write plan.md now."

  _plan_prompt_file=$(mktemp)
  printf '%s' "$PLAN_WRITE_PROMPT" > "$_plan_prompt_file"
  _main_state_before=$(_capture_main_state)
  _worktree_sha_before=$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || echo "")
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase plan-write \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --phase-id plan-write \
    --prompt-file "$_plan_prompt_file" \
    --timeout-minutes $(( (TIMEOUT_PLAN_WRITE + 59) / 60 )) \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/plan-write.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_plan_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for plan-write (exit $_tee_ec)"
  fi

  _pre_was_dirty=0
  _expected_sha=""
  if [[ -n "$_main_state_before" ]]; then
    IFS='|' read -r _expected_sha _pre_was_dirty _ <<< "$_main_state_before"
  fi

  _main_checkout_violations=""
  if [[ $_pre_was_dirty -eq 0 ]]; then
    _main_checkout_violations=$({
      git -C "$REPO_ROOT" diff --name-only 2>/dev/null
      git -C "$REPO_ROOT" diff --cached --name-only 2>/dev/null
      git -C "$REPO_ROOT" ls-files --others --exclude-standard 2>/dev/null
      if [[ -n "$_expected_sha" ]]; then
        git -C "$REPO_ROOT" diff --name-only "$_expected_sha"..HEAD 2>/dev/null
      fi
    } | grep -vE '^(plan\.md|design\.md|\.gitignore)$' | tr '\n' ' ' || true)
  fi

  _guard_main_checkout "plan-write" "$_main_state_before"

  _worktree_violations=$({
    git -C "$WORKTREE_DIR" diff --name-only HEAD 2>/dev/null
    git -C "$WORKTREE_DIR" ls-files --others --exclude-standard 2>/dev/null
    if [[ -n "$_worktree_sha_before" ]]; then
      git -C "$WORKTREE_DIR" diff --name-only "$_worktree_sha_before"..HEAD 2>/dev/null
    fi
  } | grep -vE '^(plan\.md|design\.md|\.gitignore)$' | tr '\n' ' ' || true)

  _all_violations="${_main_checkout_violations}${_worktree_violations}"
  if [[ -n "$_all_violations" ]]; then
    orchestrator_fail "plan-write agent modified source files (contract violation): ${_all_violations}"
  fi

  if [[ $_agent_ec -ne 0 ]]; then
    case $_agent_ec in
      1) orchestrator_fail "plan-write failed (contract violation)" ;;
      2) orchestrator_fail "plan-write failed (config error or timeout)" ;;
      3) orchestrator_fail "plan-write failed (unexpected error)" ;;
      *) orchestrator_fail "plan-write failed (unknown exit code $_agent_ec)" ;;
    esac
  fi

  if [[ ! -f "${WORKTREE_DIR}/plan.md" ]]; then
    orchestrator_fail "Plan file not found after plan-write phase"
  fi
  info "Plan saved to ${WORKTREE_DIR}/plan.md"
  _emit_artifact "plan-write" "${WORKTREE_DIR}/plan.md" "plan"

  _emit_phase_done "plan-write"

  _lint_plan_verification

  PHASE="implement"
fi

# ── Map resume phases into implement with correct resume stage ──────────────
if [[ "$PHASE" == "spec-review" ]]; then
  # These phases are now handled inside the review-fix loop.
  # Map to "implement" with resume stage "review" so the task loop re-enters correctly.
  info "Auto-resume: mapping phase '${PHASE}' to implement with review stage"
  RESUME_STAGE_OVERRIDE="review"
  PHASE="implement"
fi

if [[ "$_INITIAL_PHASE" != "read_issue" ]]; then _emit_skipped_until "$PHASE"; fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: implement — subagent-driven development per task
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "implement" ]]; then
  log "=== Phase: implement ==="
  _emit_phase_started "implement"
  LAST_PHASE="implement"

  ensure_worktree

  if [[ -f "${ISSUES_DIR}/blocked.json" ]]; then
    orchestrator_fail "Orchestrator is blocked from previous phase"
  fi

  TASK_MANIFEST="${ISSUES_DIR}/task-manifest.json"

  # ── helpers ────────────────────────────────────────────────────────────────

  # Parse numbered tasks from plan.md, output one per line: "N. Title"
  parse_tasks() {
    local plan_file="$1"
    grep -E "^#{2,3} Task [0-9]+:" "$plan_file" 2>/dev/null | sed -E "s/^#{2,3} Task [0-9]+: //" || true
  }

  # Extract full task text (from ## Task N: title line to the next ## section header)
  # Uses a temp file for the task_title to avoid all bash interpolation issues
  # with special chars (backticks, asterisks, $(), etc.) in task titles.
  # Terminates on: any ^##  line (section header like ## Risk Areas, ## Stop Conditions, etc.)
  extract_task_text() {
    local plan_file="$1"
    local task_title="$2"

    local title_file
    title_file=$(mktemp)
    printf '%s' "$task_title" > "$title_file"

    local line_num
    line_num=$(grep -F -n -f "$title_file" "$plan_file" 2>/dev/null | head -1 | cut -d: -f1 || true)
    rm -f "$title_file"

    if [[ -z "$line_num" ]]; then return 1; fi

    printf '%s' "$task_title" > "$title_file"
    tail -n +"$line_num" "$plan_file" | awk -v title_file="$title_file" '
      BEGIN {
        while ((getline line < title_file) > 0) { title = line }
        close(title_file)
        buf_idx = 0
      }
      NF == 0 { next }
      index($0, title) > 0 { in_task=1; next }
      /^## / {
        if (in_task) {
          for (i = 1; i <= buf_idx; i++) print buf[i]
          exit
        }
      }
      in_task { buf[++buf_idx] = $0 }
    '
    rm -f "$title_file"
  }

  # Get task number from title prefix
  task_num() { echo "$1" | cut -d. -f1; }

  extract_task_commit_msg() {
    local plan_file="$1"
    local task_title="$2"
    local fallback_msg="$3"

    local title_file
    title_file=$(mktemp)
    printf '%s' "$task_title" > "$title_file"

    local line_num
    line_num=$(grep -F -n -f "$title_file" "$plan_file" 2>/dev/null | head -1 | cut -d: -f1 || true)
    rm -f "$title_file"

    if [[ -z "$line_num" ]]; then
      echo "$fallback_msg"
      return
    fi

    local next_task_line
    next_task_line=$(awk -v start="$line_num" 'NR > start && /^#{2,3} Task [0-9]+:/ {print NR; exit}' "$plan_file")

    local commit_msg
    if [[ -n "$next_task_line" ]]; then
      commit_msg=$(sed -n "${line_num},$((next_task_line - 1))p" "$plan_file" | grep -oP 'git commit -m "\K[^"]+' | tail -1)
    else
      commit_msg=$(tail -n +"$line_num" "$plan_file" | grep -oP 'git commit -m "\K[^"]+' | tail -1)
    fi

    if [[ -n "$commit_msg" ]]; then
      echo "$commit_msg"
    else
      echo "$fallback_msg"
    fi
  }

  # Run implementer for a single task; writes status to file (not stdout)
  run_implementer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local commit_msg="$4"
    local output_log="${ISSUES_DIR}/implement-task-${task_n}.log"
    local impl_status="unknown"

    log "  Task ${task_n}: implementing..."

    IMPLEMENTER_PROMPT="You are implementing Task ${task_n}: ${task_title}

## Task Description
${task_text}

## Context
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Design: design.md
Plan: plan.md
Branch: ${BRANCH}

You are using Subagent-Driven Development. Follow the process below exactly.

## SCOPE RESTRICTION
You are implementing ONLY Task ${task_n}: ${task_title}.

Tasks numbered higher than ${task_n} in plan.md are EXPLICITLY OUT OF SCOPE
for this run. They will be implemented by separate later runs of this
orchestrator. You must NOT:
- create files, types, schemas, tests, exports, or migrations that belong
  to a later task, even if you have all the context to do so;
- 'finish the plan' because tasks N+1..M look small or related;
- pre-stage scaffolding for later tasks 'to save time later'.

A commit that includes any later-task work is a scope violation, not
helpfulness — it breaks per-task review, makes resume undecidable, and
forces the operator to revert and re-run. The plan's per-task commit
boundary is load-bearing: respect it.

If you finish Task ${task_n} quickly: STOP, run the self-review, and
report DONE. Do not 'continue' into the next task.

You may READ files associated with later tasks for context, but you must
not write, modify, stage, or commit them in this run.

## Your Job

1. Read issue.md, design.md, and plan.md for context. Identify the
   boundaries of Task ${task_n} specifically.
2. Implement exactly what Task ${task_n} specifies — nothing more.
3. Write tests following TDD where applicable, scoped to Task ${task_n}.
4. Verify Task ${task_n}'s implementation works.
5. Run: git add -A && git commit -m '${commit_msg}'
6. Self-review before reporting back, including the scope check below.

## Questions?
If you have clarifications or concerns BEFORE implementing, note them in your report
and proceed with a reasonable assumption. Do not ask questions — make decisions
and document them.

## Self-Review Checklist (before reporting back)
- Scope: Run \`git diff --stat HEAD~1\` mentally — does every changed
  file belong to Task ${task_n} alone? If any file is for a later task,
  REMOVE it from the commit before reporting DONE.
- Completeness: Did I implement everything Task ${task_n} specifies?
- Quality: Is the code clean and maintainable?
- Discipline: Did I avoid overbuilding?
- Testing: Do tests verify actual behavior?

## Report Format
Report back with:
- Status: DONE | DONE_WITH_CONCERNS | BLOCKED | NEEDS_CONTEXT
- What you implemented
- What you tested and results
- Files changed
- Self-review findings
- Any questions or concerns

## MANDATORY RESULT FILE
After reporting, write EXACTLY ONE of these values to ./implement-task-${task_n}.result:
- DONE
- DONE_WITH_CONCERNS
- BLOCKED
- NEEDS_CONTEXT
No other content in the file — just the status word.

Stop after writing the result file.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    local _impl_prompt_file
    _impl_prompt_file=$(mktemp)
    printf '%s' "$IMPLEMENTER_PROMPT" > "$_impl_prompt_file"
    local _main_state_before
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase implement \
      --phase-id "implement-task-${task_n}" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_impl_prompt_file" \
      --timeout-minutes $(( (TIMEOUT_IMPLEMENT + 59) / 60 )) \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/implement-task-${task_n}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_impl_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      orchestrator_fail "tee failed writing log for implement-task-${task_n} (exit $_tee_ec)"
    fi
    _guard_main_checkout "implement-task-${task_n}" "$_main_state_before"
    check_branch_after_agent
    if [[ $_agent_ec -ne 0 ]]; then
      if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/implement-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "implement-task-${task_n} is blocked (agent emitted BLOCKED)"
      else
        case $_agent_ec in
          1) orchestrator_fail "implement-task-${task_n} failed (contract violation)" ;;
          2) orchestrator_fail "implement-task-${task_n} failed (config error or timeout)" ;;
          3) orchestrator_fail "implement-task-${task_n} failed (unexpected error)" ;;
          *) orchestrator_fail "implement-task-${task_n} failed (unknown exit code $_agent_ec)" ;;
        esac
      fi
    fi
  }

  # Run spec reviewer for a single task; writes result to file (not stdout)
  run_spec_reviewer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local impl_report="$4"
    local output_log="${ISSUES_DIR}/spec-review-task-${task_n}.log"

    log "  Task ${task_n}: spec review..."

    SPEC_REVIEWER_PROMPT="You are reviewing whether an implementation matches its specification.

## Design Context
Read these files for full context on what was intended:
- Design: ./design.md
- Implementation plan: ./plan.md

## SCOPE RESTRICTION — READ THIS TWICE
You are reviewing ONLY Task ${task_n}: ${task_title}.

The plan is executed ONE TASK AT A TIME by separate agent invocations. Tasks
numbered higher than ${task_n} have NOT been started yet. It is EXPECTED and
CORRECT that their files, functions, tests, and behaviors do not exist yet.

DO NOT flag any of the following as issues:
- Missing files, exports, types, or functions that belong to tasks > ${task_n}
- Missing tests for behavior specified in tasks > ${task_n}
- Incomplete features that the plan assigns to tasks > ${task_n}
- Any mention of 'task X not implemented' or 'task Y is missing' where X/Y > ${task_n}

Your review must be ENTIRELY about whether Task ${task_n} alone meets its
requirements. If Task ${task_n} is complete and correct, the result is
SPEC_PASS regardless of what other tasks in the plan have not been started.

## Task Requirements
${task_text}

## What Implementer Claims They Built
$(head -n 50 <<< "$impl_report")

## CRITICAL: Do Not Trust the Report
You MUST read the actual code and verify line by line. Do not take the
implementer's word for what was built.

## Your Job
1. Read the design and plan documents first for context on this specific task.
2. Read the code that was actually committed.
3. Compare actual implementation to THIS task's requirements only.
4. Check for missing pieces within this task's scope.
5. Check for extra work not requested within this task's scope.
6. Check for misunderstandings.

## Report Format
- ✅ Spec compliant (if everything matches)
- ❌ Issues found: [list specifically with file:line references]

## MANDATORY OUTPUT FILES — write BOTH, in this exact order

Write both files to these EXACT absolute paths (not relative — a relative
path resolves against the wrong workspace and the orchestrator never sees it):

**Step 1**: Write \`${WORKTREE_DIR}/spec-review-task-${task_n}.md\` — the detailed
findings the fix-review agent will read. Include every issue with file:line
references, the spec requirement violated, and what would satisfy it. If
everything passes, write a single line: 'No findings. Implementation matches the spec.'

**Step 2**: Write \`${WORKTREE_DIR}/spec-review-task-${task_n}.result\` — EXACTLY ONE of:
SPEC_PASS | SPEC_FAIL. No other content — just the status word.

CRITICAL ORDERING RULE:
- You MUST write the .md file FIRST, then the .result file LAST.
- Do NOT write the .result file until you have finalized your verdict.
- The .result file is your final action before stopping.
- If you changed your mind during analysis, rewrite BOTH files with the
  final verdict. The .result file must match the conclusion in the .md file.

STOP RULE — THIS IS THE MOST IMPORTANT RULE:
After writing BOTH files you are DONE. Do NOT:
- Re-read any files
- Re-verify your work
- Run any commands
- Start the review over
- Do anything at all

You MUST emit no further actions after the .result file is written.
Any action after writing .result is a contract violation.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    if [[ "${SPEC_REVIEW_RERUN_WARNING:-}" == "1" ]]; then
      SPEC_REVIEWER_PROMPT="WARNING: Your previous attempt wrote the .result file but did not write the .md report file. This is a contract violation. You MUST write BOTH files in order: .md first, then .result last.

${SPEC_REVIEWER_PROMPT}"
    fi

    REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
    if [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]]; then
      local history_excerpt _hist_tmp
      _hist_tmp=$(mktemp)
      jq -r '.[] | "Iteration \(.iteration): spec=\(.spec_status) quality=\(.quality_status) fix=\(.fix_status)\n\(.spec_review_excerpt)"' "$REVIEW_LOOP_HISTORY_FILE" > "$_hist_tmp" 2>/dev/null || true
      history_excerpt=$(head -60 "$_hist_tmp")
      rm -f "$_hist_tmp"
      SPEC_REVIEWER_PROMPT="${SPEC_REVIEWER_PROMPT}

## Prior Iteration History (for context — DO NOT repeat failed approaches)
${history_excerpt}"
    fi

    local _spec_prompt_file
    _spec_prompt_file=$(mktemp)
    printf '%s' "$SPEC_REVIEWER_PROMPT" > "$_spec_prompt_file"
    local _main_state_before
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase spec-review \
      --phase-id "spec-review-task-${task_n}" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_spec_prompt_file" \
      --timeout-minutes $(( (TIMEOUT_REVIEW + 59) / 60 )) \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/spec-review-task-${task_n}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_spec_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      orchestrator_fail "tee failed writing log for spec-review-task-${task_n} (exit $_tee_ec)"
    fi
    _guard_main_checkout "spec-review-task-${task_n}" "$_main_state_before"
    check_branch_after_agent
    if [[ $_agent_ec -eq 2 ]]; then
      if grep -qE '(unknown phase|unknown profile|no agent config|must pass|missing required flag|prompt file not found|not configured)' "${ISSUES_DIR}/spec-review-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "spec-review-task-${task_n} failed (config error in log)"
      elif [[ -f "${WORKTREE_DIR}/spec-review-task-${task_n}.result" && -f "${WORKTREE_DIR}/spec-review-task-${task_n}.md" ]]; then
        warn "Spec review timed out but both artifacts exist — proceeding"
      else
        orchestrator_fail "Spec review timed out and artifacts are missing (result=${WORKTREE_DIR}/spec-review-task-${task_n}.result, md=${WORKTREE_DIR}/spec-review-task-${task_n}.md)"
      fi
    elif [[ $_agent_ec -ne 0 ]]; then
      if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/spec-review-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "spec-review-task-${task_n} is blocked (agent emitted BLOCKED)"
      else
        case $_agent_ec in
          1) orchestrator_fail "spec-review-task-${task_n} failed (contract violation)" ;;
          3) orchestrator_fail "spec-review-task-${task_n} failed (unexpected error)" ;;
          *) orchestrator_fail "spec-review-task-${task_n} failed (unknown exit code $_agent_ec)" ;;
        esac
      fi
    fi
  }

  # Run quality reviewer for a single task; writes result to file (not stdout)
  run_quality_reviewer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local base_sha="$4"
    local head_sha="$5"
    local output_log="${ISSUES_DIR}/quality-review-task-${task_n}.log"

    log "  Task ${task_n}: quality review..."

    QUALITY_REVIEWER_PROMPT="You are reviewing the quality of an implementation.

## Design Context
Read these files for full context on what was intended:
- Design: ./design.md
- Implementation plan: ./plan.md

## SCOPE RESTRICTION — READ THIS TWICE
You are reviewing ONLY Task ${task_n}: ${task_title}.

The plan is executed ONE TASK AT A TIME by separate agent invocations. Tasks
numbered higher than ${task_n} have NOT been started yet. It is EXPECTED and
CORRECT that their files, functions, tests, and behaviors do not exist yet.

DO NOT flag any of the following as issues:
- Missing files, exports, types, or functions that belong to tasks > ${task_n}
- Missing tests for behavior specified in tasks > ${task_n}
- Incomplete features that the plan assigns to tasks > ${task_n}
- Any mention of 'task X not implemented' or 'task Y is missing' where X/Y > ${task_n}

Your review must be ENTIRELY about the quality of Task ${task_n}'s implementation.
If Task ${task_n} is complete and correct, the result is QUALITY_PASS regardless
of what other tasks in the plan have not been started.

## Task Summary
${task_title}

## Task Requirements
${task_text}

## What Was Implemented
Files changed (see git diff ${base_sha}..${head_sha})

## Your Job
Run: git diff ${base_sha}..${head_sha}

First, check if the diff contains code changes (*.ts, *.tsx, *.js, *.jsx, *.py, etc.) or is documentation-only (*.md, *.txt, *.rst, etc.). Then review accordingly:

**If the diff contains code changes**, review for:
- Code cleanliness and maintainability
- Proper testing
- Following existing patterns
- Single responsibility per file

**If the diff is documentation-only**, review for:
- Accuracy: do the changes correctly describe the system behavior?
- Clarity: is the writing clear and unambiguous?
- Consistency: do the changes align with other documentation and the actual codebase?
- Formatting: proper markdown, no broken links or typos?

Do NOT fail a documentation-only change for lacking tests, code patterns, or code-specific criteria. A documentation change that is accurate, clear, and consistent should get QUALITY_PASS.

## Report Format
- Strengths: [what was done well]
- Issues: [Critical | Important | Minor]
- Assessment: APPROVED | NEEDS_WORK

## MANDATORY OUTPUT FILES — write BOTH

Write both files to these EXACT absolute paths (not relative — a relative
path resolves against the wrong workspace and the orchestrator never sees it):

1. ${WORKTREE_DIR}/quality-review-task-${task_n}.md
   The detailed findings the fix-review agent will read. Include every
   issue with file:line references, severity, and what would resolve it.
   If everything passes, write a single line:
   'No findings. Implementation meets the quality bar.'

2. ${WORKTREE_DIR}/quality-review-task-${task_n}.result
   EXACTLY ONE of: QUALITY_PASS | QUALITY_FAIL
   No other content in the file — just the status word.

Both files MUST be written before you stop, even on QUALITY_PASS. The
.md file is the primary handoff to the fix-review agent — without it,
the orchestrator silently marks the task complete despite failures.

STOP RULE — THIS IS THE MOST IMPORTANT RULE:
After writing BOTH files you are DONE. Do NOT:
- Re-read any files
- Re-verify your work
- Run any commands
- Start the review over
- Do anything at all

You MUST emit no further actions after the .result file is written.
Any action after writing .result is a contract violation.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    if [[ "${QUALITY_REVIEW_RERUN_WARNING:-}" == "1" ]]; then
      QUALITY_REVIEWER_PROMPT="WARNING: Your previous attempt wrote the .result file but did not write the .md report file. This is a contract violation. You MUST write BOTH files in order: .md first, then .result last.

${QUALITY_REVIEWER_PROMPT}"
    fi

    REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
    if [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]]; then
      local history_excerpt _hist_tmp
      _hist_tmp=$(mktemp)
      jq -r '.[] | "Iteration \(.iteration): spec=\(.spec_status) quality=\(.quality_status) fix=\(.fix_status)\n\(.quality_review_excerpt)"' "$REVIEW_LOOP_HISTORY_FILE" > "$_hist_tmp" 2>/dev/null || true
      history_excerpt=$(head -60 "$_hist_tmp")
      rm -f "$_hist_tmp"
      QUALITY_REVIEWER_PROMPT="${QUALITY_REVIEWER_PROMPT}

## Prior Iteration History (for context — DO NOT repeat failed approaches)
${history_excerpt}"
    fi

    local _qual_prompt_file
    _qual_prompt_file=$(mktemp)
    printf '%s' "$QUALITY_REVIEWER_PROMPT" > "$_qual_prompt_file"
    local _main_state_before
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase quality-review \
      --phase-id "quality-review-task-${task_n}" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_qual_prompt_file" \
      --timeout-minutes $(( (TIMEOUT_REVIEW + 59) / 60 )) \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/quality-review-task-${task_n}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_qual_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      orchestrator_fail "tee failed writing log for quality-review-task-${task_n} (exit $_tee_ec)"
    fi
    _guard_main_checkout "quality-review-task-${task_n}" "$_main_state_before"
    check_branch_after_agent
    if [[ $_agent_ec -eq 2 ]]; then
      if grep -qE '(unknown phase|unknown profile|no agent config|must pass|missing required flag|prompt file not found|not configured)' "${ISSUES_DIR}/quality-review-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "quality-review-task-${task_n} failed (config error in log)"
      elif [[ -f "${WORKTREE_DIR}/quality-review-task-${task_n}.result" && -f "${WORKTREE_DIR}/quality-review-task-${task_n}.md" ]]; then
        warn "Quality review timed out but both artifacts exist — proceeding"
      else
        orchestrator_fail "Quality review timed out and artifacts are missing (result=${WORKTREE_DIR}/quality-review-task-${task_n}.result, md=${WORKTREE_DIR}/quality-review-task-${task_n}.md)"
      fi
    elif [[ $_agent_ec -ne 0 ]]; then
      if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/quality-review-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "quality-review-task-${task_n} is blocked (agent emitted BLOCKED)"
      else
        case $_agent_ec in
          1) orchestrator_fail "quality-review-task-${task_n} failed (contract violation)" ;;
          3) orchestrator_fail "quality-review-task-${task_n} failed (unexpected error)" ;;
          *) orchestrator_fail "quality-review-task-${task_n} failed (unknown exit code $_agent_ec)" ;;
        esac
      fi
    fi
  }

  # Run fix-review: agent reads both review reports and fixes findings
  run_fix_review() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"

    log "  Task ${task_n}: fix review..."

    local spec_findings="" quality_findings=""
    local spec_md="${WORKTREE_DIR}/spec-review-task-${task_n}.md"
    local quality_md="${WORKTREE_DIR}/quality-review-task-${task_n}.md"
    if [[ -s "$spec_md" ]]; then
      spec_findings=$(cat "$spec_md")
    fi
    if [[ -s "$quality_md" ]]; then
      quality_findings=$(cat "$quality_md")
    fi

    if [[ -z "$spec_findings" && -z "$quality_findings" ]]; then
      orchestrator_fail "Task ${task_n} fix-review has no findings to act on. Reviewer agents must write detailed findings."
    fi

    FIX_REVIEW_PROMPT="You are fixing review findings for Task ${task_n}: ${task_title}

## Task Requirements
${task_text}

## Spec Review Findings
${spec_findings}

## Quality Review Findings
${quality_findings}

## Your Job
1. Read both review reports above carefully.
2. Read the actual source files referenced in the reviews.
3. Fix ALL legitimate findings. Skip findings that are:
   - Invalid (the reviewer was wrong)
   - Pre-existing (not introduced by this task)
   - Nitpicks that don't affect correctness
4. If neither review has actionable findings, write 'Status: DONE_NO_FIXES_NEEDED' and stop.
5. If you made fixes, run: git add -A && git commit -m 'fix: task ${task_n} review findings'
6. Self-verify your fixes address the actual findings.

## Report Format
Report back with:
- Status: DONE | DONE_NO_FIXES_NEEDED | BLOCKED
- What you fixed (with file references)
- What you intentionally skipped and why
- Any remaining concerns

## MANDATORY RESULT FILE
After reporting, write EXACTLY ONE of these values to ./fix-review-task-${task_n}.result:
- DONE
- DONE_NO_FIXES_NEEDED
- BLOCKED
No other content in the file — just the status word.

Stop after writing the result file.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
    if [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]]; then
      local history_excerpt _hist_tmp
      _hist_tmp=$(mktemp)
      jq -r '.[] | "Iteration \(.iteration): spec=\(.spec_status) quality=\(.quality_status) fix=\(.fix_status)\nDiff summary:\n\(.fix_diff_summary)"' "$REVIEW_LOOP_HISTORY_FILE" > "$_hist_tmp" 2>/dev/null || true
      history_excerpt=$(head -80 "$_hist_tmp")
      rm -f "$_hist_tmp"
      FIX_REVIEW_PROMPT="${FIX_REVIEW_PROMPT}

## Prior Iteration History (DO NOT repeat approaches that already failed)
${history_excerpt}"
    fi

    local _fix_prompt_file
    _fix_prompt_file=$(mktemp)
    printf '%s' "$FIX_REVIEW_PROMPT" > "$_fix_prompt_file"
    local _main_state_before
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase fix-review \
      --phase-id "fix-review-task-${task_n}" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_fix_prompt_file" \
      --timeout-minutes $(( (TIMEOUT_FIX + 59) / 60 )) \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/fix-review-task-${task_n}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_fix_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      orchestrator_fail "tee failed writing log for fix-review-task-${task_n} (exit $_tee_ec)"
    fi
    _guard_main_checkout "fix-review-task-${task_n}" "$_main_state_before"
    check_branch_after_agent
    if [[ $_agent_ec -ne 0 ]]; then
      if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/fix-review-task-${task_n}.log" 2>/dev/null; then
        orchestrator_fail "fix-review-task-${task_n} is blocked (agent emitted BLOCKED)"
      else
        case $_agent_ec in
          1) orchestrator_fail "fix-review-task-${task_n} failed (contract violation)" ;;
          2) orchestrator_fail "fix-review-task-${task_n} failed (config error or timeout)" ;;
          3) orchestrator_fail "fix-review-task-${task_n} failed (unexpected error)" ;;
          *) orchestrator_fail "fix-review-task-${task_n} failed (unknown exit code $_agent_ec)" ;;
        esac
      fi
    fi
  }

  # Run arbiter: when the review/fix loop is stuck (oscillation or no-progress),
  # invoke an arbiter agent to diagnose the deadlock and pick exactly one
  # corrective action. Writes arbiter-result.json and arbiter-rationale.md
  # to the worktree. Non-zero agent exit does NOT halt the run — the caller
  # (Task 8) decides what to do with the result.
  run_arbiter() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local base_sha="$4"
    local head_sha="$5"
    local spec_status="$6"
    local quality_status="$7"

    log "  Task ${task_n}: invoking arbiter (oscillation/stall detected)..."

    REVIEW_LOOP_HISTORY_FILE="${REVIEW_LOOP_HISTORY_FILE:-${WORKTREE_DIR}/review-loop-history.json}"
    local history_content=""
    if [[ -f "$REVIEW_LOOP_HISTORY_FILE" ]]; then
      history_content=$(cat "$REVIEW_LOOP_HISTORY_FILE")
    fi

    local spec_findings="" quality_findings=""
    local spec_md="${WORKTREE_DIR}/spec-review-task-${task_n}.md"
    local quality_md="${WORKTREE_DIR}/quality-review-task-${task_n}.md"
    [[ -s "$spec_md" ]] && spec_findings=$(cat "$spec_md")
    [[ -s "$quality_md" ]] && quality_findings=$(cat "$quality_md")

    local issue_text=""
    [[ -f "${WORKTREE_DIR}/issue.md" ]] && issue_text=$(head -100 "${WORKTREE_DIR}/issue.md")

    ARBITER_PROMPT="You are an arbiter diagnosing a stuck review/fix loop for Task ${task_n}: ${task_title}.

## Your Role
You do NOT write feature code. You diagnose the deadlock and pick exactly ONE corrective action.

## Context — Original Issue (excerpt)
${issue_text}

## Context — Plan Task Requirements
${task_text}

## Context — Review Verdicts
- Spec review: ${spec_status}
- Quality review: ${quality_status}

## Context — Spec Review Findings
${spec_findings}

## Context — Quality Review Findings
${quality_findings}

## Context — Iteration History
${history_content}

## Your Job
Diagnose why the loop is stuck and output exactly ONE action.

## Output Format
Write EXACTLY ONE JSON object to ${WORKTREE_DIR}/arbiter-result.json with this schema:

{
  \"outcome\": \"RESOLVED_TIEBREAK | RESOLVED_AMENDED | DEVIATION_PROCEED | BLOCKED_IMPL_DEFECT\",
  \"defect_classification\": \"verification_spec_defect | implementation_defect\",
  \"evidence\": \"file:line and/or issue/plan clause that justifies this outcome (REQUIRED — must not be empty)\",
  \"rationale\": \"human-readable explanation of why this outcome is correct\",
  \"amended_verification\": \"(only for RESOLVED_AMENDED) the corrected verification command, strictly narrower than original\",
  \"original_verification\": \"(only for RESOLVED_AMENDED) the original verification command that was wrong\"
}

## Rules
1. RESOLVED_TIEBREAK: Override with a binding PASS verdict. Evidence must cite what makes the failure spurious.
2. RESOLVED_AMENDED: Rewrite a demonstrably-wrong verification command to match the task's declared scope. The amendment MUST be strictly narrower — you cannot remove a check entirely.
3. DEVIATION_PROCEED: The blocker is a verification/spec defect that cannot be auto-fixed. Proceed to PR with a deviation flag.
4. BLOCKED_IMPL_DEFECT: The blocker is a genuine implementation defect. The run must stop.
5. Evidence field is MANDATORY. If you cannot cite evidence, output BLOCKED_IMPL_DEFECT.
6. Only verification_spec_defect classification may auto-proceed. implementation_defect must stop the run.

## MANDATORY OUTPUT FILE
Write the JSON to: ${WORKTREE_DIR}/arbiter-result.json

Also write a human-readable rationale to: ${WORKTREE_DIR}/arbiter-rationale-${task_n}.md

Stop after writing both files.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    local _arbiter_prompt_file
    _arbiter_prompt_file=$(mktemp)
    printf '%s' "$ARBITER_PROMPT" > "$_arbiter_prompt_file"
    local _main_state_before
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase arbitrate \
      --phase-id "arbitrate-task-${task_n}" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_arbiter_prompt_file" \
      --timeout-minutes 10 \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/arbiter-task-${task_n}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_arbiter_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      # Arbiter is a soft intervention (see plan): a log-tee hiccup must not
      # abort the run. Warn and continue, consistent with the non-zero
      # agent-exit handling below. The arbitrate phase is the documented
      # exception to the "all phases halt on tee failure" rule.
      warn "tee failed writing log for arbiter-task-${task_n} (exit $_tee_ec)"
    fi
    _guard_main_checkout "arbiter-task-${task_n}" "$_main_state_before"
    check_branch_after_agent
    if [[ $_agent_ec -ne 0 ]]; then
      warn "Arbiter agent exited with code $_agent_ec — attempting to read result if present"
    fi

    emit_event "arbitrate" "info" "arbiter.invoked" \
      "Arbiter invoked for task ${task_n}" \
      task="${task_n}" spec="${spec_status}" quality="${quality_status}" exit_code="${_agent_ec:-0}"
  }

  # ── main task loop ─────────────────────────────────────────────────────────
  cd "${WORKTREE_DIR}"
  ensure_branch

  log "Installing dependencies in worktree..."
  {
    echo "=== pnpm install ==="
    timeout 120 pnpm install --frozen-lockfile 2>&1 | tail -10 || echo "[install completed with warnings]"
  } > >(tee -a "${ISSUES_DIR}/install-worktree.log") 2>&1 || true

  log "Building workspace packages in worktree..."
  {
    echo "=== pnpm -r build ==="
    timeout 180 pnpm -r build 2>&1 | tail -20 || echo "[build completed with warnings]"
  } > >(tee -a "${ISSUES_DIR}/install-worktree.log") 2>&1 || true

  if [[ ! -f "plan.md" ]]; then
    orchestrator_fail "plan.md not found in worktree"
  fi

  TASKS=$(parse_tasks "plan.md")
  TASK_COUNT=$(echo "$TASKS" | grep -c "." || echo 0)

  if [[ $TASK_COUNT -eq 0 ]]; then
    orchestrator_fail "No tasks found in plan.md"
  fi

  log "Found ${TASK_COUNT} task(s) to implement"

  TASK_NUM=0
  IMPLEMENTATION_LOG="${ISSUES_DIR}/implementation-log.md"
  echo "# Implementation Log — Issue #${ISSUE_NUM}" > "$IMPLEMENTATION_LOG"
  _emit_artifact "implement" "${ISSUES_DIR}/implementation-log.md" "implementation_log"

  RESUME_TASK_NUM=0
  RESUME_STAGE=""
  RESUME_TASK_NUM=$(find_first_incomplete_task)
  if [[ -n "${RESUME_STAGE_OVERRIDE:-}" ]]; then
    RESUME_STAGE="$RESUME_STAGE_OVERRIDE"
    log "Auto-resume: task ${RESUME_TASK_NUM}, stage '${RESUME_STAGE}' (from detected phase)"
  else
    RESUME_STAGE="implement"
    log "Auto-resume: task ${RESUME_TASK_NUM}, stage '${RESUME_STAGE}'"
  fi

  while IFS= read -r task_title; do
    TASK_NUM=$((TASK_NUM + 1))

    if [[ $TASK_NUM -lt $RESUME_TASK_NUM ]]; then
      log "  Skipping completed task ${TASK_NUM}"
      continue
    fi

    log "=== Task ${TASK_NUM}/${TASK_COUNT}: ${task_title} ==="

    TASK_TEXT=$(extract_task_text "plan.md" "$task_title")
    if [[ -z "$TASK_TEXT" ]]; then
      warn "Could not extract task text for '${task_title}', using title as description"
      TASK_TEXT="$task_title"
    fi

    BASE_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")

    COMMIT_MSG=$(extract_task_commit_msg "plan.md" "$task_title" "feat: implement issue #${ISSUE_NUM} task ${TASK_NUM}")

    if [[ "$TASK_NUM" -eq "$RESUME_TASK_NUM" && "$RESUME_STAGE" == "review" ]]; then
      log "  Resuming at review loop for task ${TASK_NUM}"
    fi

    IMPL_STATUS="DONE"
    HEAD_SHA=""
    REVIEW_LOOPS=0
    CONTRADICTION_RETRIED=0
    # Track whether we implemented this session. On a resume directly into review
    # (DID_IMPLEMENT=0) later tasks may be stacked on the branch tip, so we must
    # not refresh the persisted head marker with that tip after fixes.
    DID_IMPLEMENT=0
    if [[ -f "${WORKTREE_DIR}/deviation-record-${TASK_NUM}.json" ]]; then
      ARBITER_INVOKED_FOR_TASK=1
      ARBITER_OUTCOME=$(jq -r '.outcome // ""' "${WORKTREE_DIR}/deviation-record-${TASK_NUM}.json")
    else
      ARBITER_INVOKED_FOR_TASK=""
      ARBITER_OUTCOME=""
    fi

    # Step 1: Implement (skipped when resuming directly into the review stage)
    if [[ $TASK_NUM -gt $RESUME_TASK_NUM || "$RESUME_STAGE" == "implement" || -z "$RESUME_STAGE" ]]; then
      # Persist the pre-implementation base SHA so a later resume into the review
      # stage can still compute this task's real diff. BASE_SHA above is the
      # pre-impl HEAD on a fresh run, but on resume it is the *post*-impl HEAD.
      echo "$BASE_SHA" > "${WORKTREE_DIR}/implement-task-${TASK_NUM}.basesha.log"
      run_implementer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$COMMIT_MSG"
      IMPL_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/implement-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/implement-task-${TASK_NUM}.md" \
        DONE DONE_WITH_CONCERNS BLOCKED NEEDS_CONTEXT \
        "DONE")
      log "  Implementer status: ${IMPL_STATUS}"

      if [[ "$IMPL_STATUS" == "BLOCKED" || "$IMPL_STATUS" == "NEEDS_CONTEXT" ]]; then
        orchestrator_fail "Task ${TASK_NUM} is ${IMPL_STATUS}. Fix the blocker and re-run."
      fi

      HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
      # Persist the post-impl head too, so a later resume into this task's review
      # uses THIS task's tip — not the branch tip, which may already carry later
      # tasks' commits and would pollute the review diff with unrelated changes.
      echo "$HEAD_SHA" > "${WORKTREE_DIR}/implement-task-${TASK_NUM}.headsha.log"
      DID_IMPLEMENT=1
    else
      # Resuming directly into review: the implement step ran in a prior session.
      # BASE_SHA above is the *post*-impl HEAD here, so a naive base..head range
      # would be empty and the quality reviewer would see no changes. Recover the
      # real range: base = persisted pre-impl SHA, head = current HEAD.
      if [[ -s "${WORKTREE_DIR}/implement-task-${TASK_NUM}.basesha.log" ]]; then
        BASE_SHA=$(cat "${WORKTREE_DIR}/implement-task-${TASK_NUM}.basesha.log" 2>/dev/null || echo "$BASE_SHA")
      else
        # No marker (task implemented before this was added) — best-effort to the
        # parent commit so the reviewer still sees a diff rather than nothing.
        BASE_SHA=$(git rev-parse HEAD~1 2>/dev/null || echo "$BASE_SHA")
        warn "No persisted base SHA for task ${TASK_NUM}; using HEAD~1 for the review diff range"
      fi
      # Use the task's own post-impl head, not the branch tip: later tasks may
      # already be committed on top, and reviewing base..tip would span them and
      # pass/fail the resumed task on unrelated changes.
      if [[ -s "${WORKTREE_DIR}/implement-task-${TASK_NUM}.headsha.log" ]]; then
        HEAD_SHA=$(cat "${WORKTREE_DIR}/implement-task-${TASK_NUM}.headsha.log" 2>/dev/null || echo "")
      else
        HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
        warn "No persisted head SHA for task ${TASK_NUM}; review diff may include later tasks' commits"
      fi
    fi

    # Step 2: Initial spec + quality reviews, then fix loop (max 5 iterations).
    # We always run initial reviews here — even on resume. Reaching this point
    # on a resumed run means find_first_incomplete_task returned this task
    # because its status is "review-needed" (i.e. reviews are NOT both passing
    # yet). Skipping reviews in that state would silently mark the task
    # complete with no review evidence, as happened on the issue #4 run.
    # Reset loop history BEFORE initial reviewers so Task 2+ does not read
    # stale iteration data from the previous task's review-loop-history.json.
    REVIEW_LOOP_HISTORY_FILE="${WORKTREE_DIR}/review-loop-history.json"
    rm -f "$REVIEW_LOOP_HISTORY_FILE"
    IMPL_REPORT=$(cat "${ISSUES_DIR}/implement-task-${TASK_NUM}.log" 2>/dev/null || echo "")
    run_spec_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$IMPL_REPORT"
    run_quality_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"

    # Validate review artifacts: .result without .md = invalid agent contract
    # Both files are written by the agent to WORKTREE_DIR using relative paths.
    spec_result="${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result"
    spec_md="${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md"
    quality_result="${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result"
    quality_md="${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md"

    # Validate spec-review artifacts
    if ! validate_review_artifacts "$spec_result" "$spec_md"; then
      rerun_reviewer_once "spec" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA" "$IMPL_REPORT"
      if ! validate_review_artifacts "$spec_result" "$spec_md"; then
        orchestrator_fail "invalid_agent_contract: spec-review-task-${TASK_NUM} failed to write valid review artifacts after re-run (missing/empty .md or missing both)"
      fi
    fi

    # Validate quality-review artifacts
    if ! validate_review_artifacts "$quality_result" "$quality_md"; then
      rerun_reviewer_once "quality" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"
      if ! validate_review_artifacts "$quality_result" "$quality_md"; then
        orchestrator_fail "invalid_agent_contract: quality-review-task-${TASK_NUM} failed to write valid review artifacts after re-review (missing/empty .md or missing both)"
      fi
    fi

    # Resolve initial review statuses
    SPEC_STATUS=$(resolve_result \
      "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result" \
      "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md" \
      SPEC_PASS SPEC_FAIL "SPEC_FAIL")
    QUALITY_STATUS=$(resolve_result \
      "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result" \
      "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md" \
      QUALITY_PASS QUALITY_FAIL "QUALITY_FAIL")

    # Record initial review statuses as iteration 0
    _append_loop_history \
      0 "$SPEC_STATUS" "$QUALITY_STATUS" "INITIAL" \
      "" "" ""

    if [[ "$SPEC_STATUS" == "SPEC_PASS" && "$QUALITY_STATUS" == "QUALITY_PASS" ]]; then
      log "  Task ${TASK_NUM}: both initial reviews pass — skipping fix loop"
    else
    # Fix-review loop: agent fixes findings, then re-reviews, up to 5 times
    while [[ $REVIEW_LOOPS -lt 5 ]]; do
      REVIEW_LOOPS=$((REVIEW_LOOPS + 1))
      log "  Review-fix loop ${REVIEW_LOOPS}/5 for task ${TASK_NUM}"
      emit_event "fix-review" "info" "loop.iteration.started" \
        "fix-review loop ${REVIEW_LOOPS}/5 for task ${TASK_NUM}" \
        task="${TASK_NUM}" iteration="${REVIEW_LOOPS}" max=5
      log "  Cancel window: press Ctrl+C within 10s to abort..."
      sleep 10

      _head_before_fix=$(git rev-parse HEAD 2>/dev/null || echo "")
      run_fix_review "$TASK_NUM" "$task_title" "$TASK_TEXT"
      FIX_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/fix-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/fix-review-task-${TASK_NUM}.md" \
        DONE DONE_NO_FIXES_NEEDED BLOCKED \
        "DONE")

      if [[ "$FIX_STATUS" == "BLOCKED" ]]; then
        orchestrator_fail "Task ${TASK_NUM} fix review is blocked. Fix the blocker and re-run."
      fi

      # Only advance HEAD_SHA if the fix actually committed something. If it did
      # not (e.g. DONE_NO_FIXES_NEEDED), keep the current scoped head so the
      # re-review range stays base..task-N-head rather than expanding to the
      # branch tip — which, on a resume with later tasks stacked, would re-review
      # unrelated commits. Refresh the persisted marker only in normal flow
      # (DID_IMPLEMENT=1), where the new tip is genuinely this task's head.
      _head_after_fix=$(git rev-parse HEAD 2>/dev/null || echo "")
      if [[ -n "$_head_after_fix" && "$_head_after_fix" != "$_head_before_fix" ]]; then
        HEAD_SHA="$_head_after_fix"
        if [[ $DID_IMPLEMENT -eq 1 ]]; then
          echo "$HEAD_SHA" > "${WORKTREE_DIR}/implement-task-${TASK_NUM}.headsha.log"
        else
          # Resume-into-review AND the fix committed. If later tasks are stacked
          # (this task's scoped head is an ancestor of, but not equal to, the
          # pre-fix tip), the fix lands above them and base..HEAD_SHA now spans
          # the later tasks too. There is no single contiguous range that isolates
          # this task plus its fix, so we surface it rather than silently
          # mis-scoping the re-review. Root prevention is not entering this state
          # (completion-gating) — see issue #170.
          _scoped_head=$(cat "${WORKTREE_DIR}/implement-task-${TASK_NUM}.headsha.log" 2>/dev/null || echo "")
          if [[ -n "$_scoped_head" && "$_scoped_head" != "$_head_before_fix" ]] \
            && git merge-base --is-ancestor "$_scoped_head" "$_head_before_fix" 2>/dev/null; then
            warn "Task ${TASK_NUM}: fix committed during a resume with later tasks stacked on top; re-review diff (${BASE_SHA}..${HEAD_SHA}) may include unrelated later-task commits (non-contiguous range, see #170)."
          fi
        fi
      fi

      # Check current review status after fix attempt
      log "  Task ${TASK_NUM}: re-running reviews after fix loop..."
      IMPL_REPORT=$(cat "${ISSUES_DIR}/fix-review-task-${TASK_NUM}.log" 2>/dev/null || echo "")
      run_spec_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$IMPL_REPORT"
      run_quality_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"

      # Validate re-review artifacts (same pattern as initial reviews above)
      if ! validate_review_artifacts "$spec_result" "$spec_md"; then
        rerun_reviewer_once "spec" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA" "$IMPL_REPORT"
        if ! validate_review_artifacts "$spec_result" "$spec_md"; then
          orchestrator_fail "invalid_agent_contract: spec-review-task-${TASK_NUM} failed to write valid review artifacts after re-review (missing/empty .md or missing both)"
        fi
      fi
      if ! validate_review_artifacts "$quality_result" "$quality_md"; then
        rerun_reviewer_once "quality" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"
        if ! validate_review_artifacts "$quality_result" "$quality_md"; then
          orchestrator_fail "invalid_agent_contract: quality-review-task-${TASK_NUM} failed to write valid review artifacts after re-review (missing/empty .md or missing both)"
        fi
      fi

      # Check if reviews now pass — resolve from result files
      SPEC_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md" \
        SPEC_PASS SPEC_FAIL \
        "SPEC_FAIL")
      QUALITY_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md" \
        QUALITY_PASS QUALITY_FAIL \
        "QUALITY_FAIL")

      emit_event "fix-review" "info" "loop.iteration.completed" \
        "fix-review loop ${REVIEW_LOOPS} completed (spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?})" \
        task="${TASK_NUM}" iteration="${REVIEW_LOOPS}" \
        spec="${SPEC_STATUS:-unknown}" quality="${QUALITY_STATUS:-unknown}"

      _append_loop_history \
        "$REVIEW_LOOPS" "$SPEC_STATUS" "$QUALITY_STATUS" "$FIX_STATUS" \
        "$(git -C "$WORKTREE_DIR" diff HEAD~1 2>/dev/null | head -20 || echo "")" \
        "$(head -30 "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md" 2>/dev/null || echo "")" \
        "$(head -30 "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md" 2>/dev/null || echo "")"

      _detect_loop_stall
      if [[ "$LOOP_STALL_TYPE" != "STALL_NONE" ]]; then
        log "  Task ${TASK_NUM}: stall detected (${LOOP_STALL_TYPE}) — invoking arbiter"
        emit_event "arbitrate" "warn" "arbiter.stall_detected" \
          "Stall detected for task ${TASK_NUM}: ${LOOP_STALL_TYPE}" \
          task="${TASK_NUM}" stall_type="${LOOP_STALL_TYPE}" iteration="${REVIEW_LOOPS}"
        ARBITER_INVOKED_FOR_TASK="${ARBITER_INVOKED_FOR_TASK:-}"
        if [[ -n "$ARBITER_INVOKED_FOR_TASK" ]]; then
          if [[ "${ARBITER_OUTCOME}" == "RESOLVED_AMENDED" ]]; then
            log "  Task ${TASK_NUM}: arbiter already invoked (RESOLVED_AMENDED), amendment did not resolve — halting as implementation defect"
            _record_deviation "$TASK_NUM" "implementation_defect" "BLOCKED_IMPL_DEFECT" \
              "Arbiter invoked once (RESOLVED_AMENDED) but loop still stalled — amendment did not resolve" \
              "Post-amendment stall indicates genuine implementation defect (guardrail G3/G4)"
            orchestrator_fail "Task ${TASK_NUM}: post-arbiter stall after RESOLVED_AMENDED — classified as implementation defect"
          fi
          if [[ "${ARBITER_OUTCOME}" == "BLOCKED_IMPL_DEFECT" ]]; then
            log "  Task ${TASK_NUM}: previous arbiter classified BLOCKED_IMPL_DEFECT — halting (guardrail G4 preserves stop condition)"
            orchestrator_fail "Task ${TASK_NUM}: previous arbiter classification was BLOCKED_IMPL_DEFECT — G4 prevents auto-proceed on resume"
          fi
          log "  Task ${TASK_NUM}: arbiter already invoked for this task — recording deviation and proceeding (guardrail G3)"
          _record_deviation "$TASK_NUM" "verification_spec_defect" "DEVIATION_PROCEED" \
            "Arbiter already invoked once (cap 1 per task), loop still stalled" \
            "Loop stalled after arbiter attempt; proceeding with deviation"
          break
        fi
        ARBITER_INVOKED_FOR_TASK=1
        rm -f "${WORKTREE_DIR}/arbiter-result.json"
        run_arbiter "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA" "$SPEC_STATUS" "$QUALITY_STATUS"
        _validate_arbiter_result || true
        emit_event "arbitrate" "info" "arbiter.resolved" \
          "Arbiter resolved for task ${TASK_NUM}: ${ARBITER_OUTCOME}" \
          task="${TASK_NUM}" outcome="${ARBITER_OUTCOME}" valid="${ARBITER_VALID}"
        if [[ "$ARBITER_VALID" != "true" ]]; then
          if [[ "${ARBITER_DEFECT_CLASSIFICATION:-implementation_defect}" == "implementation_defect" || "$ARBITER_OUTCOME" == "BLOCKED_IMPL_DEFECT" ]]; then
            _record_deviation "$TASK_NUM" "implementation_defect" "BLOCKED_IMPL_DEFECT" \
              "${ARBITER_EVIDENCE:-validation failed}" "${ARBITER_RATIONALE:-no rationale}"
            orchestrator_fail "Task ${TASK_NUM}: arbiter classified as implementation defect. Stopping run."
          fi
          _record_deviation "$TASK_NUM" "verification_spec_defect" "DEVIATION_PROCEED" \
            "Arbiter result invalid but defect is verification-related" \
            "${ARBITER_RATIONALE:-no rationale}"
          log "  Task ${TASK_NUM}: arbiter result invalid, proceeding with deviation"
          break
        fi
        case "$ARBITER_OUTCOME" in
          RESOLVED_TIEBREAK)
            SPEC_STATUS="SPEC_PASS"
            QUALITY_STATUS="QUALITY_PASS"
            log "  Task ${TASK_NUM}: arbiter tiebreak — overriding to PASS"
            _record_deviation "$TASK_NUM" "$ARBITER_DEFECT_CLASSIFICATION" "RESOLVED_TIEBREAK" \
              "$ARBITER_EVIDENCE" "$ARBITER_RATIONALE"
            break
            ;;
          RESOLVED_AMENDED)
            log "  Task ${TASK_NUM}: arbiter amended verification — re-running reviews once"
            _record_deviation "$TASK_NUM" "$ARBITER_DEFECT_CLASSIFICATION" "RESOLVED_AMENDED" \
              "$ARBITER_EVIDENCE" "$ARBITER_RATIONALE"
            if [[ -n "$ARBITER_ORIGINAL_VERIFICATION" && -n "$ARBITER_AMENDED_VERIFICATION" ]]; then
              plan_before=$(cat "${WORKTREE_DIR}/plan.md" 2>/dev/null || echo "")
              python3 -c "
import sys, os, re
worktree = os.environ.get('WORKTREE_DIR', '.')
path = os.path.join(worktree, 'plan.md')
with open(path) as f:
    lines = f.readlines()
task_num = int(sys.argv[3])
task_pattern = re.compile(r'^#{2,3} Task ' + str(task_num) + ':')
task_boundary = re.compile(r'^#{2,3} Task ')
task_start = -1
task_end = -1
for i, line in enumerate(lines):
    if task_pattern.match(line):
        task_start = i
    elif task_boundary.match(line) and task_start >= 0 and task_end < 0:
        task_end = i
        break
if task_end < 0:
    task_end = len(lines)
if task_start >= 0:
    for i in range(task_start, task_end):
        lines[i] = lines[i].replace(sys.argv[1], sys.argv[2])
with open(path, 'w') as f:
    f.writelines(lines)
" "$ARBITER_ORIGINAL_VERIFICATION" "$ARBITER_AMENDED_VERIFICATION" "$TASK_NUM"
              plan_after=$(cat "${WORKTREE_DIR}/plan.md" 2>/dev/null || echo "")
              if [[ "$plan_before" == "$plan_after" ]]; then
                warn "plan amendment: str.replace did not change plan.md — original_verification not found verbatim"
                _record_deviation "$TASK_NUM" "verification_spec_defect" "DEVIATION_PROCEED" \
                  "Arbiter amendment failed: original_verification not found verbatim in plan.md" \
                  "${ARBITER_RATIONALE}"
                break
              else
                log "  Task ${TASK_NUM}: applied verification amendment to plan.md"
                TASK_TEXT=$(extract_task_text "${WORKTREE_DIR}/plan.md" "$task_title" 2>/dev/null || echo "$TASK_TEXT")
                if [[ -z "$TASK_TEXT" ]]; then
                  TASK_TEXT="$task_title"
                fi
              fi
            fi
            ;;
          DEVIATION_PROCEED)
            _record_deviation "$TASK_NUM" "$ARBITER_DEFECT_CLASSIFICATION" "DEVIATION_PROCEED" \
              "$ARBITER_EVIDENCE" "$ARBITER_RATIONALE"
            log "  Task ${TASK_NUM}: arbiter deviation/proceed — continuing to PR"
            break
            ;;
          BLOCKED_IMPL_DEFECT)
            _record_deviation "$TASK_NUM" "implementation_defect" "BLOCKED_IMPL_DEFECT" \
              "$ARBITER_EVIDENCE" "$ARBITER_RATIONALE"
            orchestrator_fail "Task ${TASK_NUM}: arbiter classified as implementation defect. Stopping run."
            ;;
        esac
      fi

      if [[ "$SPEC_STATUS" == "SPEC_PASS" && "$QUALITY_STATUS" == "QUALITY_PASS" ]]; then
        log "  Task ${TASK_NUM}: both reviews pass"
        break
      elif [[ "$FIX_STATUS" == "DONE_NO_FIXES_NEEDED" ]]; then
        handle_contradiction_reconciliation \
          "$FIX_STATUS" "$SPEC_STATUS" "$QUALITY_STATUS" \
          "$TASK_NUM" "$task_title" "$TASK_TEXT" \
          "$BASE_SHA" "$HEAD_SHA" "$IMPL_REPORT"

        if [[ "$CONTRADICTION_ACTION" == "resolved" ]]; then
          break
        fi
        orchestrator_fail "reviews_inconsistent: Task ${TASK_NUM} — review says FAIL (spec=${SPEC_STATUS}, quality=${QUALITY_STATUS}) but fix-review says DONE_NO_FIXES_NEEDED. Spec review: ${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result / .md — Quality review: ${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result / .md"
      fi
    done
    fi

    if [[ $REVIEW_LOOPS -ge 5 ]]; then
      emit_event "fix-review" "error" "loop.exhausted" \
        "fix-review hit max iterations for task ${TASK_NUM}" \
        task="${TASK_NUM}" iterations="$REVIEW_LOOPS"
      _exh_defect="implementation_defect"
      _exh_outcome="BLOCKED_IMPL_DEFECT"
      _exh_spec=$(jq -r '[.[].spec_status] | unique | join(",")' "$REVIEW_LOOP_HISTORY_FILE" 2>/dev/null || echo "SPEC_FAIL")
      _exh_qual=$(jq -r '[.[].quality_status] | unique | join(",")' "$REVIEW_LOOP_HISTORY_FILE" 2>/dev/null || echo "QUALITY_FAIL")
      if [[ "$_exh_qual" != "QUALITY_FAIL" && "$_exh_spec" != "SPEC_FAIL" ]]; then
        _exh_defect="verification_spec_defect"
        _exh_outcome="DEVIATION_PROCEED"
      fi
      _record_deviation "$TASK_NUM" "$_exh_defect" "$_exh_outcome" \
        "Review loop exhausted ${REVIEW_LOOPS} iterations (spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?})" \
        "Loop exhaustion — $_exh_defect based on review history"
      if [[ "$_exh_outcome" == "BLOCKED_IMPL_DEFECT" ]]; then
        orchestrator_fail "Task ${TASK_NUM}: review loop exhausted with consistently failing reviews — classified as implementation defect"
      fi
      log "  Task ${TASK_NUM}: loop exhausted, proceeding with deviation"
    fi

    # Defense in depth: even if a future code path adds a `break` that
    # isn't gated on PASS, fail before declaring the task complete.
    if [[ "$SPEC_STATUS" != "SPEC_PASS" || "$QUALITY_STATUS" != "QUALITY_PASS" ]]; then
      if [[ ! -f "${WORKTREE_DIR}/deviation-record-${TASK_NUM}.json" ]]; then
        orchestrator_fail "Task ${TASK_NUM}: exited review loop with spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?}. Refusing to mark complete."
      fi
      log "  Task ${TASK_NUM}: reviews not passing but deviation recorded — proceeding"
    fi

    {
      echo ""
      echo "## Task ${TASK_NUM}: ${task_title}"
      echo "- Status: ${IMPL_STATUS}"
      echo "- Review loops: ${REVIEW_LOOPS}"
      echo "- Commit: ${HEAD_SHA}"
    } >> "$IMPLEMENTATION_LOG"

    log "  Task ${TASK_NUM} complete (impl=${IMPL_STATUS}, review_loops=${REVIEW_LOOPS})"

  done <<< "$TASKS"

  _emit_phase_done "implement"
  PHASE="validate"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: validate
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "validate" ]]; then
  log "=== Phase: validate ==="
  _emit_phase_started "validate"
  LAST_PHASE="validate"

  _VALIDATE_START_MS=$(_now_ms)
  emit_event "validate" "info" "command.started" "running validate suite" command="pnpm-validate-suite"

  ensure_worktree

  log "Running pnpm build && pnpm lint && pnpm typecheck && pnpm test..."
  cd "${WORKTREE_DIR}"
  ensure_branch

  mkdir -p "${ISSUES_DIR}"

  {
    echo "=== pnpm install ==="
    timeout 120 pnpm install --frozen-lockfile 2>&1 | tail -5 || echo "[install completed with warnings]"
    echo ""
    echo "=== pnpm build ==="
    timeout 120 pnpm build 2>&1 || echo "[build failed]"
    echo ""
    echo "=== pnpm lint ==="
    timeout 120 pnpm lint 2>&1 || echo "[lint failed]"
    echo ""
    echo "=== pnpm typecheck ==="
    timeout 120 pnpm typecheck 2>&1 || echo "[typecheck failed]"
    echo ""
    echo "=== pnpm test ==="
    timeout 120 pnpm test 2>&1 || echo "[test failed]"
    echo ""
    echo "=== pnpm test:bash ==="
    timeout 180 pnpm test:bash 2>&1 || echo "[test:bash failed]"
  } > >(tee "${ISSUES_DIR}/validate.log") 2>&1

  VALIDATE_EXIT=0
  grep -qE "\[build failed\]|\[lint failed\]|\[typecheck failed\]|\[test failed\]|\[test:bash failed\]|\[install completed with warnings\]" "${ISSUES_DIR}/validate.log" && VALIDATE_EXIT=1

  cp "${ISSUES_DIR}/validate.log" "${ISSUES_DIR}/validation.md"
  _emit_artifact "validate" "${ISSUES_DIR}/validation.md" "validation"

  _validate_now=$(_now_ms)
  _VALIDATE_DUR=$(( _validate_now - _VALIDATE_START_MS ))
  if [[ $VALIDATE_EXIT -eq 0 ]]; then
    emit_event "validate" "info" "command.completed" "validate suite passed" \
      command="pnpm-validate-suite" exitCode=0 durationMs="$_VALIDATE_DUR"
  else
    emit_event "validate" "error" "command.failed" "validate suite failed" \
      command="pnpm-validate-suite" exitCode="$VALIDATE_EXIT" durationMs="$_VALIDATE_DUR"
  fi

  # Record validation status for downstream phases
  if [[ $VALIDATE_EXIT -ne 0 ]]; then
    echo "failed" > "${ISSUES_DIR}/validation.result"
    warn "Validation had failures (check validation.md for details)"
  else
    echo "passed" > "${ISSUES_DIR}/validation.result"
    info "Validation passed"
  fi

  _emit_phase_done "validate"
  PHASE="whole-pr-review"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: whole-pr-review
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "whole-pr-review" ]]; then
  log "=== Phase: whole-pr-review ==="
  _emit_phase_started "whole-pr-review"
  LAST_PHASE="whole-pr-review"

  ensure_worktree

  REVIEW_PROMPT="You are reviewing code changes.

## CONTEXT
You are reviewing branch: ${BRANCH} against base: ${BASE_BRANCH}
Your working directory: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md

## TASK
Run: git diff origin/${BASE_BRANCH}...HEAD
Read the diff carefully.

Write a code review to ./code-review.md.

For each finding you MUST include:
- severity: critical | high | medium | low
- file path and line reference (if applicable)
- evidence: what you observed in the diff
- failure mode: why this is a problem
- required fix: specific action to resolve the issue

Categorize findings:
- critical: security, data loss, production-breaking
- high: correct behavior violation, significant bugs
- medium: suboptimal patterns, missing tests
- low: style, formatting, minor improvements

## CRITICAL RULES
- Do NOT ask questions. If something is ambiguous, note it in the review.
- Do NOT approve or request changes - just document findings.
- Do NOT rely on agent memory.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing code-review.md.

Write code-review.md now."

  _main_state_before=$(_capture_main_state)
  _review_prompt_file=$(mktemp)
  printf '%s' "$REVIEW_PROMPT" > "$_review_prompt_file"
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase whole-pr-review \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --phase-id whole-pr-review \
    --prompt-file "$_review_prompt_file" \
    --timeout-minutes $(( (TIMEOUT_REVIEW + 59) / 60 )) \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/review.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_review_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for review (exit $_tee_ec)"
  fi

  _guard_main_checkout "whole-pr-review" "$_main_state_before"

  if [[ $_agent_ec -ne 0 ]]; then
    case $_agent_ec in
      1) orchestrator_fail "review failed (contract violation)" ;;
      2) orchestrator_fail "review failed (config error or timeout)" ;;
      3) orchestrator_fail "review failed (unexpected error)" ;;
      *) orchestrator_fail "review failed (unknown exit code $_agent_ec)" ;;
    esac
  fi

  # Copy review from worktree
  if [[ -f "${WORKTREE_DIR}/code-review.md" ]]; then
    cp "${WORKTREE_DIR}/code-review.md" "${ISSUES_DIR}/review.md"
    info "Review saved to ${ISSUES_DIR}/review.md"
    _emit_artifact "whole-pr-review" "${ISSUES_DIR}/review.md" "review"
  else
    REVIEW_FILE=$(find "${WORKTREE_DIR}" -name "code-review.md" 2>/dev/null | head -1 || true)
    if [[ -n "$REVIEW_FILE" && -f "$REVIEW_FILE" ]]; then
      cp "$REVIEW_FILE" "${ISSUES_DIR}/review.md"
      _emit_artifact "whole-pr-review" "${ISSUES_DIR}/review.md" "review"
    fi
  fi

  _emit_phase_done "whole-pr-review"
  PHASE="fix-review"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: fix-review (with loop)
# ═══════════════════════════════════════════════════════════════════════════
FIX_LOOP_COUNT=0
PREV_UNRESOLVED_FP=""

# Fingerprint the set of unresolved findings in code-review.md so we can detect
# when iterations stop making progress (same findings flagged loop after loop).
# Builds each finding's identity from a 5-line ring buffer of preceding
# non-empty lines plus the status line, joined with `||` into one record so
# `sort -u` can dedupe whole-record. The ring is wide enough to capture unique
# context (file paths, line refs, severity, finding header) even when the
# re-reviewer uses repeated generic metadata lines like `- severity: high`.
# The re-review prompt does not mandate any particular heading format.
_unresolved_fingerprint() {
  local file=$1
  [[ -f "$file" ]] || { echo "missing"; return; }
  awk '
    BEGIN { rsize = 5 }
    /^[[:space:]]*$/ { next }
    {
      # Case-insensitive match via tolower so "Not Fixed", "NOT FIXED",
      # "Partially Fixed", etc. all qualify. The reviewer is not constrained
      # to a single casing in the prompt.
      if (tolower($0) ~ /not fixed|partially fixed/) {
        out = ""
        for (i = rsize; i >= 1; i--) {
          if (ring[i] != "") {
            if (out != "") out = out "||"
            out = out ring[i]
          }
        }
        if (out != "") out = out "||"
        print out $0
      }
      for (i = rsize; i > 1; i--) ring[i] = ring[i-1]
      ring[1] = $0
    }
  ' "$file" 2>/dev/null \
    | sort -u \
    | sha256sum \
    | awk '{print $1}'
}

# True if revalidate-N.log shows all four checks (build/lint/typecheck/test) passed.
# The revalidate block in this script emits "[<step> failed]" on non-zero exit,
# so the absence of any "[* failed]" marker means green.
_revalidate_is_green() {
  local file=$1
  [[ -f "$file" ]] || return 1
  ! grep -qE '\[(build|lint|typecheck|test|test:bash) failed\]' "$file"
}

if [[ "$PHASE" == "fix-review" ]]; then
_emit_phase_started "fix-review"

while [[ "$PHASE" == "fix-review" ]]; do
  FIX_LOOP_COUNT=$((FIX_LOOP_COUNT + 1))
  emit_event "fix-review" "info" "loop.iteration.started" \
    "fix-review loop ${FIX_LOOP_COUNT}/10" \
    iteration="${FIX_LOOP_COUNT}" max=10
  if [[ $FIX_LOOP_COUNT -gt 10 ]]; then
    emit_event "fix-review" "error" "loop.exhausted" \
      "fix-review hit max iterations" \
      iterations="${FIX_LOOP_COUNT}"
    info "Fix loop limit (10) reached. Moving on."
    break
  fi
  log "=== Phase: fix-review (loop $FIX_LOOP_COUNT) ==="
  log "Cancel window: press Ctrl+C within 10s to abort..."
  sleep 10
  LAST_PHASE="fix-review"

  ensure_worktree

  if [[ ! -f "${ISSUES_DIR}/review.md" ]]; then
    info "No review.md found. Skipping fix loop."
    emit_event "fix-review" "info" "loop.iteration.completed" \
      "fix-review loop ${FIX_LOOP_COUNT} completed (no review.md)" \
      iteration="${FIX_LOOP_COUNT}" status="skipped"
    break
  fi

  # Clear any stale self-report from a prior iteration so a missing write
  # this iteration falls back to running the re-review agent (fail-safe).
  rm -f "${WORKTREE_DIR}/fix-status.txt"

  FIX_PROMPT="You are fixing code review findings.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md
Review findings: ./review.md

## TASK
Read the code review findings.
Fix ALL legitimate review findings across all severities.

Rules:
- Fix only what the review asks for. Do not expand scope.
- Do not rewrite working code for style preference.
- If a finding is invalid, note it in ./review-fix-log.md and skip it.
- If a finding is fixed, document the fix in ./review-fix-log.md.

## MANDATORY RESULT FILE
After fixing (or deciding nothing needs fixing), write EXACTLY ONE of these values to ./fix-status.txt:
- ALL_FIXED      (every finding from this iteration's review was fixed in code, or was already carried-forward from a prior loop's fix. Use this ONLY when no findings this iteration were marked invalid/skip/out-of-scope by you. This is the strictest value — choose it only when you are claiming you actually changed the code to address every legitimate finding.)
- NEEDS_REVIEW   (any other case: you skipped a finding as invalid/out-of-scope, you are uncertain a fix landed correctly, or one or more findings still need work. The orchestrator will run an independent re-reviewer to verify.)
No other content in the file — just the status word.
This is your self-report. The orchestrator skips the expensive re-review pass only when you write ALL_FIXED, so do not use it as a shortcut for skipped findings — write NEEDS_REVIEW whenever any claim of yours needs verification.

## ORCHESTRATOR ARTIFACTS — DO NOT DELETE
The following files are orchestrator working artifacts. They are excluded
from git via info/exclude and will NOT appear in the final PR. If a review
finding flags them as out-of-scope, note in review-fix-log.md that they are
excluded from git and move on. Do NOT delete or modify these files:
- issue.md, issue.json, issue-comments.md
- design.md, plan.md, implementation-log.md, orchestrator.log
- *.result, *.log files (spec-review, quality-review, fix-review, etc.)
- code-review.md, review.md, validation.md

## CRITICAL RULES
- Do NOT ask questions.
- Do NOT rely on agent memory.
- Do NOT create a PR.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Load the receiving-code-review skill first.
- After fixing, run: git add -A && git commit -m 'fix: review findings for issue #${ISSUE_NUM} (loop ${FIX_LOOP_COUNT})'
- Stop after fixing and committing.

Start now."

  _fix_prompt_file=$(mktemp)
  _main_state_before=$(_capture_main_state)
  printf '%s' "$FIX_PROMPT" > "$_fix_prompt_file"
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase fix-review \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --phase-id "fix-review-${FIX_LOOP_COUNT}" \
    --step-id "${FIX_LOOP_COUNT}" \
    --prompt-file "$_fix_prompt_file" \
    --timeout-minutes $(( (TIMEOUT_PR_FIX + 59) / 60 )) \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/fix-review-${FIX_LOOP_COUNT}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_fix_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for fix-review-${FIX_LOOP_COUNT} (exit $_tee_ec)"
  fi
  _guard_main_checkout "fix-review-loop-${FIX_LOOP_COUNT}" "$_main_state_before"
  check_branch_after_agent
  if [[ $_agent_ec -ne 0 ]]; then
    if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/fix-review-${FIX_LOOP_COUNT}.log" 2>/dev/null; then
      orchestrator_fail "fix-review failed (agent emitted BLOCKED)"
    else
      case $_agent_ec in
        1) orchestrator_fail "fix-review failed (contract violation)" ;;
        2) orchestrator_fail "fix-review failed (config error or timeout)" ;;
        3) orchestrator_fail "fix-review failed (unexpected error)" ;;
        *) orchestrator_fail "fix-review failed (unknown exit code $_agent_ec)" ;;
      esac
    fi
  fi

  # ── re-validate ────────────────────────────────────────────────────────────
  log "=== Re-validating after fix (loop $FIX_LOOP_COUNT) ==="
  cd "${WORKTREE_DIR}"
  ensure_branch

  {
    echo "=== pnpm build ==="
    timeout 120 pnpm build 2>&1 || echo "[build failed]"
    echo ""
    echo "=== pnpm lint ==="
    timeout 120 pnpm lint 2>&1 || echo "[lint failed]"
    echo ""
    echo "=== pnpm typecheck ==="
    timeout 120 pnpm typecheck 2>&1 || echo "[typecheck failed]"
    echo ""
    echo "=== pnpm test ==="
    timeout 120 pnpm test 2>&1 || echo "[test failed]"
    echo ""
    echo "=== pnpm test:bash ==="
    timeout 180 pnpm test:bash 2>&1 || echo "[test:bash failed]"
  } > >(tee "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log") 2>&1

  cp "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log" "${ISSUES_DIR}/validation-${FIX_LOOP_COUNT}.md"

  # Propagate revalidate state into validation.result so the create-pr phase
  # (which labels ai:pr-ready vs ai:needs-human-review based on this file)
  # reflects the current build/lint/typecheck/test status — not the stale
  # result from the pre-loop validate phase.
  if _revalidate_is_green "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log"; then
    echo "passed" > "${ISSUES_DIR}/validation.result"
  else
    echo "failed" > "${ISSUES_DIR}/validation.result"
    warn "Revalidate after fix loop ${FIX_LOOP_COUNT} did not pass — validation.result set to failed."
  fi

  # ── deterministic gate: skip re-review agent on the happy path ────────────
  # The re-review agent is the heaviest step in this loop (full agent + skill
  # load + re-reads source). Skip it ONLY when:
  #   (a) the fix agent self-reports ALL_FIXED (the strict value — no
  #       invalid/skip/out-of-scope claims this iteration; every finding was
  #       actually fixed in code), AND
  #   (b) revalidate is green.
  # Any NEEDS_REVIEW value (including all skip/invalid claims) falls through
  # to the independent re-reviewer, so the fix agent cannot self-approve
  # findings it decided to skip.
  FIX_STATUS_FILE="${WORKTREE_DIR}/fix-status.txt"
  FIX_AGENT_STATUS=""
  if [[ -f "$FIX_STATUS_FILE" ]]; then
    # Read file directly with head (bounded read, no upstream producer that
    # could SIGPIPE under pipefail) — see SIGPIPE gotcha note at top of file.
    FIX_AGENT_STATUS=$(head -c 64 "$FIX_STATUS_FILE" 2>/dev/null | tr -d '[:space:]')
  fi
  if [[ "$FIX_AGENT_STATUS" == "ALL_FIXED" ]] \
     && _revalidate_is_green "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log"; then
    info "Fix agent reports ALL_FIXED and revalidate is green — skipping re-review agent (loop ${FIX_LOOP_COUNT})."
    echo "ALL_RESOLVED" > "${WORKTREE_DIR}/review-findings-status.txt"
    emit_event "fix-review" "info" "loop.reagent_skipped" \
      "skipped re-review agent: fix-status=ALL_FIXED and revalidate green" \
      iteration="${FIX_LOOP_COUNT}"
    emit_event "fix-review" "info" "loop.iteration.completed" \
      "fix-review loop ${FIX_LOOP_COUNT} completed (deterministic resolve)" \
      iteration="${FIX_LOOP_COUNT}" status="ALL_RESOLVED"
    break
  fi

  # ── re-review ──────────────────────────────────────────────────────────────
  log "=== Re-reviewing after fix (loop $FIX_LOOP_COUNT) ==="

  RE_REVIEW_PROMPT="You are re-reviewing code after fixes were applied.

## CONTEXT
You are reviewing branch: ${BRANCH} against base: ${BASE_BRANCH}
Your working directory: ${WORKTREE_DIR}
Original review: ./review.md
Fix agent's notes: ./review-fix-log.md  (READ THIS — it records which findings the fix agent fixed, skipped as invalid, or deemed out-of-scope, with reasoning)
Revalidation log: ./revalidate-${FIX_LOOP_COUNT}.log

## TASK
Load the receiving-code-review skill first.
Read ./review-fix-log.md first to see what the fix agent did for each finding.
Read the actual source files that had findings. Verify each finding by reading the file on disk.
Check the revalidation log for build/lint/test results.
For each original finding, note whether it is: **fixed** | **partially fixed** | **not fixed** | **invalid**
If a finding was pre-existing (not introduced by this branch), note it as **CARRIED FORWARD** (pre-existing).
Write an updated review to ./code-review.md.
Verify your assertions by reading actual file contents.

## HONORING THE FIX AGENT'S SKIP/INVALID CLAIMS
If review-fix-log.md marks a finding as **invalid**, **skip**, **out-of-scope**, or **no code change possible**:
- Default to **invalid** in your status unless you can point to a concrete, in-scope code defect on disk that contradicts the fix agent's reasoning.
- A test-design critique, a request for more tests, or 'this could be better refactored' is NOT a code defect — accept the fix agent's invalid/skip verdict.
- Do NOT re-litigate the same finding across loops. If you marked a finding **not fixed** in a prior loop and the fix agent has documented why no fix is possible, flip it to **invalid** this loop.

## MANDATORY RESULT FILE
After writing code-review.md, write EXACTLY ONE of these values to ./review-findings-status.txt:
- ALL_RESOLVED  (if every finding is fixed, carried forward, or invalid)
- HAS_UNRESOLVED (if any finding is not fixed or partially fixed)
No other content in the file — just the status word.

## CRITICAL RULES
- Do NOT ask questions.
- Do NOT expand scope.
- Do not flag new issues beyond the original review.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.

Write code-review.md and review-findings-status.txt now."

  _main_state_before=$(_capture_main_state)

  _re_review_prompt_file=$(mktemp)
  printf '%s' "$RE_REVIEW_PROMPT" > "$_re_review_prompt_file"
  # NOTE: --phase quality-review is intentional — re-review is a quality-review
  # re-run with updated context. There is no dedicated re-review profile; using
  # quality-review keeps the same model selection (inspector profile). The
  # --phase-id distinguishes this invocation in telemetry.
  ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase quality-review \
    --phase-id "re-review-${FIX_LOOP_COUNT}" \
    --cwd "$WORKTREE_DIR" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --prompt-file "$_re_review_prompt_file" \
    --timeout-minutes $(( (TIMEOUT_REVIEW + 59) / 60 )) \
    --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/re-review-${FIX_LOOP_COUNT}.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
  rm -f "$_re_review_prompt_file"
  if [[ $_tee_ec -ne 0 ]]; then
    orchestrator_fail "tee failed writing log for re-review-${FIX_LOOP_COUNT} (exit $_tee_ec)"
  fi

  _guard_main_checkout "re-review-${FIX_LOOP_COUNT}" "$_main_state_before"

  if [[ $_agent_ec -ne 0 ]]; then
    if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/re-review-${FIX_LOOP_COUNT}.log" 2>/dev/null; then
      orchestrator_fail "re-review-${FIX_LOOP_COUNT} is blocked (agent emitted BLOCKED)"
    else
      case $_agent_ec in
        1) orchestrator_fail "re-review-${FIX_LOOP_COUNT} failed (contract violation)" ;;
        2) orchestrator_fail "re-review-${FIX_LOOP_COUNT} failed (config error or timeout)" ;;
        3) orchestrator_fail "re-review-${FIX_LOOP_COUNT} failed (unexpected error)" ;;
        *) orchestrator_fail "re-review-${FIX_LOOP_COUNT} failed (unknown exit code $_agent_ec)" ;;
      esac
    fi
  fi

  # Copy updated review
  if [[ -f "${WORKTREE_DIR}/code-review.md" ]]; then
    cp "${WORKTREE_DIR}/code-review.md" "${ISSUES_DIR}/review.md"
  fi

  # Check if all findings are resolved using resolve_result (primary: .result file, fallback: extractor, tertiary: assume unresolved)
  REVIEW_STATUS=$(resolve_result \
    "${WORKTREE_DIR}/review-findings-status.txt" \
    "${ISSUES_DIR}/review.md" \
    ALL_RESOLVED HAS_UNRESOLVED \
    "HAS_UNRESOLVED")

  if [[ "$REVIEW_STATUS" == "ALL_RESOLVED" ]]; then
    info "All findings resolved. Exiting fix loop."
    emit_event "fix-review" "info" "loop.iteration.completed" \
      "fix-review loop ${FIX_LOOP_COUNT} completed (all resolved)" \
      iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}"
    break
  fi

  # No-progress detector: if the unresolved finding set is identical to the
  # previous iteration, the loop is stuck (typically on a finding the fix agent
  # cannot or will not address). Break instead of churning to the iteration cap.
  # But only break when revalidate is GREEN — if it's red, there's still
  # something objectively broken (build/lint/typecheck/test failed) and we
  # should keep trying until MAX_ITERATIONS rather than ship a broken branch.
  NEW_UNRESOLVED_FP=$(_unresolved_fingerprint "${ISSUES_DIR}/review.md")
  if [[ -n "$PREV_UNRESOLVED_FP" && "$NEW_UNRESOLVED_FP" == "$PREV_UNRESOLVED_FP" ]]; then
    if _revalidate_is_green "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log"; then
      info "Unresolved finding set unchanged since loop $((FIX_LOOP_COUNT - 1)) and revalidate green — breaking to avoid churn."
      emit_event "fix-review" "warn" "loop.no_progress" \
        "fix-review unresolved set unchanged across iterations" \
        iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}" fingerprint="${NEW_UNRESOLVED_FP}"
      emit_event "fix-review" "info" "loop.iteration.completed" \
        "fix-review loop ${FIX_LOOP_COUNT} completed (no progress)" \
        iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}"
      break
    fi
    info "Unresolved set unchanged but revalidate is red — continuing loop (refusing to early-exit with broken build/tests)."
    emit_event "fix-review" "warn" "loop.no_progress_blocked_red" \
      "no-progress break suppressed because revalidate is red" \
      iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}" fingerprint="${NEW_UNRESOLVED_FP}"
  fi
  PREV_UNRESOLVED_FP="$NEW_UNRESOLVED_FP"

  info "Review status: ${REVIEW_STATUS}. Continuing fix loop."
  emit_event "fix-review" "info" "loop.iteration.completed" \
    "fix-review loop ${FIX_LOOP_COUNT} completed (has unresolved)" \
    iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}"
done

# Post-loop guard: refuse to let create-pr label this PR as ai:pr-ready when
# the fix loop exited with unresolved findings. Covers ALL exit paths from
# the while loop — no-progress break, MAX_ITERATIONS exhaustion, or any other
# future early-break that leaves review-findings-status.txt as HAS_UNRESOLVED.
# Without this, a finding the fix agent cannot resolve would still ship as
# pr-ready as long as build/lint/typecheck/test are green.
if [[ -f "${WORKTREE_DIR}/review-findings-status.txt" ]]; then
  FINAL_REVIEW_STATUS=$(head -c 64 "${WORKTREE_DIR}/review-findings-status.txt" 2>/dev/null | tr -d '[:space:]')
  if [[ "$FINAL_REVIEW_STATUS" == "HAS_UNRESOLVED" ]]; then
    warn "fix-review exited with unresolved findings — overriding validation.result to block ai:pr-ready."
    echo "unresolved-review" > "${ISSUES_DIR}/validation.result"
    emit_event "fix-review" "warn" "phase.unresolved_findings" \
      "fix-review exited with unresolved findings; validation.result overridden to block ai:pr-ready" \
      status="$FINAL_REVIEW_STATUS"
  fi
fi

_emit_phase_done "fix-review"
PHASE="compound"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: compound
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "compound" ]]; then
  log "=== Phase: compound ==="
  _emit_phase_started "compound"
  LAST_PHASE="compound"

  ensure_worktree

  if [[ ! -f "${WORKTREE_DIR}/implementation-log.md" ]]; then
    info "No implementation-log.md found. Skipping compound."
    PHASE="create-pr"
  else
    COMPOUND_PROMPT="You are writing a compound engineering document.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md
Design: design.md
Implementation: implementation-log.md

## TASK
Read implementation-log.md and write a solution document to:
  docs/solutions/issue-${ISSUE_NUM}.md

This document should capture:
- The problem and context
- What was decided and why (with trade-offs considered)
- Key implementation decisions and their reasoning
- Gotchas, pitfalls, and lessons learned
- What someone should know if they need to modify this code

Format: markdown with clear sections. Be specific. Include actual code paths, not generic descriptions.

Rules:
- Do NOT ask questions.
- Write the document yourself. Do not delegate.
- Do not create a PR or commit anything.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.

Start now."

    _compound_prompt_file=$(mktemp)
    printf '%s' "$COMPOUND_PROMPT" > "$_compound_prompt_file"
    _main_state_before=$(_capture_main_state)
    ! NODE_OPTIONS='--conditions=development' node --import "$_TSX_LOADER" "$REPO_ROOT/apps/cli/src/run-agent.ts" \
      --phase compound \
      --phase-id "compound" \
      --cwd "$WORKTREE_DIR" \
      --run-id "$RUN_ID" \
      --repo-id "$REPO_ID" \
      --repo-root "$REPO_ROOT" \
      --prompt-file "$_compound_prompt_file" \
      --timeout-minutes $(( (TIMEOUT_COMPOUND + 59) / 60 )) \
      --start-sha "$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
      2>&1 | tee -a "${ISSUES_DIR}/compound.log"; _agent_ec=${PIPESTATUS[0]} _tee_ec=${PIPESTATUS[1]}
    rm -f "$_compound_prompt_file"
    if [[ $_tee_ec -ne 0 ]]; then
      orchestrator_fail "tee failed writing log for compound (exit $_tee_ec)"
    fi

    _guard_main_checkout "compound" "$_main_state_before"

    if [[ $_agent_ec -ne 0 ]]; then
      if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "${ISSUES_DIR}/compound.log" 2>/dev/null; then
        orchestrator_fail "compound is blocked (agent emitted BLOCKED)"
      else
        case $_agent_ec in
          1) orchestrator_fail "compound failed (contract violation)" ;;
          2) orchestrator_fail "compound failed (config error or timeout)" ;;
          3) orchestrator_fail "compound failed (unexpected error)" ;;
          *) orchestrator_fail "compound failed (unknown exit code $_agent_ec)" ;;
        esac
      fi
    fi

    # Copy the generated doc back to issues dir
    if [[ -f "${WORKTREE_DIR}/docs/solutions/issue-${ISSUE_NUM}.md" ]]; then
      cp "${WORKTREE_DIR}/docs/solutions/issue-${ISSUE_NUM}.md" "${ISSUES_DIR}/compound.md"
      info "Compound doc saved to ${ISSUES_DIR}/compound.md"
      _emit_artifact "compound" "${ISSUES_DIR}/compound.md" "compound"
    fi
  fi

  _emit_phase_done "compound"
  PHASE="create-pr"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: create-pr
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "create-pr" ]]; then
  log "=== Phase: create-pr ==="
  _emit_phase_started "create-pr"
  LAST_PHASE="create-pr"

  ensure_worktree

  cd "${WORKTREE_DIR}"
  ensure_branch

  # Validate branch has commits
  if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    orchestrator_fail "Worktree has no commits — cannot create PR"
  fi

  log "Branch ${BRANCH} HEAD: $(git rev-parse --short HEAD)"

  # Check branch has diverged from base
  LOCAL_SHA=$(git rev-parse HEAD)
  BASE_SHA=$(git merge-base "origin/${BASE_BRANCH}" HEAD 2>/dev/null || echo "")
  if [[ -n "$BASE_SHA" && "$LOCAL_SHA" == "$BASE_SHA" ]]; then
    warn "Branch ${BRANCH} has no commits beyond ${BASE_BRANCH} — PR will be empty"
  fi

  # Push branch (fail hard on error)
  log "Pushing branch..."
  if ! git push --force-with-lease -u origin "$BRANCH" 2>&1 | tee -a "${ISSUES_DIR}/orchestrator.log"; then
    orchestrator_fail "Failed to push branch ${BRANCH}"
  fi

  # Build pr-summary.md
  ISSUE_META=$(gh issue view "$ISSUE_NUM" --json title,url)
  ISSUE_TITLE=$(echo "$ISSUE_META" | jq -r '.title')
  ISSUE_URL=$(echo "$ISSUE_META" | jq -r '.url')

  PR_SUMMARY=""
  if [[ -f "${ISSUES_DIR}/implementation-log.md" ]]; then
    PR_SUMMARY=$(awk 'NR==2,/^$/ {if (/^$/) exit; print}' "${ISSUES_DIR}/implementation-log.md" 2>/dev/null || true)
  fi

  PR_TASKS=""
  if [[ -f "${ISSUES_DIR}/plan.md" ]]; then
    PR_TASKS=$(awk '/^#{2,3} Task [0-9]+:/ {sub(/^#{2,3} /, "- "); print}' "${ISSUES_DIR}/plan.md" 2>/dev/null || true)
  fi

  PR_CHANGES=""
  if [[ -n "$BASE_SHA" ]]; then
    PR_CHANGES=$(cd "$WORKTREE_DIR" && git diff --stat "${BASE_SHA}"..HEAD 2>/dev/null || true)
  fi

  PR_VALIDATION="Unknown"
  if [[ -f "${ISSUES_DIR}/validation.result" ]]; then
    PR_VALIDATION=$(cat "${ISSUES_DIR}/validation.result" 2>/dev/null | sed 's/.*/&/' | head -1)
  fi
  PR_VALIDATION_STEPS=""
  if [[ -f "${ISSUES_DIR}/validate.log" ]]; then
    # Match the exact sentinels the validate phase emits via `|| echo "[<step> failed]"`
    # (see the validate block near line 1417). The prior parser scanned for `fail|error`
    # against raw tool output, which produced false "test: failed" entries because vitest
    # legitimately prints those words on passing runs ("0 failed", test names like
    # "should fail gracefully", etc.). Steps with no failure sentinel are reported as
    # passed by absence-of-failure.
    phase_name=""
    while IFS= read -r line; do
      if [[ "$line" =~ ^===\ (.+)\ ===$ ]]; then
        if [[ -n "$phase_name" ]]; then
          PR_VALIDATION_STEPS+="- ${phase_name}: passed"$'\n'
        fi
        phase_name="${BASH_REMATCH[1]}"
      elif [[ -n "$phase_name" && "$line" =~ ^\[(build|lint|typecheck|test|install)\ failed\]$ ]]; then
        PR_VALIDATION_STEPS+="- ${phase_name}: failed"$'\n'
        phase_name=""
      elif [[ -n "$phase_name" && "$line" == "[install completed with warnings]" ]]; then
        PR_VALIDATION_STEPS+="- ${phase_name}: failed"$'\n'
        phase_name=""
      fi
    done < "${ISSUES_DIR}/validate.log"
    if [[ -n "$phase_name" ]]; then
      PR_VALIDATION_STEPS+="- ${phase_name}: passed"$'\n'
    fi
  fi

  PR_REVIEW=""
  if [[ -f "${ISSUES_DIR}/code-review.md" ]]; then
    crit_high=$(grep -ciE 'severity.*(critical|high)' "${ISSUES_DIR}/code-review.md" 2>/dev/null || echo 0)
    medi_low=$(grep -ciE 'severity.*(medium|low)' "${ISSUES_DIR}/code-review.md" 2>/dev/null || echo 0)
    PR_REVIEW="- Critical/High: ${crit_high}"$'\n'"- Medium/Low: ${medi_low}"
  elif [[ -f "${ISSUES_DIR}/review.md" ]]; then
    crit_high=$(grep -ciE 'severity.*(critical|high)' "${ISSUES_DIR}/review.md" 2>/dev/null || echo 0)
    medi_low=$(grep -ciE 'severity.*(medium|low)' "${ISSUES_DIR}/review.md" 2>/dev/null || echo 0)
    PR_REVIEW="- Critical/High: ${crit_high}"$'\n'"- Medium/Low: ${medi_low}"
  else
    PR_REVIEW="No code review performed"
  fi

  PR_AUTONOMOUS_ACTIONS=""
  arb_file=""
  for arb_file in "${WORKTREE_DIR}"/arbiter-rationale-*.md; do
    [[ -f "$arb_file" ]] || continue
    task_ref=""
    task_ref=$(basename "$arb_file" | sed 's/arbiter-rationale-//;s/\.md$//')
    PR_AUTONOMOUS_ACTIONS="${PR_AUTONOMOUS_ACTIONS}### Arbiter Rationale (Task ${task_ref})
$(cat "$arb_file")
"
  done
  dev_file=""
  for dev_file in "${WORKTREE_DIR}"/deviation-record-*.md; do
    [[ -f "$dev_file" ]] || continue
    task_ref=""
    task_ref=$(basename "$dev_file" | sed 's/deviation-record-//;s/\.md$//')
    PR_AUTONOMOUS_ACTIONS="${PR_AUTONOMOUS_ACTIONS}### Deviation Record (Task ${task_ref})
$(cat "$dev_file")
"
  done
  if [[ -n "$PR_AUTONOMOUS_ACTIONS" ]]; then
    PR_AUTONOMOUS_ACTIONS="## Autonomous Actions
${PR_AUTONOMOUS_ACTIONS}"
  fi

  cat > "${ISSUES_DIR}/pr-summary.md" << EOF
# ${ISSUE_TITLE}

Closes #${ISSUE_NUM}

${PR_SUMMARY}

## Tasks
${PR_TASKS}

## Changes
${PR_CHANGES}

## Validation: ${PR_VALIDATION}
${PR_VALIDATION_STEPS}

## Review Findings
${PR_REVIEW}

${PR_AUTONOMOUS_ACTIONS}
## Artifacts
Run logs and artifacts: \`ai/issues/${ISSUE_NUM}/\`
EOF

  # Create PR. `gh pr create` does NOT support --json (only `gh pr view/list`
  # do); it writes the PR URL to stdout on success. Capture that directly.
  PR_BODY=$(cat "${ISSUES_DIR}/pr-summary.md")
  PR_URL=$(gh pr create \
    --base "$BASE_BRANCH" \
    --head "$BRANCH" \
    --title "${ISSUE_TITLE}" \
    --body "$PR_BODY" 2>/dev/null | tail -1) || PR_URL=""

  if [[ -z "$PR_URL" ]]; then
    # Create failed — most commonly because a PR already exists for this branch.
    # Look it up by head ref and continue (idempotent for resumes).
    PR_URL=$(gh pr list --head "$BRANCH" --state open --json url --jq '.[0].url // empty' 2>/dev/null || echo "")
    if [[ -z "$PR_URL" ]]; then
      orchestrator_fail "Failed to create PR and no open PR exists for branch ${BRANCH}"
    fi
    log "PR already exists for ${BRANCH}, reusing: ${PR_URL}"
  fi

  # Resolve the PR number via gh pr view, which DOES support --json.
  PR_NUM=$(gh pr view "$PR_URL" --json number --jq '.number' 2>/dev/null || echo "")
  if [[ -z "$PR_NUM" ]]; then
    # Final fallback: parse the trailing /<number> from the URL.
    PR_NUM=$(echo "$PR_URL" | grep -oE '[0-9]+$' || echo "unknown")
  fi

  echo "$PR_URL" > "${ISSUES_DIR}/pr-url.txt"
  echo "$PR_NUM" > "${ISSUES_DIR}/pr-number.txt"
  _emit_artifact "create-pr" "${ISSUES_DIR}/pr-summary.md" "summary"
  if [[ ! -f "${ISSUES_DIR}/pr-summary.md" ]]; then
    warn "pr-summary.md not found after create-pr phase — artifact event silently skipped"
  fi
  _emit_artifact "create-pr" "${ISSUES_DIR}/pr-url.txt" "pr"

  log "PR created: ${PR_URL}"

  # Update issue labels — gate ai:pr-ready on validation passing
  gh issue edit "$ISSUE_NUM" --remove-label "ai:in-progress" 2>/dev/null || true
  VALIDATION_STATUS=$(cat "${ISSUES_DIR}/validation.result" 2>/dev/null || echo "unknown")
  if [[ "$VALIDATION_STATUS" == "passed" ]]; then
    gh issue edit "$ISSUE_NUM" --add-label "ai:pr-ready" 2>/dev/null || true
  else
    gh issue edit "$ISSUE_NUM" --add-label "ai:needs-human-review" 2>/dev/null || true
    warn "Validation did not pass (status: ${VALIDATION_STATUS}). Labeling as ai:needs-human-review instead of ai:pr-ready."
  fi

  # Comment on issue
  gh issue comment "$ISSUE_NUM" --body "PR created: ${PR_URL}" 2>/dev/null || true

  _emit_phase_done "create-pr"
  PHASE="done"
fi

# ═══════════════════════════════════════════════════════════════════════════
# DONE
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "done" ]]; then
  log "=== Orchestrator complete ==="
  log "PR: $(cat "${ISSUES_DIR}/pr-url.txt")"
  log "Artifacts: ai/issues/${ISSUE_NUM}/"

  ARCHIVE_DIR="${REPO_ROOT}/ai/issues/${ISSUE_NUM}"
  mkdir -p "$ARCHIVE_DIR"
  for f in \
    orchestrator.log \
    issue.json issue.md issue-comments.md \
    design.md plan.md \
    implementation-log.md \
    compound.md \
    validation.md validation.result validate.log revalidate-*.log validation-*.md \
    review.md review-fix-log.md code-review.md review-findings-status.txt fix-status.txt \
    pr-summary.md pr-url.txt pr-number.txt \
    poll-pr.log \
    install-worktree.log \
    blocked.json task-manifest.json \
    implement-task-*.log implement-task-*.result \
    spec-review-task-*.log spec-review-task-*.result \
    quality-review-task-*.log quality-review-task-*.result \
    fix-review-task-*.log fix-review-task-*.result \
    fix-review-*.log fix-review-*.result \
    arbiter-task-*.log arbiter-result.json arbiter-rationale-*.md \
    deviation-record-*.md deviation-record-*.json review-loop-history.json; do
    cp "${WORKTREE_DIR}/$f" "$ARCHIVE_DIR/" 2>/dev/null || true
  done
  log "Artifacts archived to ${ARCHIVE_DIR}/"

  # Start PR review poll loop in background
  log "Starting PR review poll loop (background)..."
  PR_NUM_VALUE=$(cat "${ISSUES_DIR}/pr-number.txt" 2>/dev/null || echo "")
  if [[ -n "$PR_NUM_VALUE" && "$PR_NUM_VALUE" != "unknown" ]]; then
    AI_RUN_EVENTS_FILE="${AI_RUN_EVENTS_FILE:-}" \
    AI_RUN_DISPLAY_ID="${AI_RUN_DISPLAY_ID:-}" \
    nohup "${REPO_ROOT}/scripts/ai-pr-review-poll" "$PR_NUM_VALUE" "$ISSUE_NUM" 3 300 \
      >> "${ISSUES_DIR}/poll-pr.log" 2>&1 &
    POLL_PID=$!
    disown "$POLL_PID" 2>/dev/null || true
    log "PR review poll PID: ${POLL_PID}"
    # Verify the process actually started
    sleep 2
    if kill -0 "$POLL_PID" 2>/dev/null; then
      log "PR review poll confirmed running (PID ${POLL_PID})"
    else
      warn "PR review poll process exited immediately. Check ${ISSUES_DIR}/poll-pr.log"
    fi
  else
    warn "Could not determine PR number, skipping review poll"
  fi

  echo ""
  echo "✅ Issue #${ISSUE_NUM} → PR ready"
  echo "   PR: $(cat "${ISSUES_DIR}/pr-url.txt")"
  echo "   Branch: ${BRANCH}"
  emit_event "" "info" "run.completed" "issue-to-PR run completed" \
    prUrl="${PR_URL:-}"
fi
