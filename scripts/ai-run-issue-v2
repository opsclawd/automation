#!/usr/bin/env bash
# =============================================================================
# ai-run-issue-v2.sh — Non-interactive GitHub issue-to-PR orchestrator
#
# Usage: pnpm ai:run-issue <issue-number>
#
# State labels: ai:blocked | ai:failed | ai:needs-human-review | ai:pr-ready
# Idempotent: rerunning resumes or safely fails (no duplicate branches/PRs)
# =============================================================================
set -euo pipefail
# SIGPIPE gotcha: with `set -e -o pipefail`, a `producer | head -N`
# pattern inside a command substitution can crash the script silently
# when the producer is large enough to outrun head. head closes the
# pipe early, the producer (echo, cat, find, etc.) gets SIGPIPE → 141,
# pipefail propagates that to the pipeline's exit code, errexit fires.
# Prefer `head -N <<< "$str"` (herestring) or `head -N "$file"`
# (head reads the file directly so there's no producer to SIGPIPE).
# See read_result_value() below for the canonical pattern.

ISSUE_NUM="${1:-}"
export ISSUE_NUM

if [[ -z "$ISSUE_NUM" ]]; then
  echo "Usage: pnpm ai:run-issue <issue-number>" >&2
  exit 1
fi

# ── env / defaults ────────────────────────────────────────────────────────────
REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
cd "$REPO_ROOT"

BASE_BRANCH="${BASE_BRANCH:-main}"
BRANCH="ai/issue-${ISSUE_NUM}"
# Derived from current repo; override with OWNER_REPO env var for cross-repo runs.
OWNER_REPO="${OWNER_REPO:-$(cd "$REPO_ROOT" && gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")}"
if [[ -z "$OWNER_REPO" ]]; then
  echo "FATAL: could not determine owner/repo. Set OWNER_REPO=<owner>/<repo> and retry." >&2
  exit 1
fi
PROMPTS_DIR="automation/prompts"
AGENT_MODEL="${AGENT_MODEL:-minimax-coding-plan/MiniMax-M2.7}"
AGENT_CLI="${AGENT_CLI:-opencode}"

# Phase timeouts (seconds)
TIMEOUT_BRAINSTORM=600
TIMEOUT_PLAN_WRITE=600
TIMEOUT_IMPLEMENT=1800
TIMEOUT_VALIDATE=300
TIMEOUT_REVIEW=600
TIMEOUT_FIX=900
TIMEOUT_PR_FIX=1200
TIMEOUT_COMPOUND=600

# All artifacts live in the worktree (no cross-directory permission needed for sub-agents)
WORKTREE_DIR="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}"
ISSUES_DIR="${WORKTREE_DIR}"

# ── helpers (functions) ───────────────────────────────────────────────────────
log()  { echo "[$(date +%H:%M:%S)] $*" | tee -a "${ISSUES_DIR}/orchestrator.log" >&2; }
info() { log "INFO: $*"; }
warn() { log "WARN: $*" >&2; }

# Structured event helper — emits JSON lines to $AI_RUN_EVENTS_FILE.
# When AI_RUN_EVENTS_FILE is unset (standalone Bash run), emit_event is a no-op.
# shellcheck source=lib/emit_event.sh
source "${REPO_ROOT}/scripts/lib/emit_event.sh"

# ── Per-phase wall-clock tracking ─────────────────────────────────────────────
# Invariant: _emit_phase_started must always be called before _emit_phase_done
# in the same phase block. orchestrator_fail always exits the script, so a
# missing _emit_phase_done on failure paths is acceptable (phase.failed
# supersedes phase.completed). _LAST_PHASE_START_MS holds the start time of the
# current (most recently started) phase only.
_LAST_PHASE_START_MS=0
_HAS_NANOSECONDS=false
if date +%N >/dev/null 2>&1 && [[ "$(date +%N)" != "N" ]]; then
  _HAS_NANOSECONDS=true
fi
_now_ms() {
  if [[ "$_HAS_NANOSECONDS" == "true" ]]; then
    echo $(( $(date +%s%N) / 1000000 ))
  else
    echo $(( $(date +%s) * 1000 ))
  fi
}
_emit_phase_started() {
  local phase=$1
  _LAST_PHASE_START_MS=$(_now_ms)
  emit_event "$phase" "info" "phase.started" "phase ${phase} started"
}
_emit_phase_done() {
  local phase=$1
  local now ms_dur=0
  now=$(_now_ms)
  ms_dur=$(( now - _LAST_PHASE_START_MS ))
  (( ms_dur < 0 )) && ms_dur=0
  emit_event "$phase" "info" "phase.completed" "phase ${phase} completed" durationMs="$ms_dur"
}
_emit_phase_skipped() {
  local phase=$1 reason=${2:-resume-detected}
  emit_event "$phase" "warn" "phase.skipped" "phase ${phase} skipped" reason="$reason"
}
_emit_skipped_until() {
  local target=$1
  local p found=false
  for p in read_issue plan-design plan-write implement validate review fix-review compound create-pr; do
    if [[ "$p" == "$target" ]]; then found=true; break; fi
    _emit_phase_skipped "$p" "resume-detected"
  done
  if [[ "$found" == "false" ]]; then
    warn "_emit_skipped_until did not find phase '$target' in canonical list"
  fi
}
_emit_artifact() {
  local phase=$1 path=$2 kind=$3
  if [[ -f "$path" ]]; then
    emit_event "$phase" "info" "artifact.created" "artifact ${kind} written" path="$path" kind="$kind"
  fi
}

orchestrator_fail() {
  reason="$1"
  log "FAIL: $reason"
  emit_event "${LAST_PHASE:-unknown}" "error" "phase.failed" "$reason" reason="$reason"
  emit_event "" "error" "run.failed" "$reason" lastPhase="${LAST_PHASE:-unknown}" reason="$reason"
  if [[ "$reason" == *"blocked"* || "$reason" == *"Blocking"* || "$reason" == *"waiting"* ]]; then
    printf '{"phase":"%s","reason":"%s","time":"%s"}\n' \
      "${LAST_PHASE:-unknown}" "$reason" "$(date -Iseconds)" \
      > "${ISSUES_DIR}/blocked.json"
  fi
  gh issue edit "$ISSUE_NUM" --remove-label "ai:in-progress" 2>/dev/null || true
  gh issue edit "$ISSUE_NUM" --add-label "ai:failed" 2>/dev/null || true
  gh issue comment "$ISSUE_NUM" --body "Automation failed: $reason" 2>/dev/null || true
  exit 1
}

# Verify worktree is on the correct branch; checkout if needed
ensure_branch() {
  local current
  current=$(git branch --show-current 2>/dev/null || echo "")
  if [[ "$current" != "${BRANCH}" ]]; then
    warn "Worktree on '${current}' (expected '${BRANCH}'), checking out..."
    git checkout "${BRANCH}" 2>/dev/null || orchestrator_fail "Failed to checkout ${BRANCH} in worktree"
  fi
}

# Verify worktree is still on the correct branch after agent execution
check_branch_after_agent() {
  local current
  current=$(git branch --show-current 2>/dev/null || echo "")
  if [[ "$current" != "${BRANCH}" ]]; then
    orchestrator_fail "Agent switched branch from ${BRANCH} to ${current}"
  fi
}

# Ensure $WORKTREE_DIR exists and is a valid git worktree on $BRANCH. Used by
# every phase after read_issue so resumes survive `git worktree prune`,
# archive pre-seeding that skips the read_issue setup path, and accidental
# rm-rf of .ai-worktrees/. Idempotent: no-op when the worktree is healthy.
ensure_worktree() {
  if [[ -e "${WORKTREE_DIR}/.git" ]]; then
    seed_excludes
    return 0
  fi

  # ISSUES_DIR == WORKTREE_DIR (see top of script), so log() can't write to its
  # usual path while the worktree is missing. Emit the recovery banner straight
  # to stderr; once recovery succeeds, normal log() resumes.
  echo "[$(date +%H:%M:%S)] WARN: Worktree missing at ${WORKTREE_DIR}, attempting recovery..." >&2

  cd "${REPO_ROOT}"
  git worktree prune 2>/dev/null || true
  git fetch origin "${BASE_BRANCH}" 2>/dev/null || true

  if git rev-parse --verify "${BRANCH}" 2>/dev/null; then
    # Local branch ref exists — attach a worktree to it.
    git worktree add "$WORKTREE_DIR" "$BRANCH" 2>&1 \
      || orchestrator_fail "Failed to attach worktree to local branch ${BRANCH}"
  elif git fetch origin "${BRANCH}" 2>/dev/null; then
    # Remote branch exists — recreate the branch from origin.
    git worktree add "$WORKTREE_DIR" -b "$BRANCH" "origin/${BRANCH}" 2>&1 \
      || orchestrator_fail "Failed to recreate worktree from origin/${BRANCH}"
  else
    orchestrator_fail "Worktree missing and no local or remote branch ${BRANCH} to recover from"
  fi

  if [[ ! -e "${WORKTREE_DIR}/.git" ]]; then
    orchestrator_fail "Worktree recovery completed but ${WORKTREE_DIR} is still not a worktree"
  fi
  log "Worktree recovered at ${WORKTREE_DIR}"
  seed_excludes
}

# Seed worktree-local exclude rules so orchestrator artifacts are never
# tracked. Skips the append when a sentinel pattern is already present, so
# the file doesn't accumulate duplicate blocks across every phase entry.
seed_excludes() {
  if [[ -z "${WORKTREE_DIR:-}" ]] || [[ ! -e "${WORKTREE_DIR}/.git" ]]; then
    return 1
  fi
  local common_dir exclude_file
  common_dir=$(cd "$WORKTREE_DIR" && git rev-parse --git-common-dir)
  exclude_file="${common_dir}/info/exclude"
  mkdir -p "${common_dir}/info"
  # Sentinel check: .review-context/ is the last pattern in the block, so its
  # presence means a previous seed_excludes call already wrote the full set.
  if [[ -f "$exclude_file" ]] && grep -qxF '.review-context/' "$exclude_file"; then
    return 0
  fi
  cat >> "$exclude_file" << 'EOF'
*.log
*.result
code-review.md
review.md
design.md
plan.md
compound.md
implementation-log.md
review-fix-log.md
validation*.md
issue*.json
issue*.md
pr-summary.md
pr-*.txt
MEMORY.md
AGENTS.md
CLAUDE.md
tsconfig.tsbuildinfo
spec-review-task-*.md
quality-review-task-*.md
review-findings-status.txt
implement-task-*.md
fix-review-task-*.md
fix-review-task-*.log
next-env.d.ts
node_modules/
.next/
.review-context/
EOF
}

# ── result resolution helpers ───────────────────────────────────────────────
#
# Hybrid result extraction: agent writes .result file (primary), extractor
# agent reads .md file (fallback), conservative default (tertiary).

# validate_result_file: returns 0 if file exists and contains an allowed value
# Read first non-whitespace token from a result file. Uses `head -1 file`
# (not `cat | head`) so head reads the file directly — no upstream
# producer that could be SIGPIPE'd when head closes after one line.
read_result_value() {
  head -1 "$1" 2>/dev/null | tr -d '[:space:]' || true
}

validate_result_file() {
  local result_file="$1"; shift
  local allowed_values=("$@")
  local val

  if [[ ! -f "$result_file" ]]; then
    return 1
  fi

  val=$(read_result_value "$result_file")
  if [[ -z "$val" ]]; then
    return 1
  fi

  local match=false
  for allowed in "${allowed_values[@]}"; do
    if [[ "$val" == "$allowed" ]]; then
      match=true
      break
    fi
  done

  if $match; then
    return 0
  else
    return 1
  fi
}

# validate_review_artifacts: checks that .result and .md artifacts are a valid pair.
# Returns 0 if the pair is valid (both present, both absent, or md-without-result).
# Returns 1 if .result exists but .md is missing — an impossible combination
# under the agent contract, indicating a stale or partial write.
validate_review_artifacts() {
  local result_file="$1"
  local md_file="$2"
  if [[ -f "$result_file" && ! -f "$md_file" ]]; then
    return 1
  fi
  return 0
}

# rerun_reviewer_once: re-run a single reviewer once after a contract violation
# (.result written without matching .md). Cleans up all orphaned artifacts
# from both ISSUES_DIR and WORKTREE_DIR so the re-run starts fresh.
rerun_reviewer_once() {
  local reviewer_type="$1"  # "spec" or "quality"
  local task_n="$2"
  local task_title="$3"
  local task_text="$4"
  local base_sha="$5"
  local head_sha="$6"

  log "  invalid_agent_contract: ${reviewer_type}-review-task-${task_n} wrote .result but not .md — re-running once"

  # Clean up orphaned artifacts from both directories so the re-run starts fresh
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${ISSUES_DIR}/${reviewer_type}-review-task-${task_n}.md"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.result"
  rm -f "${WORKTREE_DIR}/${reviewer_type}-review-task-${task_n}.md"

  if [[ "$reviewer_type" == "spec" ]]; then
    local impl_report="$7"
    SPEC_REVIEW_RERUN_WARNING=1 run_spec_reviewer "$task_n" "$task_title" "$task_text" "$impl_report"
  elif [[ "$reviewer_type" == "quality" ]]; then
    QUALITY_REVIEW_RERUN_WARNING=1 run_quality_reviewer "$task_n" "$task_title" "$task_text" "$base_sha" "$head_sha"
  fi
}

# extract_result: focused extractor agent that reads source .md and writes .result
extract_result() {
  local phase="$1"
  local result_file="$2"
  local source_file="$3"; shift 3
  local allowed_values=("$@")
  local allowed_regex
  allowed_regex=$(printf '|%s' "${allowed_values[@]}")
  allowed_regex="${allowed_regex:1}"

  log "  Extractor: reading ${source_file} for ${phase} result..."

  EXTRACTOR_PROMPT="You are a result extractor. Read the file below and determine the outcome.

## Source File
$(cat "$source_file" 2>/dev/null || echo "File not found: ${source_file}")

## Allowed Values
${allowed_regex}

## Your Task
Read the source file and determine which allowed value best describes the outcome.
Write EXACTLY ONE of the allowed values to the result file — nothing else, no explanation.

Result file: ${result_file}

Write the result now."

  echo "$EXTRACTOR_PROMPT" | run_agent_raw "extract-${phase}" 60

  if validate_result_file "$result_file" "${allowed_values[@]}"; then
    log "  Extractor: successfully resolved ${phase} result"
    return 0
  else
    log "  Extractor: failed to resolve ${phase} result"
    return 1
  fi
}

# resolve_result: try .result file → extractor agent → fallback default
# Usage: resolve_result RESULT_FILE SOURCE_FILE ALLOWED_VAL1 ... ALLOWED_VALN FALLBACK
resolve_result() {
  local result_file="$1"
  local source_file="$2"; shift 2
  # Last arg is fallback, rest are allowed values
  local all_args=("$@")
  local fallback="${all_args[-1]}"
  local allowed_arr=("${all_args[@]:0:$(( ${#all_args[@]} - 1 ))}")

  # Detect invalid agent contract: .result present but .md missing.
  if [[ -f "$result_file" && ! -f "$source_file" ]]; then
    log "  Result file present but source .md missing — invalid agent contract, ignoring stale .result"
    # Fall through to extractor (will fail since .md is absent), then fallback
  else
    # Primary: valid .result file
    if validate_result_file "$result_file" "${allowed_arr[@]}"; then
      local val
      val=$(read_result_value "$result_file")
      log "  Result (file): ${val}"
      echo "$val"
      return 0
    fi
  fi

  log "  Result file missing or invalid, trying extractor..."

  # Fallback: extractor agent reads .md file
  if [[ -f "$source_file" ]]; then
    if extract_result "$(basename "$result_file" .result)" "$result_file" "$source_file" "${allowed_arr[@]}"; then
      local val
      val=$(read_result_value "$result_file")
      log "  Result (extractor): ${val}"
      echo "$val"
      return 0
    fi
  fi

  # Tertiary: conservative fallback default
  log "  Result (fallback): ${fallback}"
  echo "$fallback" > "$result_file" 2>/dev/null || true
  echo "$fallback"
  return 0
}

run_agent_raw() {
  local phase="$1"
  local timeout_sec="$2"
  local output_log="${ISSUES_DIR}/${phase}.log"
  local agent_cmd

  case "$AGENT_CLI" in
    claude|claude-minimax)
      agent_cmd="~/bin/claude-minimax --settings ~/.claude/profiles/minimax.json --print --model $AGENT_MODEL"
      ;;
    opencode)
      agent_cmd="opencode --model $AGENT_MODEL run"
      ;;
    *)
      orchestrator_fail "Unsupported AGENT_CLI: $AGENT_CLI"
      ;;
  esac

  log "Running agent for phase '$phase' (timeout=${timeout_sec}s)..."

  local prompt_file
  prompt_file=$(mktemp)
  cat > "$prompt_file"

  # Use process substitution to avoid PIPESTATUS issues with || true.
  # Capture agent exit code explicitly via a wrapper that writes to a temp file.
  local ec_file
  ec_file=$(mktemp)
  local ec=0

  # Run agent with timeout; capture exit code via wrapper so it's not lost
  # through the pipeline. The { ... ; } block writes the real exit code
  # before any pipeline consumer can obscure it.
  { timeout "$timeout_sec" bash -c "$agent_cmd" < "$prompt_file" 2>&1; echo $? > "$ec_file"; } \
    | tee -a "$output_log" \
    | grep -v "^\[0m$" | grep -v "^$" || true
  ec=$(cat "$ec_file")

  rm -f "$prompt_file" "$ec_file"

  if [[ $ec -eq 124 ]]; then
    orchestrator_fail "Phase '$phase' timed out after ${timeout_sec}s"
  fi

  if [[ $ec -ne 0 ]]; then
    warn "Phase '$phase' exited with code $ec"
    # Blocked detection requires a structured signal, not free-text matching.
    # The old grep ("waiting|blocked|asking.*question|need.*input", case-
    # insensitive) hit any agent prose that mentioned those words in passing
    # (e.g. "I waited for the test to finish") and killed valid runs.
    #
    # The contract is now: if the agent wants to block, it writes exactly
    # `BLOCKED` on its own line (optionally followed by a colon-prefixed
    # reason). This matches the same convention used by the result-file
    # mechanism (BLOCKED is one of the allowed result values).
    if grep -qE '^[[:space:]]*BLOCKED([[:space:]]*$|:)' "$output_log" 2>/dev/null; then
      orchestrator_fail "Phase '$phase' is blocked (agent emitted BLOCKED)"
    fi
  fi
}

# ── setup ─────────────────────────────────────────────────────────────────────
# Stage issue data in a temp directory outside the worktree, so it survives
# the rm-rf that happens before worktree creation on fresh runs.
ISSUE_STAGING_DIR="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}-staging"
mkdir -p "${ISSUES_DIR}"
mkdir -p "${ISSUE_STAGING_DIR}"
echo "" > "${ISSUES_DIR}/orchestrator.log"

log "=== Starting orchestrator for issue #${ISSUE_NUM} ==="

# ── auto-resume: task-level checkpoint detection ─────────────────────────────
LAST_PHASE="start"

  get_task_completion_status() {
    local task_n="$1"
    local impl_result_file="${ISSUES_DIR}/implement-task-${task_n}.result"
    local spec_result_file="${ISSUES_DIR}/spec-review-task-${task_n}.result"
    local quality_result_file="${ISSUES_DIR}/quality-review-task-${task_n}.result"

    local impl_result="PENDING"
    if [[ -f "$impl_result_file" ]]; then
      impl_result=$(cat "$impl_result_file" 2>/dev/null || echo "PENDING")
    fi

    if [[ "$impl_result" != "DONE" ]]; then
      if [[ -f "${ISSUES_DIR}/implement-task-${task_n}.log" ]]; then
        echo "implementing"
      else
        echo "pending"
      fi
      return
    fi

    if [[ ! -f "$spec_result_file" || ! -f "$quality_result_file" ]]; then
      echo "review-needed"
      return
    fi

    local spec_result quality_result
    spec_result=$(cat "$spec_result_file" 2>/dev/null || echo "SPEC_FAIL")
    quality_result=$(cat "$quality_result_file" 2>/dev/null || echo "QUALITY_FAIL")

    if [[ "$spec_result" == "SPEC_PASS" && "$quality_result" == "QUALITY_PASS" ]]; then
      echo "complete"
    else
      echo "review-needed"
    fi
  }

find_first_incomplete_task() {
  local plan_file="${ISSUES_DIR}/plan.md"
  if [[ ! -f "$plan_file" ]]; then
    echo "0"
    return
  fi

  local task_count
  task_count=$(awk '/^#{2,3} Task [0-9]+:/ {n++} END{print n+0}' "$plan_file")

  if [[ "$task_count" -eq 0 ]]; then
    echo "0"
    return
  fi

  local n=1
  while [[ $n -le "$task_count" ]]; do
    local status
    status=$(get_task_completion_status "$n")
    if [[ "$status" != "complete" ]]; then
      echo "$n"
      return
    fi
    n=$((n + 1))
  done

  echo "$((task_count + 1))"
}

detect_resume_point() {
  local first_incomplete
  first_incomplete=$(find_first_incomplete_task)

  if [[ "$first_incomplete" -eq 0 ]]; then
    echo "read_issue"
    return
  fi

  local status
  status=$(get_task_completion_status "$first_incomplete")

  case "$status" in
    complete)
      local task_count
      task_count=$(awk '/^#{2,3} Task [0-9]+:/ {n++} END{print n+0}' "${ISSUES_DIR}/plan.md")
      if [[ $first_incomplete -gt $task_count ]]; then
        echo "validate"
      else
        echo "implement"
      fi
      ;;
    implementing)    echo "implement" ;;
    pending)        echo "implement" ;;
    review-needed)  echo "spec-review" ;;
    *)              echo "implement" ;;
  esac
}

detect_phase() {
  if [[ -n "${ORCHESTRATOR_PHASE:-}" ]]; then
    echo "$ORCHESTRATOR_PHASE"
    return
  fi

  if [[ -f "${ISSUES_DIR}/pr-url.txt" ]]; then
    echo "done"
  elif [[ -f "${ISSUES_DIR}/compound.md" ]]; then
    echo "create-pr"
  elif [[ -f "${ISSUES_DIR}/review.md" ]]; then
    echo "fix-review"
  elif [[ -f "${ISSUES_DIR}/validate.log" ]]; then
    echo "review"
  elif [[ -f "${ISSUES_DIR}/plan.md" ]]; then
    detect_resume_point
  elif [[ -f "${ISSUES_DIR}/design.md" ]]; then
    echo "plan-write"
  elif [[ -f "${ISSUES_DIR}/issue.json" ]]; then
    echo "plan-design"
  else
    echo "read_issue"
  fi
}

PHASE="$(detect_phase)"
_INITIAL_PHASE="$PHASE"

log "Auto-resume: detected phase='${PHASE}'"

emit_event "" "info" "run.started" "issue-to-PR run started" \
  issueNumber="$ISSUE_NUM" baseBranch="${BASE_BRANCH:-main}" branch="$BRANCH"

if [[ "$PHASE" == "done" ]]; then
  log "Orchestrator already completed. See $(cat "${ISSUES_DIR}/pr-url.txt" 2>/dev/null || echo 'PR')."
  emit_event "" "info" "run.completed" "run already completed" \
    prUrl="$(cat "${ISSUES_DIR}/pr-url.txt" 2>/dev/null || echo '')"
  exit 0
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: read_issue
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "read_issue" ]]; then
  log "=== Phase: read_issue ==="
  _emit_phase_started "read_issue"
  LAST_PHASE="read_issue"

  # Guard: don't destroy existing progress on accidental re-entry
  if [[ -f "${ISSUES_DIR}/design.md" || -f "${ISSUES_DIR}/plan.md" ]]; then
    orchestrator_fail "read_issue phase reached but progress artifacts exist (design.md/plan.md). Likely a resume-detection bug. Use ORCHESTRATOR_PHASE=implement to force resume."
  fi

  # Fetch issue — write to staging dir (not worktree, which gets rm -rf'd below)
  gh issue view "$ISSUE_NUM" \
    --json number,title,body,url,labels,comments,state \
    > "${ISSUE_STAGING_DIR}/issue.json" \
    || orchestrator_fail "Failed to fetch issue #${ISSUE_NUM}"

  # Save issue body and comments
  gh issue view "$ISSUE_NUM" --json body --jq '.body' \
    > "${ISSUE_STAGING_DIR}/issue.md"

  # gh issue view --json comments returns at most 100 comments (GraphQL limit,
  # no auto-pagination). Use the REST endpoint with --paginate so issues with
  # hundreds of comments don't silently lose data.
  gh api --paginate "repos/${OWNER_REPO}/issues/${ISSUE_NUM}/comments" \
    --jq '.[].body' \
    > "${ISSUE_STAGING_DIR}/issue-comments.md"

  ISSUE_TITLE=$(gh issue view "$ISSUE_NUM" --json title --jq '.title')
  log "Issue #${ISSUE_NUM}: ${ISSUE_TITLE}"



  # Check for blocked label
  if gh issue view "$ISSUE_NUM" --json labels --jq '.labels[].name' | grep -qx "ai:blocked"; then
    orchestrator_fail "Issue has ai:blocked label"
  fi

  # Create worktree/branch
  info "Creating branch: ${BRANCH}"
  git fetch origin "$BASE_BRANCH" 2>/dev/null || true

  # Delete remote branch if it exists (fresh start)
  if git fetch origin "${BRANCH}" 2>/dev/null; then
    warn "Remote branch ${BRANCH} exists — deleting for fresh start"
    git push origin --delete "${BRANCH}" 2>/dev/null || true
  fi

  # Prune stale worktree admin refs, then create fresh worktree
  git worktree prune 2>/dev/null || true
  if ! git rev-parse --verify "${BRANCH}" 2>/dev/null; then
    rm -rf "$WORKTREE_DIR"
    git worktree add "$WORKTREE_DIR" -b "$BRANCH" "origin/${BASE_BRANCH}"
    if [[ ! -f "${WORKTREE_DIR}/.git" ]]; then
      orchestrator_fail "Worktree creation failed — ${WORKTREE_DIR} is not a git worktree"
    fi
  fi

  # Copy staged issue data into the worktree (survived the rm -rf above)
  cp "${ISSUE_STAGING_DIR}/issue.json" "${WORKTREE_DIR}/issue.json" 2>/dev/null || true
  cp "${ISSUE_STAGING_DIR}/issue.md" "${WORKTREE_DIR}/issue.md" 2>/dev/null || true
  cp "${ISSUE_STAGING_DIR}/issue-comments.md" "${WORKTREE_DIR}/issue-comments.md" 2>/dev/null || true
  cp "${ISSUES_DIR}/orchestrator.log" "${WORKTREE_DIR}/orchestrator.log" 2>/dev/null || true
  rm -rf "${ISSUE_STAGING_DIR}"

  # Copy prompts into worktree
  mkdir -p "${WORKTREE_DIR}/automation/prompts"
  cp -r "${REPO_ROOT}/${PROMPTS_DIR}"/*.md "${WORKTREE_DIR}/automation/prompts/" 2>/dev/null || true
  mkdir -p "${WORKTREE_DIR}/scripts"
  cp -r "${REPO_ROOT}/scripts/"*.sh "${WORKTREE_DIR}/scripts/" 2>/dev/null || true

  # Run artifacts (issue.json, issue.md, issue-comments.md) are written directly to worktree
  # Seed exclude rules so orchestrator artifacts are never tracked by git.
  seed_excludes

  # Archive pre-seeding: skip phases that already have outputs from a prior run
  ARCHIVE_DIR="${REPO_ROOT}/ai/issues/${ISSUE_NUM}"
  if [[ -f "${ARCHIVE_DIR}/plan.md" ]]; then
    info "Archive has plan.md — pre-seeding to skip plan-design and plan-write"
    cp "${ARCHIVE_DIR}/plan.md" "${WORKTREE_DIR}/plan.md"
    cp "${ARCHIVE_DIR}/design.md" "${WORKTREE_DIR}/design.md" 2>/dev/null || true
    PHASE="implement"
  elif [[ -f "${ARCHIVE_DIR}/design.md" ]]; then
    info "Archive has design.md — pre-seeding to skip plan-design"
    cp "${ARCHIVE_DIR}/design.md" "${WORKTREE_DIR}/design.md"
    PHASE="plan-write"
  else
    PHASE="plan-design"
  fi
  _emit_phase_done "read_issue"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: plan-design — brainstorm using the brainstorming skill
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "plan-design" ]]; then
  log "=== Phase: plan-design (brainstorm) ==="
  _emit_phase_started "plan-design"
  LAST_PHASE="plan-design"

  ensure_worktree

  BRAINSTORM_PROMPT="You are analyzing a GitHub issue to produce a design document.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue file: issue.md (contains the GitHub issue description)
Comments file: issue-comments.md (contains issue comments)

## TASK
1. Load the brainstorming skill: say exactly '/skill brainstorming' to activate it.
2. Read issue.md and issue-comments.md thoroughly.
3. Analyze the codebase to understand the existing patterns, types, and architecture relevant to this issue.
4. Using the brainstorming skill guidance, produce a design document at ./design.md covering:
   - The problem being solved and why it matters
   - Key design decisions and trade-offs considered
   - Proposed approach with rationale
   - Assumptions made (do not ask questions — state assumptions explicitly)
   - What is in scope and what is explicitly out of scope
   - Any risks or concerns identified from code analysis

## CRITICAL RULES
- Do NOT ask questions. Make reasonable assumptions and document them explicitly.
- Do NOT rely on agent memory. Write everything to design.md.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing design.md. Do not implement anything.

Write design.md now."

  echo "$BRAINSTORM_PROMPT" | run_agent_raw "plan-design" "$TIMEOUT_BRAINSTORM"

  if [[ ! -f "${WORKTREE_DIR}/design.md" ]]; then
    orchestrator_fail "Design doc not found after plan-design phase"
  fi
  info "Design doc saved to ${WORKTREE_DIR}/design.md"
  _emit_artifact "plan-design" "${WORKTREE_DIR}/design.md" "design"

  _emit_phase_done "plan-design"
  PHASE="plan-write"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: plan-write — write implementation plan using writing-plans skill
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "plan-write" ]]; then
  log "=== Phase: plan-write (implementation plan) ==="
  _emit_phase_started "plan-write"
  LAST_PHASE="plan-write"

  ensure_worktree

  # design.md lives in the worktree (written by plan-design agent) — no action needed

  PLAN_WRITE_PROMPT="You are writing an implementation plan.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Design doc: design.md (produced in the previous brainstorming step)
Issue file: issue.md
Comments file: issue-comments.md

## TASK
1. Load the writing-plans skill: say exactly '/skill writing-plans' to activate it.
2. Read design.md, issue.md, and issue-comments.md.
3. Using the writing-plans skill guidance, produce a complete implementation plan at ./plan.md.

The plan MUST include:
- goal
- non-goals
- affected files (full paths from repo root)
- ordered implementation tasks (numbered, clear description per task)
- tests to add or update
- validation commands (exact commands to verify correctness)
- risk areas
- stop conditions (what would cause you to abort instead of continue)

## CRITICAL RULES
- Do NOT ask questions. Make reasonable assumptions and document them.
- Do NOT rely on agent memory. Write everything to plan.md.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing plan.md. Do not implement anything.

Write plan.md now."

  echo "$PLAN_WRITE_PROMPT" | run_agent_raw "plan-write" "$TIMEOUT_PLAN_WRITE"

  if [[ ! -f "${WORKTREE_DIR}/plan.md" ]]; then
    orchestrator_fail "Plan file not found after plan-write phase"
  fi
  info "Plan saved to ${WORKTREE_DIR}/plan.md"
  _emit_artifact "plan-write" "${WORKTREE_DIR}/plan.md" "plan"

  _emit_phase_done "plan-write"
  PHASE="implement"
fi

# ── Map resume phases into implement with correct resume stage ──────────────
if [[ "$PHASE" == "spec-review" || "$PHASE" == "quality-review" ]]; then
  # These phases are now handled inside the review-fix loop.
  # Map to "implement" with resume stage "review" so the task loop re-enters correctly.
  info "Auto-resume: mapping phase '${PHASE}' to implement with review stage"
  RESUME_STAGE_OVERRIDE="review"
  PHASE="implement"
fi

if [[ "$_INITIAL_PHASE" != "read_issue" ]]; then _emit_skipped_until "$PHASE"; fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: implement — subagent-driven development per task
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "implement" ]]; then
  log "=== Phase: implement ==="
  _emit_phase_started "implement"
  LAST_PHASE="implement"

  ensure_worktree

  if [[ -f "${ISSUES_DIR}/blocked.json" ]]; then
    orchestrator_fail "Orchestrator is blocked from previous phase"
  fi

  TASK_MANIFEST="${ISSUES_DIR}/task-manifest.json"

  # ── helpers ────────────────────────────────────────────────────────────────

  # Parse numbered tasks from plan.md, output one per line: "N. Title"
  parse_tasks() {
    local plan_file="$1"
    grep -E "^#{2,3} Task [0-9]+:" "$plan_file" 2>/dev/null | sed -E "s/^#{2,3} Task [0-9]+: //" || true
  }

  # Extract full task text (from ## Task N: title line to the next ## section header)
  # Uses a temp file for the task_title to avoid all bash interpolation issues
  # with special chars (backticks, asterisks, $(), etc.) in task titles.
  # Terminates on: any ^##  line (section header like ## Risk Areas, ## Stop Conditions, etc.)
  extract_task_text() {
    local plan_file="$1"
    local task_title="$2"

    local title_file
    title_file=$(mktemp)
    printf '%s' "$task_title" > "$title_file"

    local line_num
    line_num=$(grep -F -n -f "$title_file" "$plan_file" 2>/dev/null | head -1 | cut -d: -f1 || true)
    rm -f "$title_file"

    if [[ -z "$line_num" ]]; then return 1; fi

    printf '%s' "$task_title" > "$title_file"
    tail -n +"$line_num" "$plan_file" | awk -v title_file="$title_file" '
      BEGIN {
        while ((getline line < title_file) > 0) { title = line }
        close(title_file)
        buf_idx = 0
      }
      NF == 0 { next }
      index($0, title) > 0 { in_task=1; next }
      /^## / {
        if (in_task) {
          for (i = 1; i <= buf_idx; i++) print buf[i]
          exit
        }
      }
      in_task { buf[++buf_idx] = $0 }
    '
    rm -f "$title_file"
  }

  # Get task number from title prefix
  task_num() { echo "$1" | cut -d. -f1; }

  extract_task_commit_msg() {
    local plan_file="$1"
    local task_title="$2"
    local fallback_msg="$3"

    local title_file
    title_file=$(mktemp)
    printf '%s' "$task_title" > "$title_file"

    local line_num
    line_num=$(grep -F -n -f "$title_file" "$plan_file" 2>/dev/null | head -1 | cut -d: -f1 || true)
    rm -f "$title_file"

    if [[ -z "$line_num" ]]; then
      echo "$fallback_msg"
      return
    fi

    local next_task_line
    next_task_line=$(awk -v start="$line_num" 'NR > start && /^#{2,3} Task [0-9]+:/ {print NR; exit}' "$plan_file")

    local commit_msg
    if [[ -n "$next_task_line" ]]; then
      commit_msg=$(sed -n "${line_num},$((next_task_line - 1))p" "$plan_file" | grep -oP 'git commit -m "\K[^"]+' | tail -1)
    else
      commit_msg=$(tail -n +"$line_num" "$plan_file" | grep -oP 'git commit -m "\K[^"]+' | tail -1)
    fi

    if [[ -n "$commit_msg" ]]; then
      echo "$commit_msg"
    else
      echo "$fallback_msg"
    fi
  }

  # Run implementer for a single task; writes status to file (not stdout)
  run_implementer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local commit_msg="$4"
    local output_log="${ISSUES_DIR}/implement-task-${task_n}.log"
    local impl_status="unknown"

    log "  Task ${task_n}: implementing..."

    IMPLEMENTER_PROMPT="You are implementing Task ${task_n}: ${task_title}

## Task Description
${task_text}

## Context
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Design: design.md
Plan: plan.md
Branch: ${BRANCH}

You are using Subagent-Driven Development. Follow the process below exactly.

## SCOPE RESTRICTION
You are implementing ONLY Task ${task_n}: ${task_title}.

Tasks numbered higher than ${task_n} in plan.md are EXPLICITLY OUT OF SCOPE
for this run. They will be implemented by separate later runs of this
orchestrator. You must NOT:
- create files, types, schemas, tests, exports, or migrations that belong
  to a later task, even if you have all the context to do so;
- 'finish the plan' because tasks N+1..M look small or related;
- pre-stage scaffolding for later tasks 'to save time later'.

A commit that includes any later-task work is a scope violation, not
helpfulness — it breaks per-task review, makes resume undecidable, and
forces the operator to revert and re-run. The plan's per-task commit
boundary is load-bearing: respect it.

If you finish Task ${task_n} quickly: STOP, run the self-review, and
report DONE. Do not 'continue' into the next task.

You may READ files associated with later tasks for context, but you must
not write, modify, stage, or commit them in this run.

## Your Job

1. Read issue.md, design.md, and plan.md for context. Identify the
   boundaries of Task ${task_n} specifically.
2. Implement exactly what Task ${task_n} specifies — nothing more.
3. Write tests following TDD where applicable, scoped to Task ${task_n}.
4. Verify Task ${task_n}'s implementation works.
5. Run: git add -A && git commit -m '${commit_msg}'
6. Self-review before reporting back, including the scope check below.

## Questions?
If you have clarifications or concerns BEFORE implementing, note them in your report
and proceed with a reasonable assumption. Do not ask questions — make decisions
and document them.

## Self-Review Checklist (before reporting back)
- Scope: Run \`git diff --stat HEAD~1\` mentally — does every changed
  file belong to Task ${task_n} alone? If any file is for a later task,
  REMOVE it from the commit before reporting DONE.
- Completeness: Did I implement everything Task ${task_n} specifies?
- Quality: Is the code clean and maintainable?
- Discipline: Did I avoid overbuilding?
- Testing: Do tests verify actual behavior?

## Report Format
Report back with:
- Status: DONE | DONE_WITH_CONCERNS | BLOCKED | NEEDS_CONTEXT
- What you implemented
- What you tested and results
- Files changed
- Self-review findings
- Any questions or concerns

## MANDATORY RESULT FILE
After reporting, write EXACTLY ONE of these values to ./implement-task-${task_n}.result:
- DONE
- DONE_WITH_CONCERNS
- BLOCKED
- NEEDS_CONTEXT
No other content in the file — just the status word.

Stop after writing the result file.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    echo "$IMPLEMENTER_PROMPT" | run_agent_raw "implement-task-${task_n}" "$TIMEOUT_IMPLEMENT"
    check_branch_after_agent
  }

  # Run spec reviewer for a single task; writes result to file (not stdout)
  run_spec_reviewer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local impl_report="$4"
    local output_log="${ISSUES_DIR}/spec-review-task-${task_n}.log"

    log "  Task ${task_n}: spec review..."

    SPEC_REVIEWER_PROMPT="You are reviewing whether an implementation matches its specification.

## Design Context
Read these files for full context on what was intended:
- Design: ./design.md
- Implementation plan: ./plan.md

## SCOPE RESTRICTION
You are reviewing ONLY Task ${task_n}: ${task_title}.
Evaluate ONLY whether this task's requirements have been met. Do NOT flag
missing features, files, or behaviors that belong to other tasks in the plan.
The plan is executed task-by-task; tasks not yet implemented are expected to be
absent. A missing task is NOT a spec failure for the current task.

## Task Requirements
${task_text}

## What Implementer Claims They Built
$(head -n 50 <<< "$impl_report")

## CRITICAL: Do Not Trust the Report
You MUST read the actual code and verify line by line. Do not take the
implementer's word for what was built.

## Your Job
1. Read the design and plan documents first for context on this specific task.
2. Read the code that was actually committed.
3. Compare actual implementation to THIS task's requirements only.
4. Check for missing pieces within this task's scope.
5. Check for extra work not requested within this task's scope.
6. Check for misunderstandings.

## Report Format
- ✅ Spec compliant (if everything matches)
- ❌ Issues found: [list specifically with file:line references]

## MANDATORY OUTPUT FILES — write BOTH, in this exact order

**Step 1**: Write `./spec-review-task-${task_n}.md` — the detailed findings
the fix-review agent will read. Include every issue with file:line references,
the spec requirement violated, and what would satisfy it. If everything passes,
write a single line: 'No findings. Implementation matches the spec.'

**Step 2**: Write `./spec-review-task-${task_n}.result` — EXACTLY ONE of:
SPEC_PASS | SPEC_FAIL. No other content — just the status word.

CRITICAL ORDERING RULE:
- You MUST write the .md file FIRST, then the .result file LAST.
- Do NOT write the .result file until you have finalized your verdict.
- The .result file is your final action before stopping.
- If you changed your mind during analysis, rewrite BOTH files with the
  final verdict. The .result file must match the conclusion in the .md file.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    if [[ "${SPEC_REVIEW_RERUN_WARNING:-}" == "1" ]]; then
      SPEC_REVIEWER_PROMPT="WARNING: Your previous attempt wrote the .result file but did not write the .md report file. This is a contract violation. You MUST write BOTH files in order: .md first, then .result last.

${SPEC_REVIEWER_PROMPT}"
    fi

    echo "$SPEC_REVIEWER_PROMPT" | run_agent_raw "spec-review-task-${task_n}" "$TIMEOUT_REVIEW"
    check_branch_after_agent
  }

  # Run quality reviewer for a single task; writes result to file (not stdout)
  run_quality_reviewer() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"
    local base_sha="$4"
    local head_sha="$5"
    local output_log="${ISSUES_DIR}/quality-review-task-${task_n}.log"

    log "  Task ${task_n}: quality review..."

    QUALITY_REVIEWER_PROMPT="You are reviewing the quality of an implementation.

## Design Context
Read these files for full context on what was intended:
- Design: ./design.md
- Implementation plan: ./plan.md

## Task Summary
${task_title}

## Task Requirements
${task_text}

## What Was Implemented
Files changed (see git diff ${base_sha}..${head_sha})

## Your Job
Run: git diff ${base_sha}..${head_sha}

First, check if the diff contains code changes (*.ts, *.tsx, *.js, *.jsx, *.py, etc.) or is documentation-only (*.md, *.txt, *.rst, etc.). Then review accordingly:

**If the diff contains code changes**, review for:
- Code cleanliness and maintainability
- Proper testing
- Following existing patterns
- Single responsibility per file

**If the diff is documentation-only**, review for:
- Accuracy: do the changes correctly describe the system behavior?
- Clarity: is the writing clear and unambiguous?
- Consistency: do the changes align with other documentation and the actual codebase?
- Formatting: proper markdown, no broken links or typos?

Do NOT fail a documentation-only change for lacking tests, code patterns, or code-specific criteria. A documentation change that is accurate, clear, and consistent should get QUALITY_PASS.

## Report Format
- Strengths: [what was done well]
- Issues: [Critical | Important | Minor]
- Assessment: APPROVED | NEEDS_WORK

## MANDATORY OUTPUT FILES — write BOTH

1. ./quality-review-task-${task_n}.md
   The detailed findings the fix-review agent will read. Include every
   issue with file:line references, severity, and what would resolve it.
   If everything passes, write a single line:
   'No findings. Implementation meets the quality bar.'

2. ./quality-review-task-${task_n}.result
   EXACTLY ONE of: QUALITY_PASS | QUALITY_FAIL
   No other content in the file — just the status word.

Both files MUST be written before you stop, even on QUALITY_PASS. The
.md file is the primary handoff to the fix-review agent — without it,
the orchestrator silently marks the task complete despite failures.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    if [[ "${QUALITY_REVIEW_RERUN_WARNING:-}" == "1" ]]; then
      QUALITY_REVIEWER_PROMPT="WARNING: Your previous attempt wrote the .result file but did not write the .md report file. This is a contract violation. You MUST write BOTH files in order: .md first, then .result last.

${QUALITY_REVIEWER_PROMPT}"
    fi

    echo "$QUALITY_REVIEWER_PROMPT" | run_agent_raw "quality-review-task-${task_n}" "$TIMEOUT_REVIEW"
    check_branch_after_agent
  }

  # Run fix-review: agent reads both review reports and fixes findings
  run_fix_review() {
    local task_n="$1"
    local task_title="$2"
    local task_text="$3"

    log "  Task ${task_n}: fix review..."

    # Read findings from .md if present (preferred), else fall back to the
    # .log (the agent's full transcript). Without this fallback, the missing
    # .md silently produces empty findings and the fix-review agent reports
    # 'no fixes needed' against real review failures (observed on issue #4
    # task 1 where SPEC_FAIL + QUALITY_FAIL still produced DONE_NO_FIXES_NEEDED).
    local spec_findings="" quality_findings=""
    local spec_md="${WORKTREE_DIR}/spec-review-task-${task_n}.md"
    local quality_md="${WORKTREE_DIR}/quality-review-task-${task_n}.md"
    local spec_log="${ISSUES_DIR}/spec-review-task-${task_n}.log"
    local quality_log="${ISSUES_DIR}/quality-review-task-${task_n}.log"

    if [[ -s "$spec_md" ]]; then
      spec_findings=$(cat "$spec_md")
    elif [[ -s "$spec_log" ]]; then
      # Strip ANSI escapes (\033[...m) so the agent reads clean prose.
      spec_findings=$(sed -E 's/\x1B\[[0-9;]*[a-zA-Z]//g' "$spec_log")
    fi
    if [[ -s "$quality_md" ]]; then
      quality_findings=$(cat "$quality_md")
    elif [[ -s "$quality_log" ]]; then
      quality_findings=$(sed -E 's/\x1B\[[0-9;]*[a-zA-Z]//g' "$quality_log")
    fi

    if [[ -z "$spec_findings" && -z "$quality_findings" ]]; then
      orchestrator_fail "Task ${task_n} fix-review has no findings to act on (no .md, no .log). Reviewer agents must write detailed findings."
    fi

    FIX_REVIEW_PROMPT="You are fixing review findings for Task ${task_n}: ${task_title}

## Task Requirements
${task_text}

## Spec Review Findings
${spec_findings}

## Quality Review Findings
${quality_findings}

## Your Job
1. Read both review reports above carefully.
2. Read the actual source files referenced in the reviews.
3. Fix ALL legitimate findings. Skip findings that are:
   - Invalid (the reviewer was wrong)
   - Pre-existing (not introduced by this task)
   - Nitpicks that don't affect correctness
4. If neither review has actionable findings, write 'Status: DONE_NO_FIXES_NEEDED' and stop.
5. If you made fixes, run: git add -A && git commit -m 'fix: task ${task_n} review findings'
6. Self-verify your fixes address the actual findings.

## Report Format
Report back with:
- Status: DONE | DONE_NO_FIXES_NEEDED | BLOCKED
- What you fixed (with file references)
- What you intentionally skipped and why
- Any remaining concerns

## MANDATORY RESULT FILE
After reporting, write EXACTLY ONE of these values to ./fix-review-task-${task_n}.result:
- DONE
- DONE_NO_FIXES_NEEDED
- BLOCKED
No other content in the file — just the status word.

Stop after writing the result file.

CRITICAL: Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}."

    echo "$FIX_REVIEW_PROMPT" | run_agent_raw "fix-review-task-${task_n}" "$TIMEOUT_FIX"
    check_branch_after_agent
  }

  # ── main task loop ─────────────────────────────────────────────────────────
  cd "${WORKTREE_DIR}"
  ensure_branch

  log "Installing dependencies in worktree..."
  {
    echo "=== pnpm install ==="
    timeout 120 pnpm install --frozen-lockfile 2>&1 | tail -10 || echo "[install completed with warnings]"
  } > >(tee -a "${ISSUES_DIR}/install-worktree.log") 2>&1 || true

  log "Building workspace packages in worktree..."
  {
    echo "=== pnpm -r build ==="
    timeout 180 pnpm -r build 2>&1 | tail -20 || echo "[build completed with warnings]"
  } > >(tee -a "${ISSUES_DIR}/install-worktree.log") 2>&1 || true

  if [[ ! -f "plan.md" ]]; then
    orchestrator_fail "plan.md not found in worktree"
  fi

  TASKS=$(parse_tasks "plan.md")
  TASK_COUNT=$(echo "$TASKS" | grep -c "." || echo 0)

  if [[ $TASK_COUNT -eq 0 ]]; then
    orchestrator_fail "No tasks found in plan.md"
  fi

  log "Found ${TASK_COUNT} task(s) to implement"

  TASK_NUM=0
  IMPLEMENTATION_LOG="${ISSUES_DIR}/implementation-log.md"
  echo "# Implementation Log — Issue #${ISSUE_NUM}" > "$IMPLEMENTATION_LOG"
  _emit_artifact "implement" "${ISSUES_DIR}/implementation-log.md" "implementation_log"

  RESUME_TASK_NUM=0
  RESUME_STAGE=""
  RESUME_TASK_NUM=$(find_first_incomplete_task)
  if [[ -n "${RESUME_STAGE_OVERRIDE:-}" ]]; then
    RESUME_STAGE="$RESUME_STAGE_OVERRIDE"
    log "Auto-resume: task ${RESUME_TASK_NUM}, stage '${RESUME_STAGE}' (from detected phase)"
  else
    RESUME_STAGE="implement"
    log "Auto-resume: task ${RESUME_TASK_NUM}, stage '${RESUME_STAGE}'"
  fi

  while IFS= read -r task_title; do
    TASK_NUM=$((TASK_NUM + 1))

    if [[ $TASK_NUM -lt $RESUME_TASK_NUM ]]; then
      log "  Skipping completed task ${TASK_NUM}"
      continue
    fi

    log "=== Task ${TASK_NUM}/${TASK_COUNT}: ${task_title} ==="

    TASK_TEXT=$(extract_task_text "plan.md" "$task_title")
    if [[ -z "$TASK_TEXT" ]]; then
      warn "Could not extract task text for '${task_title}', using title as description"
      TASK_TEXT="$task_title"
    fi

    BASE_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")

    COMMIT_MSG=$(extract_task_commit_msg "plan.md" "$task_title" "feat: implement issue #${ISSUE_NUM} task ${TASK_NUM}")

    if [[ "$TASK_NUM" -eq "$RESUME_TASK_NUM" && "$RESUME_STAGE" == "review" ]]; then
      log "  Resuming at review loop for task ${TASK_NUM}"
    fi

    IMPL_STATUS="DONE"
    HEAD_SHA=""
    REVIEW_LOOPS=0

    # Step 1: Implement
    if [[ $TASK_NUM -gt $RESUME_TASK_NUM || "$RESUME_STAGE" == "implement" || -z "$RESUME_STAGE" ]]; then
      run_implementer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$COMMIT_MSG"
      IMPL_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/implement-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/implement-task-${TASK_NUM}.md" \
        DONE DONE_WITH_CONCERNS BLOCKED NEEDS_CONTEXT \
        "DONE")
      log "  Implementer status: ${IMPL_STATUS}"

      if [[ "$IMPL_STATUS" == "BLOCKED" || "$IMPL_STATUS" == "NEEDS_CONTEXT" ]]; then
        orchestrator_fail "Task ${TASK_NUM} is ${IMPL_STATUS}. Fix the blocker and re-run."
      fi

      HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
    fi

    # Step 2: Initial spec + quality reviews, then fix loop (max 5 iterations).
    # We always run initial reviews here — even on resume. Reaching this point
    # on a resumed run means find_first_incomplete_task returned this task
    # because its status is "review-needed" (i.e. reviews are NOT both passing
    # yet). Skipping reviews in that state would silently mark the task
    # complete with no review evidence, as happened on the issue #4 run.
    IMPL_REPORT=$(cat "${ISSUES_DIR}/implement-task-${TASK_NUM}.log" 2>/dev/null || echo "")
    run_spec_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$IMPL_REPORT"
    run_quality_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"

    # Validate review artifacts: .result without .md = invalid agent contract
    # Both files are written by the agent to WORKTREE_DIR using relative paths.
    spec_result="${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result"
    spec_md="${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md"
    quality_result="${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result"
    quality_md="${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md"

    # Validate spec-review artifacts
    if ! validate_review_artifacts "$spec_result" "$spec_md"; then
      rerun_reviewer_once "spec" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA" "$IMPL_REPORT"
      if ! validate_review_artifacts "$spec_result" "$spec_md"; then
        orchestrator_fail "invalid_agent_contract: spec-review-task-${TASK_NUM} wrote .result but not .md after re-run"
      fi
    fi

    # Validate quality-review artifacts
    if ! validate_review_artifacts "$quality_result" "$quality_md"; then
      rerun_reviewer_once "quality" "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"
      if ! validate_review_artifacts "$quality_result" "$quality_md"; then
        orchestrator_fail "invalid_agent_contract: quality-review-task-${TASK_NUM} wrote .result but not .md after re-run"
      fi
    fi

    # Fix-review loop: agent fixes findings, then re-reviews, up to 5 times
    while [[ $REVIEW_LOOPS -lt 5 ]]; do
      REVIEW_LOOPS=$((REVIEW_LOOPS + 1))
      log "  Review-fix loop ${REVIEW_LOOPS}/5 for task ${TASK_NUM}"
      emit_event "fix-review" "info" "loop.iteration.started" \
        "fix-review loop ${REVIEW_LOOPS}/5 for task ${TASK_NUM}" \
        task="${TASK_NUM}" iteration="${REVIEW_LOOPS}" max=5
      log "  Cancel window: press Ctrl+C within 10s to abort..."
      sleep 10

      run_fix_review "$TASK_NUM" "$task_title" "$TASK_TEXT"
      FIX_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/fix-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/fix-review-task-${TASK_NUM}.md" \
        DONE DONE_NO_FIXES_NEEDED BLOCKED \
        "DONE")

      if [[ "$FIX_STATUS" == "BLOCKED" ]]; then
        orchestrator_fail "Task ${TASK_NUM} fix review is blocked. Fix the blocker and re-run."
      fi

      # Update HEAD_SHA after potential fixes
      HEAD_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")

      # Check current review status after fix attempt
      log "  Task ${TASK_NUM}: re-running reviews after fix loop..."
      IMPL_REPORT=$(cat "${ISSUES_DIR}/fix-review-task-${TASK_NUM}.log" 2>/dev/null || echo "")
      run_spec_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$IMPL_REPORT"
      run_quality_reviewer "$TASK_NUM" "$task_title" "$TASK_TEXT" "$BASE_SHA" "$HEAD_SHA"

      # Check if reviews now pass — resolve from result files
      SPEC_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/spec-review-task-${TASK_NUM}.md" \
        SPEC_PASS SPEC_FAIL \
        "SPEC_FAIL")
      QUALITY_STATUS=$(resolve_result \
        "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.result" \
        "${WORKTREE_DIR}/quality-review-task-${TASK_NUM}.md" \
        QUALITY_PASS QUALITY_FAIL \
        "QUALITY_FAIL")

      emit_event "fix-review" "info" "loop.iteration.completed" \
        "fix-review loop ${REVIEW_LOOPS} completed (spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?})" \
        task="${TASK_NUM}" iteration="${REVIEW_LOOPS}" \
        spec="${SPEC_STATUS:-unknown}" quality="${QUALITY_STATUS:-unknown}"

      if [[ "$SPEC_STATUS" == "SPEC_PASS" && "$QUALITY_STATUS" == "QUALITY_PASS" ]]; then
        log "  Task ${TASK_NUM}: both reviews pass"
        break
      elif [[ "$FIX_STATUS" == "DONE_NO_FIXES_NEEDED" ]]; then
        # Fix-agent declined to do anything but reviews remain failing.
        # This is NOT a stable terminal state — it means the fix-agent
        # didn't see the findings (Bug A/B), or the findings genuinely
        # require human judgement. Either way, do not silently mark the
        # task complete — fail the orchestrator so the operator looks.
        orchestrator_fail "Task ${TASK_NUM}: reviews failing (spec=${SPEC_STATUS}, quality=${QUALITY_STATUS}) and fix-agent reported no fixes. Inspect spec-review-task-${TASK_NUM}.md / quality-review-task-${TASK_NUM}.md and re-run."
      fi
    done

    if [[ $REVIEW_LOOPS -eq 5 ]]; then
      emit_event "fix-review" "error" "loop.exhausted" \
        "fix-review hit max iterations for task ${TASK_NUM}" \
        task="${TASK_NUM}" iterations="$REVIEW_LOOPS"
      orchestrator_fail "Review loop hit max 5 iterations for task ${TASK_NUM}. Reviews not passing (spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?})."
    fi

    # Defense in depth: even if a future code path adds a `break` that
    # isn't gated on PASS, fail before declaring the task complete.
    if [[ "$SPEC_STATUS" != "SPEC_PASS" || "$QUALITY_STATUS" != "QUALITY_PASS" ]]; then
      orchestrator_fail "Task ${TASK_NUM}: exited review loop with spec=${SPEC_STATUS:-?}, quality=${QUALITY_STATUS:-?}. Refusing to mark complete."
    fi

    {
      echo ""
      echo "## Task ${TASK_NUM}: ${task_title}"
      echo "- Status: ${IMPL_STATUS}"
      echo "- Review loops: ${REVIEW_LOOPS}"
      echo "- Commit: ${HEAD_SHA}"
    } >> "$IMPLEMENTATION_LOG"

    log "  Task ${TASK_NUM} complete (impl=${IMPL_STATUS}, review_loops=${REVIEW_LOOPS})"

  done <<< "$TASKS"

  _emit_phase_done "implement"
  PHASE="validate"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: validate
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "validate" ]]; then
  log "=== Phase: validate ==="
  _emit_phase_started "validate"
  LAST_PHASE="validate"

  _VALIDATE_START_MS=$(_now_ms)
  emit_event "validate" "info" "command.started" "running validate suite" command="pnpm-validate-suite"

  ensure_worktree

  log "Running pnpm build && pnpm lint && pnpm typecheck && pnpm test..."
  cd "${WORKTREE_DIR}"
  ensure_branch

  mkdir -p "${ISSUES_DIR}"

  {
    echo "=== pnpm install ==="
    timeout 120 pnpm install --frozen-lockfile 2>&1 | tail -5 || echo "[install completed with warnings]"
    echo ""
    echo "=== pnpm build ==="
    timeout 120 pnpm build 2>&1 || echo "[build failed]"
    echo ""
    echo "=== pnpm lint ==="
    timeout 120 pnpm lint 2>&1 || echo "[lint failed]"
    echo ""
    echo "=== pnpm typecheck ==="
    timeout 120 pnpm typecheck 2>&1 || echo "[typecheck failed]"
    echo ""
    echo "=== pnpm test ==="
    timeout 120 pnpm test 2>&1 || echo "[test failed]"
  } > >(tee "${ISSUES_DIR}/validate.log") 2>&1

  VALIDATE_EXIT=0
  grep -qE "\[build failed\]|\[lint failed\]|\[typecheck failed\]|\[test failed\]" "${ISSUES_DIR}/validate.log" && VALIDATE_EXIT=1

  cp "${ISSUES_DIR}/validate.log" "${ISSUES_DIR}/validation.md"
  _emit_artifact "validate" "${ISSUES_DIR}/validation.md" "validation"

  _validate_now=$(_now_ms)
  _VALIDATE_DUR=$(( _validate_now - _VALIDATE_START_MS ))
  if [[ $VALIDATE_EXIT -eq 0 ]]; then
    emit_event "validate" "info" "command.completed" "validate suite passed" \
      command="pnpm-validate-suite" exitCode=0 durationMs="$_VALIDATE_DUR"
  else
    emit_event "validate" "error" "command.failed" "validate suite failed" \
      command="pnpm-validate-suite" exitCode="$VALIDATE_EXIT" durationMs="$_VALIDATE_DUR"
  fi

  # Record validation status for downstream phases
  if [[ $VALIDATE_EXIT -ne 0 ]]; then
    echo "failed" > "${ISSUES_DIR}/validation.result"
    warn "Validation had failures (check validation.md for details)"
  else
    echo "passed" > "${ISSUES_DIR}/validation.result"
    info "Validation passed"
  fi

  _emit_phase_done "validate"
  PHASE="review"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: review
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "review" ]]; then
  log "=== Phase: review ==="
  _emit_phase_started "review"
  LAST_PHASE="review"

  ensure_worktree

  REVIEW_PROMPT="You are reviewing code changes.

## CONTEXT
You are reviewing branch: ${BRANCH} against base: ${BASE_BRANCH}
Your working directory: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md

## TASK
Run: git diff origin/${BASE_BRANCH}...HEAD
Read the diff carefully.

Write a code review to ./code-review.md.

For each finding you MUST include:
- severity: critical | high | medium | low
- file path and line reference (if applicable)
- evidence: what you observed in the diff
- failure mode: why this is a problem
- required fix: specific action to resolve the issue

Categorize findings:
- critical: security, data loss, production-breaking
- high: correct behavior violation, significant bugs
- medium: suboptimal patterns, missing tests
- low: style, formatting, minor improvements

## CRITICAL RULES
- Do NOT ask questions. If something is ambiguous, note it in the review.
- Do NOT approve or request changes - just document findings.
- Do NOT rely on agent memory.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Stop after writing code-review.md.

Write code-review.md now."

  echo "$REVIEW_PROMPT" | run_agent_raw "review" "$TIMEOUT_REVIEW"

  # Copy review from worktree
  if [[ -f "${WORKTREE_DIR}/code-review.md" ]]; then
    cp "${WORKTREE_DIR}/code-review.md" "${ISSUES_DIR}/review.md"
    info "Review saved to ${ISSUES_DIR}/review.md"
    _emit_artifact "review" "${ISSUES_DIR}/review.md" "review"
  else
    REVIEW_FILE=$(find "${WORKTREE_DIR}" -name "code-review.md" 2>/dev/null | head -1 || true)
    if [[ -n "$REVIEW_FILE" && -f "$REVIEW_FILE" ]]; then
      cp "$REVIEW_FILE" "${ISSUES_DIR}/review.md"
      _emit_artifact "review" "${ISSUES_DIR}/review.md" "review"
    fi
  fi

  _emit_phase_done "review"
  PHASE="fix-review"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: fix-review (with loop)
# ═══════════════════════════════════════════════════════════════════════════
FIX_LOOP_COUNT=0

if [[ "$PHASE" == "fix-review" ]]; then
_emit_phase_started "fix-review"

while [[ "$PHASE" == "fix-review" ]]; do
  FIX_LOOP_COUNT=$((FIX_LOOP_COUNT + 1))
  emit_event "fix-review" "info" "loop.iteration.started" \
    "fix-review loop ${FIX_LOOP_COUNT}/10" \
    iteration="${FIX_LOOP_COUNT}" max=10
  if [[ $FIX_LOOP_COUNT -gt 10 ]]; then
    emit_event "fix-review" "error" "loop.exhausted" \
      "fix-review hit max iterations" \
      iterations="${FIX_LOOP_COUNT}"
    info "Fix loop limit (10) reached. Moving on."
    break
  fi
  log "=== Phase: fix-review (loop $FIX_LOOP_COUNT) ==="
  log "Cancel window: press Ctrl+C within 10s to abort..."
  sleep 10
  LAST_PHASE="fix-review"

  ensure_worktree

  if [[ ! -f "${ISSUES_DIR}/review.md" ]]; then
    info "No review.md found. Skipping fix loop."
    emit_event "fix-review" "info" "loop.iteration.completed" \
      "fix-review loop ${FIX_LOOP_COUNT} completed (no review.md)" \
      iteration="${FIX_LOOP_COUNT}" status="skipped"
    break
  fi

  FIX_PROMPT="You are fixing code review findings.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md
Review findings: ./review.md

## TASK
Read the code review findings.
Fix ALL legitimate review findings across all severities.

Rules:
- Fix only what the review asks for. Do not expand scope.
- Do not rewrite working code for style preference.
- If a finding is invalid, note it in ./review-fix-log.md and skip it.
- If a finding is fixed, document the fix in ./review-fix-log.md.

## ORCHESTRATOR ARTIFACTS — DO NOT DELETE
The following files are orchestrator working artifacts. They are excluded
from git via info/exclude and will NOT appear in the final PR. If a review
finding flags them as out-of-scope, note in review-fix-log.md that they are
excluded from git and move on. Do NOT delete or modify these files:
- issue.md, issue.json, issue-comments.md
- design.md, plan.md, implementation-log.md, orchestrator.log
- *.result, *.log files (spec-review, quality-review, fix-review, etc.)
- code-review.md, review.md, validation.md

## CRITICAL RULES
- Do NOT ask questions.
- Do NOT rely on agent memory.
- Do NOT create a PR.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.
- Load the requesting-code-review skill first.
- After fixing, run: git add -A && git commit -m 'fix: review findings for issue #${ISSUE_NUM} (loop ${FIX_LOOP_COUNT})'
- Stop after fixing and committing.

Start now."

  echo "$FIX_PROMPT" | run_agent_raw "fix-review-${FIX_LOOP_COUNT}" "$TIMEOUT_PR_FIX"
  check_branch_after_agent

  # ── re-validate ────────────────────────────────────────────────────────────
  log "=== Re-validating after fix (loop $FIX_LOOP_COUNT) ==="
  cd "${WORKTREE_DIR}"
  ensure_branch

  {
    echo "=== pnpm build ==="
    timeout 120 pnpm build 2>&1 || echo "[build failed]"
    echo ""
    echo "=== pnpm lint ==="
    timeout 120 pnpm lint 2>&1 || echo "[lint failed]"
    echo ""
    echo "=== pnpm typecheck ==="
    timeout 120 pnpm typecheck 2>&1 || echo "[typecheck failed]"
    echo ""
    echo "=== pnpm test ==="
    timeout 120 pnpm test 2>&1 || echo "[test failed]"
  } > >(tee "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log") 2>&1

  cp "${ISSUES_DIR}/revalidate-${FIX_LOOP_COUNT}.log" "${ISSUES_DIR}/validation-${FIX_LOOP_COUNT}.md"

  # ── re-review ──────────────────────────────────────────────────────────────
  log "=== Re-reviewing after fix (loop $FIX_LOOP_COUNT) ==="

  RE_REVIEW_PROMPT="You are re-reviewing code after fixes were applied.

## CONTEXT
You are reviewing branch: ${BRANCH} against base: ${BASE_BRANCH}
Your working directory: ${WORKTREE_DIR}
Original review: ./review.md
Revalidation log: ./revalidate-${FIX_LOOP_COUNT}.log

## TASK
Load the requesting-code-review skill first.
Read the actual source files that had findings. Verify each finding by reading the file on disk.
Check the revalidation log for build/lint/test results.
For each original finding, note whether it is: **fixed** | **partially fixed** | **not fixed** | **invalid**
If a finding was pre-existing (not introduced by this branch), note it as **CARRIED FORWARD** (pre-existing).
Write an updated review to ./code-review.md.
Verify your assertions by reading actual file contents.

## MANDATORY RESULT FILE
After writing code-review.md, write EXACTLY ONE of these values to ./review-findings-status.txt:
- ALL_RESOLVED  (if every finding is fixed, carried forward, or invalid)
- HAS_UNRESOLVED (if any finding is not fixed or partially fixed)
No other content in the file — just the status word.

## CRITICAL RULES
- Do NOT ask questions.
- Do NOT expand scope.
- Do not flag new issues beyond the original review.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.

Write code-review.md and review-findings-status.txt now."

  echo "$RE_REVIEW_PROMPT" | run_agent_raw "re-review-${FIX_LOOP_COUNT}" "$TIMEOUT_REVIEW"

  # Copy updated review
  if [[ -f "${WORKTREE_DIR}/code-review.md" ]]; then
    cp "${WORKTREE_DIR}/code-review.md" "${ISSUES_DIR}/review.md"
  fi

  # Check if all findings are resolved using resolve_result (primary: .result file, fallback: extractor, tertiary: assume unresolved)
  REVIEW_STATUS=$(resolve_result \
    "${WORKTREE_DIR}/review-findings-status.txt" \
    "${ISSUES_DIR}/review.md" \
    ALL_RESOLVED HAS_UNRESOLVED \
    "HAS_UNRESOLVED")

  if [[ "$REVIEW_STATUS" == "ALL_RESOLVED" ]]; then
    info "All findings resolved. Exiting fix loop."
    emit_event "fix-review" "info" "loop.iteration.completed" \
      "fix-review loop ${FIX_LOOP_COUNT} completed (all resolved)" \
      iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}"
    break
  fi
  info "Review status: ${REVIEW_STATUS}. Continuing fix loop."
  emit_event "fix-review" "info" "loop.iteration.completed" \
    "fix-review loop ${FIX_LOOP_COUNT} completed (has unresolved)" \
    iteration="${FIX_LOOP_COUNT}" status="${REVIEW_STATUS}"
done

_emit_phase_done "fix-review"
PHASE="compound"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: compound
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "compound" ]]; then
  log "=== Phase: compound ==="
  _emit_phase_started "compound"
  LAST_PHASE="compound"

  ensure_worktree

  if [[ ! -f "${WORKTREE_DIR}/implementation-log.md" ]]; then
    info "No implementation-log.md found. Skipping compound."
    PHASE="create-pr"
  else
    COMPOUND_PROMPT="You are writing a compound engineering document.

## CONTEXT
You are working in: ${WORKTREE_DIR}
Issue: issue.md
Plan: plan.md
Design: design.md
Implementation: implementation-log.md

## TASK
Read implementation-log.md and write a solution document to:
  docs/solutions/issue-${ISSUE_NUM}.md

This document should capture:
- The problem and context
- What was decided and why (with trade-offs considered)
- Key implementation decisions and their reasoning
- Gotchas, pitfalls, and lessons learned
- What someone should know if they need to modify this code

Format: markdown with clear sections. Be specific. Include actual code paths, not generic descriptions.

Rules:
- Do NOT ask questions.
- Write the document yourself. Do not delegate.
- Do not create a PR or commit anything.
- Do NOT switch branches (no git checkout, git switch, git stash branch). All work must stay on branch ${BRANCH}.

Start now."

    echo "$COMPOUND_PROMPT" | run_agent_raw "compound" "$TIMEOUT_COMPOUND"

    # Copy the generated doc back to issues dir
    if [[ -f "${WORKTREE_DIR}/docs/solutions/issue-${ISSUE_NUM}.md" ]]; then
      cp "${WORKTREE_DIR}/docs/solutions/issue-${ISSUE_NUM}.md" "${ISSUES_DIR}/compound.md"
      info "Compound doc saved to ${ISSUES_DIR}/compound.md"
      _emit_artifact "compound" "${ISSUES_DIR}/compound.md" "compound"
    fi
  fi

  _emit_phase_done "compound"
  PHASE="create-pr"
fi

# ═══════════════════════════════════════════════════════════════════════════
# PHASE: create-pr
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "create-pr" ]]; then
  log "=== Phase: create-pr ==="
  _emit_phase_started "create-pr"
  LAST_PHASE="create-pr"

  ensure_worktree

  cd "${WORKTREE_DIR}"
  ensure_branch

  # Validate branch has commits
  if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    orchestrator_fail "Worktree has no commits — cannot create PR"
  fi

  log "Branch ${BRANCH} HEAD: $(git rev-parse --short HEAD)"

  # Check branch has diverged from base
  LOCAL_SHA=$(git rev-parse HEAD)
  BASE_SHA=$(git merge-base "origin/${BASE_BRANCH}" HEAD 2>/dev/null || echo "")
  if [[ -n "$BASE_SHA" && "$LOCAL_SHA" == "$BASE_SHA" ]]; then
    warn "Branch ${BRANCH} has no commits beyond ${BASE_BRANCH} — PR will be empty"
  fi

  # Push branch (fail hard on error)
  log "Pushing branch..."
  if ! git push --force-with-lease -u origin "$BRANCH" 2>&1 | tee -a "${ISSUES_DIR}/orchestrator.log"; then
    orchestrator_fail "Failed to push branch ${BRANCH}"
  fi

  # Build pr-summary.md
  ISSUE_META=$(gh issue view "$ISSUE_NUM" --json title,url)
  ISSUE_TITLE=$(echo "$ISSUE_META" | jq -r '.title')
  ISSUE_URL=$(echo "$ISSUE_META" | jq -r '.url')

  PR_SUMMARY=""
  if [[ -f "${ISSUES_DIR}/implementation-log.md" ]]; then
    PR_SUMMARY=$(awk 'NR==2,/^$/ {if (/^$/) exit; print}' "${ISSUES_DIR}/implementation-log.md" 2>/dev/null || true)
  fi

  PR_TASKS=""
  if [[ -f "${ISSUES_DIR}/plan.md" ]]; then
    PR_TASKS=$(awk '/^#{2,3} Task [0-9]+:/ {sub(/^#{2,3} /, "- "); print}' "${ISSUES_DIR}/plan.md" 2>/dev/null || true)
  fi

  PR_CHANGES=""
  if [[ -n "$BASE_SHA" ]]; then
    PR_CHANGES=$(cd "$WORKTREE_DIR" && git diff --stat "${BASE_SHA}"..HEAD 2>/dev/null || true)
  fi

  PR_VALIDATION="Unknown"
  if [[ -f "${ISSUES_DIR}/validation.result" ]]; then
    PR_VALIDATION=$(cat "${ISSUES_DIR}/validation.result" 2>/dev/null | sed 's/.*/&/' | head -1)
  fi
  PR_VALIDATION_STEPS=""
  if [[ -f "${ISSUES_DIR}/validate.log" ]]; then
    phase_name=""
    while IFS= read -r line; do
      if [[ "$line" =~ ^===\ (.+)\ ===$ ]]; then
        phase_name="${BASH_REMATCH[1]}"
      elif [[ -n "$phase_name" ]]; then
        if echo "$line" | grep -qiE 'fail|error'; then
          PR_VALIDATION_STEPS+="- ${phase_name}: failed"$'\n'
          phase_name=""
        elif echo "$line" | grep -qiE 'passed|succeeded|done'; then
          PR_VALIDATION_STEPS+="- ${phase_name}: passed"$'\n'
          phase_name=""
        fi
      fi
    done < "${ISSUES_DIR}/validate.log"
    if [[ -z "$PR_VALIDATION_STEPS" ]]; then
      PR_VALIDATION_STEPS=$(awk '/^=== / {gsub(/^=== | ===$/, ""); phase=$0; next} /fail|error/i {print "- " phase ": failed"; next} /passed|succeeded/i {print "- " phase ": passed"; next}' "${ISSUES_DIR}/validate.log" 2>/dev/null | head -10 || true)
    fi
  fi

  PR_REVIEW=""
  if [[ -f "${ISSUES_DIR}/code-review.md" ]]; then
    crit_high=$(grep -ciE 'severity.*(critical|high)' "${ISSUES_DIR}/code-review.md" 2>/dev/null || echo 0)
    medi_low=$(grep -ciE 'severity.*(medium|low)' "${ISSUES_DIR}/code-review.md" 2>/dev/null || echo 0)
    PR_REVIEW="- Critical/High: ${crit_high}"$'\n'"- Medium/Low: ${medi_low}"
  elif [[ -f "${ISSUES_DIR}/review.md" ]]; then
    crit_high=$(grep -ciE 'severity.*(critical|high)' "${ISSUES_DIR}/review.md" 2>/dev/null || echo 0)
    medi_low=$(grep -ciE 'severity.*(medium|low)' "${ISSUES_DIR}/review.md" 2>/dev/null || echo 0)
    PR_REVIEW="- Critical/High: ${crit_high}"$'\n'"- Medium/Low: ${medi_low}"
  else
    PR_REVIEW="No code review performed"
  fi

  cat > "${ISSUES_DIR}/pr-summary.md" << EOF
# ${ISSUE_TITLE}

Closes #${ISSUE_NUM}

${PR_SUMMARY}

## Tasks
${PR_TASKS}

## Changes
${PR_CHANGES}

## Validation: ${PR_VALIDATION}
${PR_VALIDATION_STEPS}

## Review Findings
${PR_REVIEW}

## Artifacts
Run logs and artifacts: \`ai/issues/${ISSUE_NUM}/\`
EOF

  # Create PR. `gh pr create` does NOT support --json (only `gh pr view/list`
  # do); it writes the PR URL to stdout on success. Capture that directly.
  PR_BODY=$(cat "${ISSUES_DIR}/pr-summary.md")
  PR_URL=$(gh pr create \
    --base "$BASE_BRANCH" \
    --head "$BRANCH" \
    --title "${ISSUE_TITLE}" \
    --body "$PR_BODY" 2>/dev/null | tail -1) || PR_URL=""

  if [[ -z "$PR_URL" ]]; then
    # Create failed — most commonly because a PR already exists for this branch.
    # Look it up by head ref and continue (idempotent for resumes).
    PR_URL=$(gh pr list --head "$BRANCH" --state open --json url --jq '.[0].url // empty' 2>/dev/null || echo "")
    if [[ -z "$PR_URL" ]]; then
      orchestrator_fail "Failed to create PR and no open PR exists for branch ${BRANCH}"
    fi
    log "PR already exists for ${BRANCH}, reusing: ${PR_URL}"
  fi

  # Resolve the PR number via gh pr view, which DOES support --json.
  PR_NUM=$(gh pr view "$PR_URL" --json number --jq '.number' 2>/dev/null || echo "")
  if [[ -z "$PR_NUM" ]]; then
    # Final fallback: parse the trailing /<number> from the URL.
    PR_NUM=$(echo "$PR_URL" | grep -oE '[0-9]+$' || echo "unknown")
  fi

  echo "$PR_URL" > "${ISSUES_DIR}/pr-url.txt"
  echo "$PR_NUM" > "${ISSUES_DIR}/pr-number.txt"
  _emit_artifact "create-pr" "${ISSUES_DIR}/pr-summary.md" "summary"
  if [[ ! -f "${ISSUES_DIR}/pr-summary.md" ]]; then
    warn "pr-summary.md not found after create-pr phase — artifact event silently skipped"
  fi
  _emit_artifact "create-pr" "${ISSUES_DIR}/pr-url.txt" "pr"

  log "PR created: ${PR_URL}"

  # Update issue labels — gate ai:pr-ready on validation passing
  gh issue edit "$ISSUE_NUM" --remove-label "ai:in-progress" 2>/dev/null || true
  VALIDATION_STATUS=$(cat "${ISSUES_DIR}/validation.result" 2>/dev/null || echo "unknown")
  if [[ "$VALIDATION_STATUS" == "passed" ]]; then
    gh issue edit "$ISSUE_NUM" --add-label "ai:pr-ready" 2>/dev/null || true
  else
    gh issue edit "$ISSUE_NUM" --add-label "ai:needs-human-review" 2>/dev/null || true
    warn "Validation did not pass (status: ${VALIDATION_STATUS}). Labeling as ai:needs-human-review instead of ai:pr-ready."
  fi

  # Comment on issue
  gh issue comment "$ISSUE_NUM" --body "PR created: ${PR_URL}" 2>/dev/null || true

  _emit_phase_done "create-pr"
  PHASE="done"
fi

# ═══════════════════════════════════════════════════════════════════════════
# DONE
# ═══════════════════════════════════════════════════════════════════════════
if [[ "$PHASE" == "done" ]]; then
  log "=== Orchestrator complete ==="
  log "PR: $(cat "${ISSUES_DIR}/pr-url.txt")"
  log "Artifacts: ai/issues/${ISSUE_NUM}/"

  ARCHIVE_DIR="${REPO_ROOT}/ai/issues/${ISSUE_NUM}"
  mkdir -p "$ARCHIVE_DIR"
  for f in \
    orchestrator.log \
    issue.json issue.md issue-comments.md \
    design.md plan.md \
    implementation-log.md \
    compound.md \
    validation.md validation.result validate.log revalidate-*.log validation-*.md \
    review.md review-fix-log.md code-review.md review-findings-status.txt \
    pr-summary.md pr-url.txt pr-number.txt \
    poll-pr.log \
    install-worktree.log \
    blocked.json task-manifest.json \
    implement-task-*.log implement-task-*.result \
    spec-review-task-*.log spec-review-task-*.result \
    quality-review-task-*.log quality-review-task-*.result \
    fix-review-task-*.log fix-review-task-*.result \
    fix-review-*.log fix-review-*.result; do
    cp "${WORKTREE_DIR}/$f" "$ARCHIVE_DIR/" 2>/dev/null || true
  done
  log "Artifacts archived to ${ARCHIVE_DIR}/"

  # Start PR review poll loop in background
  log "Starting PR review poll loop (background)..."
  PR_NUM_VALUE=$(cat "${ISSUES_DIR}/pr-number.txt" 2>/dev/null || echo "")
  if [[ -n "$PR_NUM_VALUE" && "$PR_NUM_VALUE" != "unknown" ]]; then
    AI_RUN_EVENTS_FILE="${AI_RUN_EVENTS_FILE:-}" \
    AI_RUN_DISPLAY_ID="${AI_RUN_DISPLAY_ID:-}" \
    nohup "${REPO_ROOT}/scripts/ai-pr-review-poll" "$PR_NUM_VALUE" "$ISSUE_NUM" 3 300 \
      >> "${ISSUES_DIR}/poll-pr.log" 2>&1 &
    POLL_PID=$!
    disown "$POLL_PID" 2>/dev/null || true
    log "PR review poll PID: ${POLL_PID}"
    # Verify the process actually started
    sleep 2
    if kill -0 "$POLL_PID" 2>/dev/null; then
      log "PR review poll confirmed running (PID ${POLL_PID})"
    else
      warn "PR review poll process exited immediately. Check ${ISSUES_DIR}/poll-pr.log"
    fi
  else
    warn "Could not determine PR number, skipping review poll"
  fi

  echo ""
  echo "✅ Issue #${ISSUE_NUM} → PR ready"
  echo "   PR: $(cat "${ISSUES_DIR}/pr-url.txt")"
  echo "   Branch: ${BRANCH}"
  emit_event "" "info" "run.completed" "issue-to-PR run completed" \
    prUrl="${PR_URL:-}"
fi
