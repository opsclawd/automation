#!/usr/bin/env bash
# ai-consolidate-compound — milestone-triggered curation pass over per-run
# compound artifacts. Reads ai/issues/*/compound.md and
# ai/poll-pr-*/compound-*.md, hands them plus the existing docs/solutions/
# corpus to one agent invocation, and lets the agent decide what (if anything)
# to write back into docs/solutions/.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export REPO_ROOT

TIMEOUT_SEC="${TIMEOUT_SEC:-900}"
LOG_FILE="${LOG_FILE:-${REPO_ROOT}/ai/consolidate-$(date -u +%Y%m%dT%H%M%SZ).log}"
mkdir -p "$(dirname "$LOG_FILE")"

# shellcheck source=lib/consolidate_helpers.sh
source "${REPO_ROOT}/scripts/lib/consolidate_helpers.sh"

log()  { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*" | tee -a "$LOG_FILE" >&2; }
warn() { printf '[%s] WARN: %s\n' "$(date '+%H:%M:%S')" "$*" | tee -a "$LOG_FILE" >&2; }

usage() {
  cat >&2 <<EOF
Usage: $0 [--since <git-ref>] [--issues <n,m,...>] [--dry-run] [--yes]
  --since REF    Consolidate compound files newer than REF (mutually exclusive with --issues).
  --issues LIST  Consolidate only the listed issue numbers, poll-pr files excluded (mutually exclusive with --since).
  --dry-run      Run the agent but do not stage or commit anything.
  --yes          Skip the interactive confirmation prompt.

Environment:
  AI_AGENT_MODEL    Override the model (routed via phaseProfiles.compound).
  AI_AGENT_PROVIDER Override the provider.
  TIMEOUT_SEC       Agent timeout in seconds (default: 900).
  CONSOLIDATE_RUN_ID  Custom run UUID (default: auto-generated).
  OWNER_REPO        Custom repo identifier (default: auto-detected via gh, falls back to 'local/local').
EOF
  exit 2
}

SINCE="" ISSUES="" DRY_RUN=false ASSUME_YES=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --since)   [[ $# -ge 2 && -n "$2" && "$2" != -* ]] || usage; SINCE="$2"; shift 2 ;;
    --issues)  [[ $# -ge 2 && -n "$2" && "$2" != -* ]] || usage; ISSUES="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --yes)     ASSUME_YES=true; shift ;;
    -h|--help) usage ;;
    *) usage ;;
  esac
done

cd "$REPO_ROOT"

if [[ -n "$SINCE" && -n "$ISSUES" ]]; then
  warn "--since and --issues are mutually exclusive (they define disjoint input scopes). Pass one or the other."
  usage
fi

INPUT_ARGS=()
if [[ -n "$ISSUES" ]]; then
  INPUT_ARGS=(--issues "$ISSUES")
elif [[ -n "$SINCE" ]]; then
  INPUT_ARGS=(--since "$SINCE")
fi

INPUT_TMP=$(mktemp)
discover_inputs "${INPUT_ARGS[@]}" > "$INPUT_TMP"
ec=$?
if [[ $ec -ne 0 ]]; then
  rm -f "$INPUT_TMP"
  warn "discover_inputs failed (exit ${ec})"
  exit "$ec"
fi
mapfile -t INPUT_FILES < "$INPUT_TMP"
rm -f "$INPUT_TMP"
log "Discovered ${#INPUT_FILES[@]} compound input file(s)."
if [[ ${#INPUT_FILES[@]} -eq 0 ]]; then
  log "No compound inputs to consolidate. Exiting."
  exit 0
fi

# Stage existing curated docs for the agent's context.
mapfile -t EXISTING_DOCS < <(find docs/solutions -name '*.md' -type f 2>/dev/null | sort)
log "Existing curated docs in scope: ${#EXISTING_DOCS[@]}"

PROMPT_FILE=$(mktemp)
{
  echo "You are running a milestone consolidation pass over raw compound-engineering artifacts."
  echo ""
  echo "## YOUR JOB"
  echo "Decide whether anything in the inputs is worth committing to docs/solutions/."
  echo "Most batches should produce ZERO or a SMALL number of new/updated docs. Restating"
  echo "the diff or the PR description is noise. Only commit lessons that would change"
  echo "how a future issue is approached."
  echo ""
  echo "## OUTPUT CONVENTION (existing structure — match it)"
  echo "- Files live under docs/solutions/<category>/<topic-slug>-<YYYY-MM-DD>.md"
  echo "- Categories already in use: domain, orchestrator, runtime-errors, test-failures"
  echo "- Use YAML frontmatter (title, date, category, module, problem_type, ..., tags)"
  echo "- Cluster by TOPIC, not by issue. One file per cluster."
  echo "- Update an existing file in place if a new input reinforces or contradicts it."
  echo "- Filename should be slug-ish and stable: edit existing files rather than"
  echo "  creating a v2 with a slightly different name."
  echo ""
  echo "## ZERO-OUTPUT IS A VALID RESULT"
  echo "If nothing in the inputs warrants a curated doc, write nothing and exit."
  echo "Do NOT pad the batch with low-signal docs to feel productive."
  echo ""
  echo "## EXISTING CURATED DOCS (read these first; update in place when applicable)"
  for d in "${EXISTING_DOCS[@]}"; do
    echo ""
    echo "### ${d}"
    echo '```markdown'
    cat "$d"
    echo '```'
  done
  echo ""
  echo "## RAW INPUTS (this consolidation pass)"
  for f in "${INPUT_FILES[@]}"; do
    echo ""
    echo "### ${f}"
    echo '```markdown'
    cat "$f"
    echo '```'
  done
  echo ""
  echo "## RULES"
  echo "- Write only inside docs/solutions/."
  echo "- Do not delete existing files (you may overwrite/update them)."
  echo "- Do not modify any per-run input file under ai/."
  echo "- Do not run git commands. Do not commit. The wrapping script handles that."
} > "$PROMPT_FILE"

log "Invoking agent via run-agent.ts (timeout ${TIMEOUT_SEC}s, phase compound)..."

timeout "$TIMEOUT_SEC" bash -c '
  local prompt="$1"
  local timeout_min=$(( (TIMEOUT_SEC + 59) / 60 ))
  if [[ $timeout_min -lt 1 ]]; then timeout_min=1; fi

  local phase_id
  if [[ -n "${ISSUES+x}" ]]; then
    phase_id="consolidate-issues-${ISSUES//,/-}"
  elif [[ -n "${SINCE+x}" ]]; then
    phase_id="consolidate-since-${SINCE//\//-}"
  else
    phase_id="consolidate-$(date -u +%Y%m%dT%H%M%SZ)"
  fi

  local run_id
  run_id="${CONSOLIDATE_RUN_ID:-$(uuidgen 2>/dev/null || python3 -c '"'"'import uuid; print(uuid.uuid4())'"'"' 2>/dev/null || echo '"'"'fallback-uuid-'"'"'$(date +%s))}"

  local owner_repo
  owner_repo="${OWNER_REPO:-$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo '"'"'local/local'"'"')}"

  local start_sha
  if [[ -n "${SINCE+x}" ]]; then
    start_sha=$(git -C "$REPO_ROOT" rev-parse "$SINCE" 2>/dev/null) || start_sha=$(printf '"'"'0%.0s'"'"' {1..40})
  else
    start_sha=$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null) || start_sha=$(printf '"'"'0%.0s'"'"' {1..40})
  fi

  NODE_OPTIONS='"'"'--conditions=development'"'"' pnpm --filter @ai-sdlc/cli exec tsx \
    "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase compound \
    --phase-id "$phase_id" \
    --cwd "$REPO_ROOT" \
    --run-id "$run_id" \
    --repo-id "$owner_repo" \
    --repo-root "$REPO_ROOT" \
    --prompt-file "$prompt" \
    --timeout-minutes "$timeout_min" \
    --start-sha "$start_sha"
' _ "$PROMPT_FILE" 2>&1 | tee -a "$LOG_FILE"
AGENT_EC=${PIPESTATUS[0]}
rm -f "$PROMPT_FILE"

if [[ $AGENT_EC -ne 0 ]]; then
  warn "Agent exited non-zero (${AGENT_EC}); inspect $LOG_FILE before deciding to commit."
fi

if $DRY_RUN; then
  if [[ $AGENT_EC -ne 0 ]]; then
    warn "--dry-run: agent exited non-zero (${AGENT_EC}); dry-run considered failed."
  fi
  log "--dry-run: leaving working tree as-is. Inspect with: git status -- docs/solutions/"
  exit "$AGENT_EC"
fi

if $ASSUME_YES; then
  if [[ $AGENT_EC -ne 0 ]]; then
    warn "--yes mode: agent exited non-zero (${AGENT_EC}), skipping commit to avoid committing partial output."
    exit 1
  fi
  if git diff --quiet -- docs/solutions/ && [[ -z "$(git status --porcelain -- docs/solutions/)" ]]; then
    log "Nothing to commit under docs/solutions/."
    exit 0
  fi
  commit_consolidation
  exit 0
fi

if diff_and_confirm; then
  commit_consolidation
else
  warn "Aborted by user. docs/solutions/ left modified for inspection."
  exit 1
fi
