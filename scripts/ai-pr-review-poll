#!/usr/bin/env bash
# ai-pr-review-poll.sh — Polls a PR for review comments, fixes them, and replies.
# Designed to run as a background process spawned by ai-run-issue-v2.sh.
# Uses explicit error handling instead of set -e to avoid dying on transient API failures.
set -uo pipefail

# ── Config ─────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PR_NUMBER="${1:-}"
ISSUE_NUM="${2:-}"
MAX_POLLS="${3:-3}"
POLL_INTERVAL="${4:-300}"
# OWNER_REPO defaults to the current repo (where this checkout was cloned from).
# Override with the OWNER_REPO env var when running against a different repo.
OWNER_REPO="${OWNER_REPO:-$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")}"
if [[ -z "$OWNER_REPO" ]]; then
  echo "FATAL: could not determine owner/repo. Set OWNER_REPO=<owner>/<repo> and retry." >&2
  exit 1
fi

# Generate a unique run ID for agent invocation plumbing
RUN_ID="${AI_RUN_UUID:-${RUN_ID:-$(uuidgen 2>/dev/null || python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || date +%s%N)}}"
REPO_ID="${REPO_ID:-$OWNER_REPO}"

if [[ -z "$PR_NUMBER" ]]; then
  echo "Usage: $0 <PR_NUMBER> [issue_num] [max_polls=3] [interval_sec=300]" >&2
  exit 1
fi

ISSUES_DIR="${REPO_ROOT}/ai/poll-pr-${PR_NUMBER}"
mkdir -p "$ISSUES_DIR"

# Own our scratch path. The orchestrator (ai-run-issue-v2) exports a per-run
# TMPDIR pointing at .ai-tmp/<run-id>/ and deletes it on terminal status. The
# poll inherits that TMPDIR via nohup and outlives the orchestrator, so every
# mktemp here would fail once the per-run dir is swept. Point TMPDIR at a
# directory we control for the lifetime of this poll.
export TMPDIR="${ISSUES_DIR}/tmp"
mkdir -p "$TMPDIR"
# Two-tier processed-ID tracking. The agent's reply is the irreversible
# side-effect we must never duplicate; the build outcome can flip back and
# forth across polls. Splitting the tracking lets us:
#   - never re-prompt the agent for an ID it has already replied to;
#   - keep re-running build verification across polls until it succeeds;
#   - promote IDs from REPLIED to PROCESSED only when verification is clean.
#
# PROCESSED — terminal: replies posted AND verification (commits + build) passed.
# REPLIED   — interim:  replies posted, verification pending.
PROCESSED_IDS_FILE="${ISSUES_DIR}/processed-comment-ids.txt"
REPLIED_IDS_FILE="${ISSUES_DIR}/replied-comment-ids.txt"
COMMENT_STATE_FILE="${ISSUES_DIR}/comment-state.json"
touch "$PROCESSED_IDS_FILE" "$REPLIED_IDS_FILE"

log() { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*" | tee -a "${ISSUES_DIR}/poll.log" >&2; }
# Pipe BEFORE >&2 so tee actually sees the message; the trailing >&2 then
# routes tee's stdout to stderr for terminal visibility.
warn() { printf '[%s] WARN: %s\n' "$(date '+%H:%M:%S')" "$*" | tee -a "${ISSUES_DIR}/poll.log" >&2; }
# Structured event helper — emits JSON lines to $AI_RUN_EVENTS_FILE.
# When AI_RUN_EVENTS_FILE is unset (standalone Bash run), emit_event is a no-op.
# shellcheck source=lib/emit_event.sh
source "${REPO_ROOT}/scripts/lib/emit_event.sh"
# shellcheck source=lib/poll_compound.sh
source "${REPO_ROOT}/scripts/lib/poll_compound.sh"
# shellcheck source=lib/comment-state.sh
source "${REPO_ROOT}/scripts/lib/comment-state.sh"

if ! command -v jq >/dev/null 2>&1; then
  echo "FATAL: jq is required but not found on PATH. Install jq and retry." >&2
  exit 1
fi

_POLL_HAS_NANOSECONDS=false
if date +%N >/dev/null 2>&1 && [[ "$(date +%N)" != "N" ]]; then
  _POLL_HAS_NANOSECONDS=true
fi
_now_ms() {
  if [[ "$_POLL_HAS_NANOSECONDS" == "true" ]]; then
    echo $(( $(date +%s%N) / 1000000 ))
  else
    echo $(( $(date +%s) * 1000 ))
  fi
}

log "=== PR review poll starting (PR #${PR_NUMBER}, max_polls=${MAX_POLLS}, interval=${POLL_INTERVAL}s) ==="
log "PID: $$"
log "ISSUES_DIR: ${ISSUES_DIR}"

# ── PR info (with retry — PR may not be visible immediately after creation) ──
log "Fetching PR info for #${PR_NUMBER}..."
for attempt in 1 2 3; do
  PR_BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName' 2>/dev/null) && break
  warn "Attempt $attempt: failed to fetch PR info. Retrying in 5s..."
  sleep 5
done

if [[ -z "$PR_BRANCH" ]]; then
  warn "Could not fetch PR info after 3 attempts. Exiting."
  exit 1
fi

PR_URL=$(gh pr view "$PR_NUMBER" --json url --jq '.url' 2>/dev/null || echo "unknown")
log "PR #${PR_NUMBER}: ${PR_URL} (branch: ${PR_BRANCH})"

# ── Checkout branch in isolated worktree ────────────────────────────────────
# Safety contract: when this block exits, $(pwd) MUST be a worktree whose HEAD
# is $PR_BRANCH. If we can't guarantee that, abort — running a merge against
# the wrong branch (e.g. main, when the orchestrator worktree silently kept
# its initial HEAD) corrupts the shared index across all worktrees.
ORCHESTRATOR_WORKTREE="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}"
POLL_WORKTREE="${REPO_ROOT}/.ai-worktrees/poll-pr-${PR_NUMBER}"
cd "$REPO_ROOT"
git fetch origin "$PR_BRANCH" || warn "git fetch origin ${PR_BRANCH} failed (continuing with local refs)"

# Sync a worktree to $PR_BRANCH. Fails loudly if anything goes wrong.
# Refuses to proceed unless HEAD ends up exactly on $PR_BRANCH.
sync_worktree_to_pr_branch() {
  local wt="$1"
  cd "$wt" || { warn "cd ${wt} failed"; return 1; }
  if ! git checkout "$PR_BRANCH"; then
    warn "git checkout ${PR_BRANCH} failed in ${wt} (branch may be checked out in another worktree)"
    return 1
  fi
  local head_branch
  head_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
  if [[ "$head_branch" != "$PR_BRANCH" ]]; then
    warn "worktree HEAD is '${head_branch}', expected '${PR_BRANCH}'. Refusing to merge."
    return 1
  fi
  if ! git pull --ff-only origin "$PR_BRANCH"; then
    warn "fast-forward pull failed; attempting merge of origin/${PR_BRANCH} into ${PR_BRANCH}"
    if ! git merge --no-edit "origin/$PR_BRANCH"; then
      warn "merge of origin/${PR_BRANCH} failed in ${wt}; aborting merge"
      git merge --abort 2>/dev/null || true
      return 1
    fi
  fi
  return 0
}

if [[ -n "$ISSUE_NUM" && -d "$ORCHESTRATOR_WORKTREE" ]]; then
  POLL_WORKTREE="$ORCHESTRATOR_WORKTREE"
  log "Reusing orchestrator worktree at ${POLL_WORKTREE}"
  sync_worktree_to_pr_branch "$POLL_WORKTREE" || {
    warn "Could not put orchestrator worktree on ${PR_BRANCH}; aborting to avoid corrupting shared index"
    exit 2
  }
elif [[ -d "$POLL_WORKTREE" ]]; then
  log "Reusing existing poll worktree at ${POLL_WORKTREE}"
  sync_worktree_to_pr_branch "$POLL_WORKTREE" || {
    warn "Could not put poll worktree on ${PR_BRANCH}; aborting"
    exit 2
  }
else
  log "Creating worktree at ${POLL_WORKTREE}"
  if git rev-parse --verify "$PR_BRANCH" 2>/dev/null; then
    git worktree add "$POLL_WORKTREE" "$PR_BRANCH" || { warn "git worktree add failed"; exit 2; }
  else
    git worktree add "$POLL_WORKTREE" -b "$PR_BRANCH" "origin/$PR_BRANCH" || { warn "git worktree add failed"; exit 2; }
  fi
  cd "$POLL_WORKTREE"
fi

# Final safety assertion: we must be in a worktree on $PR_BRANCH before
# anything downstream (agent invocations, commits, pushes) runs.
_actual_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$_actual_branch" != "$PR_BRANCH" ]]; then
  warn "Bootstrap finished but HEAD is '${_actual_branch}', not '${PR_BRANCH}'. Refusing to continue."
  exit 2
fi
log "Working directory: $(pwd) (HEAD: ${_actual_branch})"

# ── Result resolution (three-tier: .result file → extractor agent → fallback) ──

# Read first non-whitespace token from a result file. Uses `head -1 file`
# (not `cat | head`) so head reads the file directly — no upstream
# producer that could be SIGPIPE'd when head closes after one line. With
# `pipefail`, the cat-piped variant silently returned empty when a
# result file had >1 line; this avoids that footgun.
# shellcheck source=lib/result-resolver.sh
source "${REPO_ROOT}/scripts/lib/result-resolver.sh"

extract_result() {
  local phase="$1"
  local result_file="$2"
  local source_file="$3"; shift 3
  local allowed_values=("$@")
  local allowed_regex
  allowed_regex=$(printf '|%s' "${allowed_values[@]}")
  allowed_regex="${allowed_regex:1}"

  log "  Extractor: reading ${source_file} for ${phase} result..."

  local extractor_prompt
  extractor_prompt="You are a result extractor. Read the file below and determine the outcome.

## Source File
$(cat "$source_file" 2>/dev/null || echo "File not found: ${source_file}")

## Allowed Values
${allowed_regex}

## Your Task
Read the source file and determine which allowed value best describes the outcome.
Write EXACTLY ONE of the allowed values to the result file — nothing else, no explanation.

Result file: ${result_file}

Write the result now."

  local extractor_ec
  echo "$extractor_prompt" | run_agent "extract-${phase}" 60
  extractor_ec=$?

  if [[ "$extractor_ec" != "0" ]]; then
    warn "  Extractor: agent exited with code ${extractor_ec}"
  fi

  if validate_result_file "$result_file" "${allowed_values[@]}"; then
    log "  Extractor: successfully resolved ${phase} result"
    return 0
  else
    warn "  Extractor: failed to resolve ${phase} result"
    return 1
  fi
}

# ── Verification functions ──────────────────────────────────────────────────

# ensure_local_pushed — used by the REPLIED re-verification path (no new
# comments, replies posted, build was last seen red). Unlike
# verify_commits_pushed it does not need a pre-agent SHA; it just asks
# "is local HEAD ahead of origin/${PR_BRANCH}?" If yes (a transient `git
# push` failure left commits stranded locally), retry the push and
# re-check. Returns 0 only when origin contains every local commit.
ensure_local_pushed() {
  git fetch origin "$PR_BRANCH" 2>/dev/null || {
    warn "  ensure_local_pushed: failed to fetch origin/${PR_BRANCH}"
    return 1
  }

  local ahead
  ahead=$(git rev-list --count "origin/${PR_BRANCH}..HEAD" 2>/dev/null || echo "0")
  if [[ "$ahead" -eq 0 ]]; then
    log "  ensure_local_pushed: HEAD already on origin/${PR_BRANCH}"
    return 0
  fi

  log "  ensure_local_pushed: ${ahead} local commit(s) ahead of origin/${PR_BRANCH}; pushing..."
  if ! git push origin "$PR_BRANCH" 2>&1 | tee -a "${ISSUES_DIR}/poll.log"; then
    warn "  ensure_local_pushed: push failed"
    return 1
  fi

  ahead=$(git rev-list --count "origin/${PR_BRANCH}..HEAD" 2>/dev/null || echo "0")
  if [[ "$ahead" -eq 0 ]]; then
    log "  ensure_local_pushed: push succeeded"
    DID_PUSH_COMMITS=$((DID_PUSH_COMMITS + 1))
    return 0
  fi
  warn "  ensure_local_pushed: still ${ahead} commit(s) ahead after push"
  return 1
}

verify_commits_pushed() {
  local pre_sha="$1"
  local branch="$2"
  local new_commits

  new_commits=$(git log "${pre_sha}..origin/${branch}" --oneline 2>/dev/null) || true

  if [[ -n "$new_commits" ]]; then
    log "  verify_commits: new commits detected on origin/${branch}:"
    echo "$new_commits" | while IFS= read -r line; do log "    $line"; done
    DID_PUSH_COMMITS=$((DID_PUSH_COMMITS + 1))
    return 0
  fi

  local local_commits
  local_commits=$(git log "${pre_sha}..HEAD" --oneline 2>/dev/null) || true
  if [[ -n "$local_commits" ]]; then
    warn "  verify_commits: commits exist locally but not on remote. Attempting push..."
    git push origin "$branch" 2>&1 | tee -a "${ISSUES_DIR}/poll.log" || {
      warn "  verify_commits: push failed"
      return 1
    }

    new_commits=$(git log "${pre_sha}..origin/${branch}" --oneline 2>/dev/null) || true
    if [[ -n "$new_commits" ]]; then
      log "  verify_commits: push succeeded, commits now on remote"
      DID_PUSH_COMMITS=$((DID_PUSH_COMMITS + 1))
      return 0
    fi
  fi

  warn "  verify_commits: no new commits found (neither local nor remote)"
  return 1
}

verify_replies_posted() {
  local comment_ids_file="${ISSUES_DIR}/comments.json"
  if [[ ! -f "$comment_ids_file" ]]; then
    warn "  verify_replies: no comments.json found, cannot verify replies"
    return 1
  fi

  local expected_ids
  expected_ids=$(jq -r '.[].id' "$comment_ids_file" 2>/dev/null) || {
    warn "  verify_replies: failed to parse comments.json"
    return 1
  }

  if [[ -z "$expected_ids" ]]; then
    log "  verify_replies: no comment IDs to verify"
    return 0
  fi

  # --paginate is required: GitHub returns 30 items per page by default and
  # a long-lived PR will quickly exceed that. Each page emits one JSON value
  # per --jq invocation; we slurp them back into a single array with `jq -s '. | flatten'`.
  local all_replies
  all_replies=$(gh api --paginate "repos/${OWNER_REPO}/pulls/${PR_NUMBER}/comments" \
    --jq '[.[] | select(.in_reply_to_id != null) | .in_reply_to_id]' 2>/dev/null \
    | jq -s 'flatten') || {
    warn "  verify_replies: failed to fetch PR comments for verification"
    return 1
  }

  # Per-ID status file lets the caller mark partial successes — without it,
  # a 2/3 outcome leaves zero IDs tracked and the agent re-replies to the 2
  # already-answered comments on the next poll.
  local status_file="${ISSUES_DIR}/replies-status-p${POLL_COUNT}.txt"
  : > "$status_file"

  local missing=0
  local total=0
  for cid in $expected_ids; do
    total=$((total + 1))
    local has_reply
    has_reply=$(echo "$all_replies" | jq --arg cid "$cid" '[.[] | select((. | tostring) == $cid or (. | tonumber) == ($cid | tonumber))] | length' 2>/dev/null || echo "0")
    if [[ "$has_reply" -gt 0 ]]; then
      echo "$cid" >> "$status_file"
    else
      warn "  verify_replies: comment ${cid} has no reply"
      missing=$((missing + 1))
    fi
  done

  if [[ $missing -eq 0 ]]; then
    log "  verify_replies: all ${total} threads have replies"
    return 0
  else
    warn "  verify_replies: ${missing}/${total} threads missing replies"
    return 1
  fi
}

# Resolve PR review threads via GraphQL. Takes whitespace-separated databaseIds
# (numeric REST comment IDs) and resolves each containing thread.
resolve_threads() {
  local ids="$*"
  [[ -z "$ids" ]] && return 0
  local owner="${OWNER_REPO%/*}"
  local repo="${OWNER_REPO#*/}"

  local threads_json
  threads_json=$(gh api graphql -f query='
    query($owner:String!,$repo:String!,$pr:Int!) {
      repository(owner:$owner, name:$repo) {
        pullRequest(number:$pr) {
          reviewThreads(first:100) {
            nodes { id isResolved comments(first:50){ nodes { databaseId } } }
          }
        }
      }
    }' -F owner="$owner" -F repo="$repo" -F pr="$PR_NUMBER" 2>/dev/null) || {
    warn "  resolve_threads: failed to fetch review threads"
    return 1
  }

  local resolved=0 skipped=0 failed=0
  for cid in $ids; do
    local thread_id
    thread_id=$(echo "$threads_json" | jq -r --argjson cid "$cid" '
      .data.repository.pullRequest.reviewThreads.nodes[]
      | select(.isResolved == false)
      | select(.comments.nodes | any(.databaseId == $cid))
      | .id' 2>/dev/null | head -1)
    if [[ -z "$thread_id" || "$thread_id" == "null" ]]; then
      skipped=$((skipped + 1))
      continue
    fi
    if gh api graphql -f query='mutation($id:ID!){resolveReviewThread(input:{threadId:$id}){thread{id isResolved}}}' \
        -F id="$thread_id" >/dev/null 2>&1; then
      resolved=$((resolved + 1))
    else
      failed=$((failed + 1))
      warn "  resolve_threads: failed to resolve thread for comment ${cid}"
    fi
  done
  log "  resolve_threads: resolved=${resolved} already-resolved=${skipped} failed=${failed}"
}

verify_build_passes() {
  cd "$POLL_WORKTREE" || { warn "  verify_build: cannot cd to ${POLL_WORKTREE}"; return 1; }
  pnpm install --frozen-lockfile 2>/dev/null || pnpm install 2>/dev/null || true
  log "  verify_build: running lint + typecheck + build + test..."
  local build_log="${ISSUES_DIR}/build-verify-p${POLL_COUNT}.log"

  # Use pnpm to stay consistent with ai-run-issue-v2's validate phase.
  if ! pnpm lint > "$build_log" 2>&1; then
    warn "  verify_build: lint failed (see ${build_log})"
    return 1
  fi

  if ! pnpm typecheck >> "$build_log" 2>&1; then
    warn "  verify_build: typecheck failed (see ${build_log})"
    return 1
  fi

  if ! pnpm build >> "$build_log" 2>&1; then
    warn "  verify_build: build failed (see ${build_log})"
    return 1
  fi

  if ! pnpm test >> "$build_log" 2>&1; then
    warn "  verify_build: tests failed (see ${build_log})"
    return 1
  fi

  log "  verify_build: lint + typecheck + build + test all passed"
  return 0
}

# ── Agent runner ───────────────────────────────────────────────────────────
run_agent() {
  local phase="$1"
  local timeout_sec="$2"
  local output_log="${ISSUES_DIR}/${phase}.log"
  local prompt_file
  prompt_file=$(mktemp)
  cat > "$prompt_file"
  local timeout_min=$(( (timeout_sec + 59) / 60 ))
  if [[ $timeout_min -lt 1 ]]; then timeout_min=1; fi

  local routing_phase
  if [[ "$phase" == extract-* ]]; then
    routing_phase="extract"
  else
    routing_phase="$phase"
  fi

  log "Running agent for '${phase}' (timeout=${timeout_sec}s)..."
  local _agent_ec=0
  local _pnpm_ec_file
  _pnpm_ec_file=$(mktemp)
  # Capture main checkout state before the agent runs: HEAD SHA + whether
  # the working tree was already dirty. The guard uses both to distinguish
  # an agent leak (HEAD moved, or clean→dirty) from pre-existing dev work
  # (already dirty before the agent ran — must not be reset).
  local _main_state_before
  _main_state_before=$(_capture_main_state)
  NODE_OPTIONS='--conditions=development' pnpm -C "$REPO_ROOT" --filter @ai-sdlc/cli exec tsx "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase "$routing_phase" \
    --phase-id "$routing_phase" \
    --cwd "${POLL_WORKTREE:-$REPO_ROOT}" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --prompt-file "$prompt_file" \
    --timeout-minutes "$timeout_min" \
    --start-sha "$(git -C "${POLL_WORKTREE:-$REPO_ROOT}" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "$output_log"
  echo ${PIPESTATUS[0]} > "$_pnpm_ec_file"
  _agent_ec=$(cat "$_pnpm_ec_file")
  _guard_main_checkout "post-pr-review" "$_main_state_before"
  rm -f "$_pnpm_ec_file"
  rm -f "$prompt_file"
  if [[ "$_agent_ec" == "2" ]]; then
    log "FAIL: '${phase}' timed out or had config error"
    return 1
  fi
  if [[ "$_agent_ec" != "0" ]]; then
    log "WARN: '${phase}' exited with code $_agent_ec"
  fi
  return $_agent_ec
}

# shellcheck source=lib/guard-main-checkout.sh
source "${REPO_ROOT}/scripts/lib/guard-main-checkout.sh"

# ── Process reviews ────────────────────────────────────────────────────────
process_reviews() {
  local pr_state
  pr_state=$(gh pr view "$PR_NUMBER" --json state --jq '{state}' 2>/dev/null) || {
    warn "Failed to fetch PR state. Skipping this poll."
    return 1
  }
  if echo "$pr_state" | jq -e '.state == "MERGED"' > /dev/null 2>&1; then
emit_event "post-pr-review" "info" "post-pr-review.run.completed" \
      "PR #${PR_NUMBER} is already merged" \
      totalProcessed="0" terminalReason="already_merged"
    log "PR #${PR_NUMBER} is already merged. Exiting."
    exit 0
  fi

  log "Fetching PR review comments..."

  # Pagination: each page's --jq output is one JSON array; slurp+flatten yields
  # a single combined array. Without --paginate, anything past page 1 (>30
  # items) is silently dropped.
  local reviews all_comments comments
  reviews=$(gh api --paginate "repos/${OWNER_REPO}/pulls/${PR_NUMBER}/reviews" \
    --jq '[.[] | select(.state == "CHANGES_REQUESTED" or .state == "COMMENT")]' 2>/dev/null \
    | jq -s 'flatten') || {
    warn "Failed to fetch reviews. Skipping this poll."
    return 1
  }
  # Filter to TOP-LEVEL review comments only (in_reply_to_id == null).
  # Without this, the agent's own past replies come back as fresh "comments"
  # and it dutifully replies to their parent thread — which is the source of
  # the runaway duplicate-reply spiral on PRs with prior poll history.
  all_comments=$(gh api --paginate "repos/${OWNER_REPO}/pulls/${PR_NUMBER}/comments" \
    --jq '[.[] | select(.in_reply_to_id == null) | {id, path, body, line, pull_request_review_id, user: .user.login}]' 2>/dev/null \
    | jq -s 'flatten') || {
    warn "Failed to fetch comments. Skipping this poll."
    return 1
  }

  # Seed/migrate comment-state.json BEFORE filtering so that legacy
  # processed/replied IDs from text files are visible to the filter.
  # Without this, an upgrade run where text files have IDs but comment-state.json
  # does not would feed old comments back to the agent for duplicate replies.
  local pre_sha
  pre_sha=$(git rev-parse HEAD 2>/dev/null || echo "")
  log "  Pre-agent SHA: ${pre_sha:-unknown}"
  init_comment_state "" "$pre_sha"

  # Filter out already-handled IDs using comment-state.json.
  # Blocked, replied, and processed IDs are excluded from prompts.
  local known_ids
  if [[ -f "$COMMENT_STATE_FILE" ]]; then
    known_ids=$(jq -r 'to_entries[] | select(.value.state == "processed" or .value.state == "replied" or .value.state == "blocked") | .key' "$COMMENT_STATE_FILE" | tr '\n' ',' | sed 's/,$//')
  else
    known_ids=""
  fi
  if [[ -n "$known_ids" ]]; then
    comments=$(echo "$all_comments" | jq --arg ids "$known_ids" '
      [ .[] | .id as $cid
        | select( ($ids | split(",") | map(tonumber? | select(. != null)) | index($cid)) | not )
      ]
    ' 2>/dev/null || echo "$all_comments")
  else
    comments="$all_comments"
  fi

  # Seed new comment IDs into comment-state.json. The per-comment pre_sha
  # captured here is the HEAD when the comment was FIRST seen, not HEAD on
  # later polls — so re-check verification still confirms a commit is newer
  # than the original pre-agent SHA, not newer than a SHA that has since
  # advanced with successful pushes.
  local new_comment_ids
  new_comment_ids=$(echo "$comments" | jq -r '.[].id' 2>/dev/null | tr '\n' ' ')
  init_comment_state "$new_comment_ids" "$pre_sha"

  local total_comment_count
  total_comment_count=$(echo "$all_comments" | jq 'length' 2>/dev/null || echo 0)
  local comment_count
  comment_count=$(echo "$comments" | jq 'length')
  emit_event "post-pr-review" "info" "post-pr-review.poll.comments.fetched" \
    "fetched ${total_comment_count} comments, ${comment_count} unprocessed" \
    total="$total_comment_count" unprocessed="$comment_count"

  if [[ $comment_count -eq 0 ]]; then
    # No new comments. Re-check replied IDs using per-comment verification.
    local replied_count_json=0
    if [[ -f "$COMMENT_STATE_FILE" ]]; then
      replied_count_json=$(jq '[to_entries[] | select(.value.state == "replied")] | length' "$COMMENT_STATE_FILE" 2>/dev/null || echo 0)
    fi
    if [[ "$replied_count_json" -gt 0 ]]; then
      log "No new comments, but ${replied_count_json} replied comment(s) awaiting verification. Re-checking."
      local reverify_ok=true
      ensure_local_pushed || reverify_ok=false
      verify_build_passes || reverify_ok=false
      if $reverify_ok; then
        # Re-verify per-comment: only promote comments that pass the guard
        local replied_ids
        replied_ids=$(jq -r 'to_entries[] | select(.value.state == "replied") | .key' "$COMMENT_STATE_FILE" 2>/dev/null)
        # Fetch all PR comments once to avoid N+1 API calls.
        # Use jq -s to slurp paginated JSON arrays into a single merged array.
        local all_replies_json
        all_replies_json=$(gh api --paginate "repos/${OWNER_REPO}/pulls/${PR_NUMBER}/comments" 2>/dev/null \
          | jq -s '[flatten | .[] | select(.in_reply_to_id != null) | .in_reply_to_id]' 2>/dev/null || echo '[]')
        local promoted=0
        local promoted_reverify_ids=""
        local cid
        for cid in $replied_ids; do
          [[ -z "$cid" ]] && continue
          # Check reply existence from the pre-fetched list
          local has_reply
          has_reply=$(echo "$all_replies_json" | jq --arg cid "$cid" '[.[] | select(. == ($cid | tonumber))] | length' 2>/dev/null || echo "0")
          if [[ "$has_reply" -gt 0 ]]; then
            jq --arg cid "$cid" '.[$cid].reply_verified = true' \
              "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
              mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
          fi
          # For fixed outcomes, re-verify commit SHA using the per-comment
          # pre_sha captured when the comment was first seen. Using a
          # per-comment pre_sha (not local $pre_sha, which is undefined
          # in this re-check branch) keeps the "newer than pre_sha" check
          # correct across polls even as HEAD advances.
          local outcome
          outcome=$(jq -r --arg cid "$cid" '.[$cid].outcome // "null"' "$COMMENT_STATE_FILE")
          if [[ "$outcome" == "fixed" ]]; then
            local commit_sha cid_pre_sha
            commit_sha=$(jq -r --arg cid "$cid" '.[$cid].commit_sha // "null"' "$COMMENT_STATE_FILE")
            cid_pre_sha=$(jq -r --arg cid "$cid" '.[$cid].pre_sha // ""' "$COMMENT_STATE_FILE")
            if [[ "$commit_sha" != "null" && -n "$commit_sha" ]]; then
              if verify_comment_commit "$cid" "$commit_sha" "$cid_pre_sha"; then
                jq --arg cid "$cid" '.[$cid].commit_verified = true' \
                  "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
                  mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
              else
                warn "  Comment ${cid}: commit verification failed on re-check — demoting to pending for re-prompt"
                # Demote to pending WITHOUT incrementing attempts — update_comment_outcomes
                # already counted this agent run for this comment.
                jq --arg cid "$cid" \
                  '.[$cid].commit_verified = false | .[$cid].build_verified = false | .[$cid].reply_verified = false | .[$cid].outcome = null | .[$cid].commit_sha = null | .[$cid].state = "pending"' \
                  "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
                  mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
              fi
            fi
          fi
          # For fixed outcomes, set build_verified since reverify_ok confirms
          # the build passed (verify_build_passes ran and succeeded).
          # Re-read outcome from JSON because the demotion block above may have
          # cleared it to null; using the stale local variable would incorrectly
          # mark a just-demoted comment as build_verified.
          outcome=$(jq -r --arg cid "$cid" '.[$cid].outcome // "null"' "$COMMENT_STATE_FILE")
          if [[ "$outcome" == "fixed" ]]; then
            jq --arg cid "$cid" '.[$cid].build_verified = true' \
              "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
              mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
          fi
          if can_transition_to_processed "$cid"; then
            set_comment_state "$cid" "processed"
            promoted=$((promoted + 1))
            promoted_reverify_ids="${promoted_reverify_ids:-} ${cid}"
          fi
        done
        if [[ $promoted -gt 0 ]]; then
          log "Promoted ${promoted} comment(s) from replied to processed."
          if [[ -n "${promoted_reverify_ids:-}" ]]; then
            resolve_threads $promoted_reverify_ids
          fi
          derive_compat_files
          LAST_REVIEW_RESULT="NO_FIXES_NEEDED"
          return 0
        else
          warn "No comments passed per-comment verification on re-check."
        fi
      else
        warn "Verification still failing; replied comments remain for next poll."
        return 2
      fi
    fi
    log "No new review comments found."
    return 1
  fi

  log "Found $comment_count new comment(s) (skipping already-processed). Processing..."

  # NOTE: We intentionally do NOT append IDs to PROCESSED_IDS_FILE here.
  # If we did, an agent crash or verification failure would silently drop
  # these comments forever. IDs are only marked processed after the agent
  # AND verification succeed (see end of this function).

  echo "$reviews" > "${ISSUES_DIR}/reviews.json"
  echo "$comments" > "${ISSUES_DIR}/comments.json"
  gh pr diff "$PR_NUMBER" > "${ISSUES_DIR}/pr-diff.diff" 2>/dev/null || warn "Failed to fetch PR diff"

  # Stage everything the agent needs INSIDE its sandbox (POLL_WORKTREE).
  # opencode auto-rejects external_directory reads, so the prompt must point
  # at paths under the worktree, not REPO_ROOT.
  local CTX="${POLL_WORKTREE}/.review-context"
  mkdir -p "$CTX"
  for f in issue.md design.md plan.md; do
    [[ -f "${REPO_ROOT}/ai/issues/${ISSUE_NUM}/$f" ]] && cp "${REPO_ROOT}/ai/issues/${ISSUE_NUM}/$f" "$CTX/" 2>/dev/null || true
  done
  cp "${ISSUES_DIR}/comments.json" "${ISSUES_DIR}/pr-diff.diff" "$CTX/" 2>/dev/null || true
  local COMMON_DIR
  COMMON_DIR=$(cd "$POLL_WORKTREE" && git rev-parse --git-common-dir)
  if ! grep -qxF '.review-context/' "${COMMON_DIR}/info/exclude" 2>/dev/null; then
    echo '.review-context/' >> "${COMMON_DIR}/info/exclude"
  fi
  local RESULT_IN_WT="${CTX}/process-review-p${POLL_COUNT}.result"
  rm -f "$RESULT_IN_WT"

  local comment_text
  comment_text=$(echo "$comments" | jq -r '.[] | "- \(.path):\(.line) — \(.body)"')

  # Build prompt to temp file so we can capture run_agent exit code
  local prompt_file
  prompt_file=$(mktemp)

  {
    echo 'Load the receiving-code-review skill first.'
    echo ''
    echo '## CONTEXT'
    echo "PR Number: #${PR_NUMBER}"
    echo "Branch: ${PR_BRANCH}"
    echo "Repository: ${OWNER_REPO}"
    echo "Your working directory: ${POLL_WORKTREE}"
    echo "Review context (relative to working directory): .review-context/ (issue.md, design.md, plan.md, comments.json, pr-diff.diff)"
    echo ''
    echo '## PR DIFF'
    echo '```'
    cat "${ISSUES_DIR}/pr-diff.diff"
    echo '```'
    echo ''
    echo '## REVIEW COMMENTS'
    echo "${comment_text}"
    echo ''
    echo '## TASK'
    echo ''
    echo '### Step 1: Understand the design context'
    echo "The issue archive is staged inside your working directory at .review-context/. Read it via:"
    echo '```'
    echo "cat .review-context/issue.md"
    echo "cat .review-context/design.md"
    echo "cat .review-context/plan.md"
    echo '```'
    echo ''
    echo '### Step 2: Assess each comment'
    echo 'For each review comment, make a judgement call: is it technically valid against the design? Note your reasoning.'
    echo ''
    echo '### Step 3: Fix the code'
    echo 'Fix the code for any comments you assessed as valid. Then run:'
    echo '```'
    echo 'git add -A'
    echo "git commit -m 'fix: address PR review feedback'"
    echo "git push origin ${PR_BRANCH}   # Do NOT change this branch name"
    echo '```'
    echo ''
    echo '### Step 4: Reply to all threads'
    echo "Using comment IDs from .review-context/comments.json, reply to EVERY thread (both valid and invalid comments):"
    echo '```'
    echo "jq -r '.[] | \"gh api repos/${OWNER_REPO}/pulls/${PR_NUMBER}/comments/\(.id)/replies --method POST --raw-field body=Chosen approach: <what was done>. Options considered: <other approaches and why not chosen>. Reasoning: <why this decision aligns with the design>\"' .review-context/comments.json | bash"
    echo '```'
    echo 'Use the actual comment IDs from the JSON file. Replace the <...> placeholders with real content describing your reasoning.'
    echo ''
    echo '### Step 5: Verify'
    echo 'Confirm your replies were posted:'
    echo '```'
    echo "gh pr view ${PR_NUMBER} --json comments --jq 'length'"
    echo '```'
    echo ''
    echo '## MANDATORY OUTCOME FILE'
    echo 'Alongside the result file, you MUST write a comment-outcomes manifest.'
    echo "Write it to: .review-context/comment-outcomes.json"
    echo 'Format: a JSON object keyed by numeric comment ID (as string), with values:'
    echo '```json'
    echo '{'
    echo '  "<comment-id>": { "outcome": "fixed", "commit_sha": "<7+ char SHA>" },'
    echo '  "<comment-id>": { "outcome": "no_fix_needed", "reason": "why no fix is needed" },'
    echo '  "<comment-id>": { "outcome": "unresolved", "reason": "what blocked you" }'
    echo '}'
    echo '```'
    echo '- Every comment ID from .review-context/comments.json MUST appear in this manifest.'
    echo '- "fixed" requires the commit SHA of the fix pushed to the branch.'
    echo '- "no_fix_needed" requires a non-empty reason string.'
    echo '- "unresolved" means you could not address the comment; provide a reason.'
    echo ''
    echo '## MANDATORY RESULT FILE'
    echo 'When you are done, write EXACTLY ONE of these values to the file below (nothing else, no explanation):'
    echo '- ALL_DONE — All valid comments addressed, code fixed and pushed, replies posted'
    echo '- NO_FIXES_NEEDED — All comments assessed as invalid, no code changes needed, replies posted explaining why'
    echo '- PARTIAL — Some comments addressed but could not complete all (state which in your output)'
    echo '- BLOCKED — Cannot proceed (need info, conflicting constraints, etc.)'
    echo ''
    echo "Result file (write inside your working directory): .review-context/process-review-p${POLL_COUNT}.result"
    echo ''
    echo '## RULES'
    echo '- Follow the receiving-code-review skill strictly.'
    echo '- No performative agreement (no "thanks", "great point", etc.).'
    echo '- Reply factually: state the chosen approach, options considered, and reasoning.'
    echo '- If truly ambiguous, note the ambiguity, pick the safest default that preserves existing behavior, and explain your reasoning.'
    echo '- Do NOT expand scope beyond comments.'
    echo '- Do NOT create a new PR.'
    echo '- Do NOT merge the PR (no gh pr merge). Only commit, push, and reply.'
    echo "- CRITICAL: Only push to ${PR_BRANCH}. Never push to main, master, or any other branch. Always use: git push origin ${PR_BRANCH}"
  } > "$prompt_file"

  AGENT_START_MS=$(_now_ms)
  emit_event "post-pr-review" "info" "post-pr-review.agent.started" \
    "invoking agent for poll iteration ${POLL_COUNT}" commentId="batch-p${POLL_COUNT}"

  # Scale the agent timeout with comment volume: 5 min baseline + ~2 min per
  # comment (read diff, edit, commit, reply), capped at 30 min so a runaway
  # agent doesn't hold the loop hostage. Floor at 5 min for the empty/edge case.
  local _comment_count
  _comment_count=$(echo "$comments" | jq 'length' 2>/dev/null || echo 0)
  local _timeout_min=$(( 5 + 2 * _comment_count ))
  if (( _timeout_min > 30 )); then _timeout_min=30; fi
  if (( _timeout_min < 5 )); then _timeout_min=5; fi
  log "  Agent timeout: ${_timeout_min}m (for ${_comment_count} comment(s))"

  # Capture main checkout state before the agent runs: HEAD SHA + whether
  # the working tree was already dirty. The guard uses both to distinguish
  # an agent leak (HEAD moved, or clean→dirty) from pre-existing dev work
  # (already dirty before the agent ran — must not be reset).
  local _main_state_before
  _main_state_before=$(_capture_main_state)

  NODE_OPTIONS='--conditions=development' pnpm -C "$REPO_ROOT" --filter @ai-sdlc/cli exec tsx "$REPO_ROOT/apps/cli/src/run-agent.ts" \
    --phase post-pr-review \
    --cwd "$POLL_WORKTREE" \
    --run-id "$RUN_ID" \
    --repo-id "$REPO_ID" \
    --repo-root "$REPO_ROOT" \
    --phase-id "process-review-p${POLL_COUNT}" \
    --step-id "${POLL_COUNT}" \
    --prompt-file "$prompt_file" \
    --timeout-minutes "$_timeout_min" \
    --start-sha "$(git -C "$POLL_WORKTREE" rev-parse HEAD 2>/dev/null || printf '0%.0s' {1..40})" \
    2>&1 | tee -a "${ISSUES_DIR}/process-review-p${POLL_COUNT}.log"
  local _agent_ec=${PIPESTATUS[0]}
  _guard_main_checkout "post-pr-review" "$_main_state_before"

  if [[ "$_agent_ec" != "0" ]]; then
    warn "Agent exited with code ${_agent_ec} (poll ${POLL_COUNT})"
  fi

  # Promote agent's in-worktree result (where opencode CAN write) to ISSUES_DIR
  # so the existing resolver and artifact archiving keep working unchanged.
  if [[ -f "$RESULT_IN_WT" ]]; then
    cp "$RESULT_IN_WT" "${ISSUES_DIR}/process-review-p${POLL_COUNT}.result"
  fi

  # Promote agent's per-comment outcome manifest (if present)
  local OUTCOMES_IN_WT="${CTX}/comment-outcomes.json"
  local OUTCOMES_FILE="${ISSUES_DIR}/comment-outcomes-p${POLL_COUNT}.json"
  if [[ -f "$OUTCOMES_IN_WT" ]]; then
    cp "$OUTCOMES_IN_WT" "$OUTCOMES_FILE"
    log "  Promoted comment outcomes manifest from agent worktree"
  else
    : > "$OUTCOMES_FILE"
    warn "  No comment-outcomes.json found in agent worktree"
  fi

  # Resolve structured result from agent output
  local _result_file="${ISSUES_DIR}/process-review-p${POLL_COUNT}.result"
  local _result_was_valid=false
  if validate_result_file "$_result_file" ALL_DONE NO_FIXES_NEEDED PARTIAL BLOCKED; then
    _result_was_valid=true
  fi
  local review_result
  review_result=$(resolve_result \
    "$_result_file" \
    "${ISSUES_DIR}/process-review-p${POLL_COUNT}.log" \
    --agent-ec "$_agent_ec" \
    ALL_DONE NO_FIXES_NEEDED PARTIAL BLOCKED \
    PARTIAL)

  log "Review result: ${review_result}"
  LAST_REVIEW_RESULT="$review_result"

  AGENT_DUR=$(( $(_now_ms) - AGENT_START_MS ))
  if [[ "$_agent_ec" != "0" ]]; then
    AGENT_FAILED=true
    emit_event "post-pr-review" "error" "post-pr-review.agent.failed" \
      "agent for poll iteration ${POLL_COUNT} exited with code ${_agent_ec}" \
      commentId="batch-p${POLL_COUNT}" reason="non_zero_exit" exitCode="$_agent_ec" durationMs="$AGENT_DUR"
  else
    if [[ "$_result_was_valid" == "false" ]]; then
      AGENT_FAILED=true
      emit_event "post-pr-review" "error" "post-pr-review.agent.failed" \
        "agent for poll iteration ${POLL_COUNT} produced no valid result file" \
        commentId="batch-p${POLL_COUNT}" reason="no_result_file" exitCode="$_agent_ec" durationMs="$AGENT_DUR"
    else
      case "$review_result" in
        ALL_DONE|NO_FIXES_NEEDED|PARTIAL)
          emit_event "post-pr-review" "info" "post-pr-review.agent.completed" \
            "agent completed for poll iteration ${POLL_COUNT}: ${review_result}" \
            commentId="batch-p${POLL_COUNT}" result="$review_result" durationMs="$AGENT_DUR"
          ;;
        BLOCKED)
          emit_event "post-pr-review" "error" "post-pr-review.agent.failed" \
            "agent blocked for poll iteration ${POLL_COUNT}" \
            commentId="batch-p${POLL_COUNT}" reason="BLOCKED" exitCode="$_agent_ec"
          ;;
        *)
          emit_event "post-pr-review" "error" "post-pr-review.agent.failed" \
            "agent for poll iteration ${POLL_COUNT} produced invalid result: ${review_result}" \
            commentId="batch-p${POLL_COUNT}" reason="invalid_result" exitCode="$_agent_ec"
          ;;
      esac
    fi
  fi

  # Merge agent outcomes into per-comment state — only when the agent
  # produced a valid result. When _agent_ec != 0, the outcomes file is
  # empty, and update_comment_outcomes would mark every pending comment
  # as "unresolved" and increment their attempts, hitting the block
  # threshold on transient failures without the agent ever having
  # handled those comments.
  if ! $AGENT_FAILED; then
    update_comment_outcomes "$OUTCOMES_FILE"
  else
    log "  Skipping outcome merge — agent failed or produced no valid result"
  fi

  rm -f "$prompt_file"

  # ── Verification chain ──────────────────────────────────────────────────
  # Two independent flags:
  #
  #   replies_ok — replies are observable on GitHub for every comment ID we
  #                fed the agent. This is the *irreversible* side-effect we
  #                must not duplicate; once true, the comment IDs are done
  #                whether or not the build is green.
  #
  #   verify_ok  — every verification (replies + commits + build) passed.
  #                Drives the return code so the outer loop reports failure
  #                correctly, but does NOT gate processed-ID tracking.
  #   build_passed — true only when verify_build_passes actually ran and
  #                succeeded. Unlike verify_ok, this is false when
  #                NO_FIXES_NEEDED skips build verification entirely.
  #
  # This split avoids two failure modes:
  #   (a) agent crashes before replying → replies_ok=false → IDs unmarked
  #       → next poll retries (the original P0 fix).
  #   (b) replies posted but build red → replies_ok=true → IDs marked
  #       → next poll does not re-feed the same comments and the agent
  #       does not spam duplicate replies. Build still re-runs naturally
  #       on the next poll once unrelated state changes.
  local verify_ok=true
  local build_passed=false
  local replies_ok=false

  if [[ "$review_result" == "NO_FIXES_NEEDED" ]]; then
    log "Agent reports no fixes needed. Skipping commit/build verification."
    if verify_replies_posted; then
      replies_ok=true
      emit_event "post-pr-review" "info" "post-pr-review.reply.posted" \
        "replies confirmed (no fixes needed)" commentId="batch-p${POLL_COUNT}"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
        "verification failed (replies not confirmed)" \
        commentId="batch-p${POLL_COUNT}" reason="verify_replies_failed"
    fi
  elif [[ "$review_result" == "ALL_DONE" || "$review_result" == "PARTIAL" ]]; then
    if verify_commits_pushed "$pre_sha" "$PR_BRANCH"; then
      emit_event "post-pr-review" "info" "post-pr-review.verification.passed" \
        "commits pushed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}" step="commits_pushed"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
        "commits not pushed for batch p${POLL_COUNT}" \
        commentId="batch-p${POLL_COUNT}" reason="commits_not_pushed" step="commits_pushed"
    fi
    if verify_replies_posted; then
      replies_ok=true
      emit_event "post-pr-review" "info" "post-pr-review.reply.posted" \
        "replies confirmed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.reply.failed" \
        "reply verification failed for batch p${POLL_COUNT}" \
        commentId="batch-p${POLL_COUNT}" error="verify_replies_failed"
    fi
    if verify_build_passes; then
      build_passed=true
      emit_event "post-pr-review" "info" "post-pr-review.verification.passed" \
        "build verification passed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}" step="build_passes"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
        "build verification failed for batch p${POLL_COUNT}" \
        commentId="batch-p${POLL_COUNT}" reason="build_or_commits_failed" step="build_passes"
    fi
  elif [[ "$review_result" == "BLOCKED" ]]; then
    warn "Agent is blocked. No verification possible."
    emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
      "agent blocked, skipping verification" \
      commentId="batch-p${POLL_COUNT}" reason="BLOCKED"
    verify_ok=false
    BLOCKED_EXIT=true
  else
    warn "Unknown result '${review_result}'. Running full verification."
    if verify_commits_pushed "$pre_sha" "$PR_BRANCH"; then
      emit_event "post-pr-review" "info" "post-pr-review.verification.passed" \
        "commits pushed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}" step="commits_pushed"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
        "commits not pushed" commentId="batch-p${POLL_COUNT}" reason="commits_not_pushed" step="commits_pushed"
    fi
    if verify_replies_posted; then
      replies_ok=true
      emit_event "post-pr-review" "info" "post-pr-review.reply.posted" \
        "replies confirmed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.reply.failed" \
        "reply verification failed" \
        commentId="batch-p${POLL_COUNT}" error="verify_replies_failed"
    fi
    if verify_build_passes; then
      build_passed=true
      emit_event "post-pr-review" "info" "post-pr-review.verification.passed" \
        "build verification passed for batch p${POLL_COUNT}" commentId="batch-p${POLL_COUNT}" step="build_passes"
    else
      verify_ok=false
      emit_event "post-pr-review" "error" "post-pr-review.verification.failed" \
        "build verification failed" \
        commentId="batch-p${POLL_COUNT}" reason="build_or_commits_failed" step="build_passes"
    fi
  fi

   # Per-comment state transitions — reply_verified + state→replied
   # For each comment in the batch, update reply_verified if reply was confirmed.
   # Only transition to "replied" if the outcome is not "unresolved" — unresolved
   # comments that received a reply stay "pending" so check_stuck_comments can
   # track attempts and escalate them to "blocked" when they exceed the threshold.
   local status_file="${ISSUES_DIR}/replies-status-p${POLL_COUNT}.txt"
   if [[ -f "$status_file" && -s "$status_file" ]]; then
     local replied_id
     while IFS= read -r replied_id; do
       [[ -z "$replied_id" ]] && continue
       if [[ -f "$COMMENT_STATE_FILE" ]] && jq -e --arg cid "$replied_id" 'has($cid)' "$COMMENT_STATE_FILE" >/dev/null 2>&1; then
         jq --arg cid "$replied_id" '.[$cid].reply_verified = true' \
           "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
           mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
        local outcome
          outcome=$(jq -r --arg cid "$replied_id" '.[$cid].outcome // "null"' "$COMMENT_STATE_FILE")
          # Only transition to "replied" if the outcome is promotable:
          # - "fixed" requires a non-null commit_sha
          # - "no_fix_needed" requires a non-empty no_fix_reason
          # - "unresolved" stays pending for stuck-loop escalation
          # Incomplete outcomes (fixed without commit_sha, no_fix_needed without reason)
          # also stay pending so they can be re-prompted or eventually blocked.
          local can_promote=false
          if [[ "$outcome" == "fixed" ]]; then
            local sha
            sha=$(jq -r --arg cid "$replied_id" '.[$cid].commit_sha // "null"' "$COMMENT_STATE_FILE")
            if [[ -n "$sha" && "$sha" != "null" ]]; then
              can_promote=true
            fi
          elif [[ "$outcome" == "no_fix_needed" ]]; then
            local reason
            reason=$(jq -r --arg cid "$replied_id" '.[$cid].no_fix_reason // "null"' "$COMMENT_STATE_FILE")
            if [[ -n "$reason" && "$reason" != "null" ]]; then
              can_promote=true
            fi
          fi
          if $can_promote; then
            set_comment_state "$replied_id" "replied"
          fi
       fi
     done < "$status_file"
     local replied_count
     replied_count=$(wc -l < "$status_file" | tr -d ' ')
     log "  Set reply_verified=true for ${replied_count} comment(s)"
   fi

  # Per-comment commit SHA verification for fixed outcomes.
  # Uses the per-comment pre_sha captured at first init (so re-check
  # verification on a later poll still compares against the original
  # pre-agent SHA, not against HEAD that has since advanced with pushes).
  local comment_ids
  comment_ids=$(jq -r 'keys[]' "$COMMENT_STATE_FILE" 2>/dev/null)
  local cid
  for cid in $comment_ids; do
    [[ -z "$cid" ]] && continue
    local outcome
    outcome=$(jq -r --arg cid "$cid" '.[$cid].outcome // "null"' "$COMMENT_STATE_FILE")
    if [[ "$outcome" == "fixed" ]]; then
      local commit_sha cid_pre_sha
      commit_sha=$(jq -r --arg cid "$cid" '.[$cid].commit_sha // "null"' "$COMMENT_STATE_FILE")
      cid_pre_sha=$(jq -r --arg cid "$cid" '.[$cid].pre_sha // ""' "$COMMENT_STATE_FILE")
      if [[ "$commit_sha" != "null" && -n "$commit_sha" ]]; then
        if verify_comment_commit "$cid" "$commit_sha" "$cid_pre_sha"; then
          log "  Comment ${cid}: commit ${commit_sha:0:7} verified on origin/${PR_BRANCH}"
          jq --arg cid "$cid" '.[$cid].commit_verified = true' \
            "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
            mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
         else
           warn "  Comment ${cid}: commit ${commit_sha:0:7} verification failed — demoting to pending for re-prompt"
           # Demote to pending WITHOUT incrementing attempts — update_comment_outcomes
           # already counted this agent run for this comment.
           jq --arg cid "$cid" \
             '.[$cid].commit_verified = false | .[$cid].build_verified = false | .[$cid].reply_verified = false | .[$cid].outcome = null | .[$cid].commit_sha = null | .[$cid].state = "pending"' \
             "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
             mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
         fi
      fi
    fi
  done

   # Set build_verified for fixed outcomes when build actually passed.
   # This must be per-comment: verify_ok can be true without a build running
   # (e.g. NO_FIXES_NEEDED path skips build verification), so we use
   # build_passed which is true only when verify_build_passes actually ran
   # and succeeded.
   if $build_passed; then
     for cid in $comment_ids; do
       [[ -z "$cid" ]] && continue
       local outcome
       outcome=$(jq -r --arg cid "$cid" '.[$cid].outcome // "null"' "$COMMENT_STATE_FILE")
       if [[ "$outcome" == "fixed" ]]; then
         jq --arg cid "$cid" '.[$cid].build_verified = true' \
           "$COMMENT_STATE_FILE" > "${COMMENT_STATE_FILE}.tmp" && \
           mv "${COMMENT_STATE_FILE}.tmp" "$COMMENT_STATE_FILE"
       fi
     done
   fi

  # State transitions: replied -> processed (if guard passes)
  # can_transition_to_processed checks per-comment build_verified for
  # fixed outcomes, so no batch-level verify_ok check is needed here.
  local promoted_ids=""
  for cid in $comment_ids; do
    [[ -z "$cid" ]] && continue
    local state
    state=$(jq -r --arg cid "$cid" '.[$cid].state' "$COMMENT_STATE_FILE")
    if [[ "$state" == "replied" ]]; then
      if can_transition_to_processed "$cid"; then
        set_comment_state "$cid" "processed"
        log "  Comment ${cid}: transitioned replied → processed"
        promoted_ids="${promoted_ids} ${cid}"
      fi
    fi
  done

  # Resolve GitHub threads for newly-processed comments
  if [[ -n "$promoted_ids" ]]; then
    resolve_threads $promoted_ids
  fi

  # Check for stuck comments and block them
  check_stuck_comments

  # Derive compatibility text files from JSON state
  derive_compat_files

  # Dirty worktree cleanup — archive diff and reset on failure paths.
  # This MUST run after verify_commits_pushed has attempted to push valid commits,
  # but before we return from process_reviews.
  if [[ "$_agent_ec" != "0" || "$review_result" == "BLOCKED" || ("$verify_ok" == "false" && "$replies_ok" == "false") ]]; then
    if [[ -n "${POLL_WORKTREE:-}" ]]; then
      cleanup_dirty_worktree "$POLL_WORKTREE"
    fi
  fi

  if $verify_ok; then
    log "All verifications passed."
    return 0
  else
    warn "Some verifications failed — see logs above."
    return 2
  fi
}

# ── Main loop ──────────────────────────────────────────────────────────────
POLL_COUNT=0
TOTAL_POLLS=0
LAST_REMOTE_SHA=""
BLOCKED_EXIT=false
ALL_REVIEWS_RESOLVED=false
LAST_REVIEW_RESULT=""
AGENT_FAILED=false
DID_PUSH_COMMITS=0
CONTRADICTION_FIRED=false
PROCESSED_IDS_COUNT_START=$(wc -l < "$PROCESSED_IDS_FILE" 2>/dev/null || echo 0)
COMMENT_STATE_FILE="${ISSUES_DIR}/comment-state.json"
# Hard ceiling on total iterations regardless of resets — protects against
# pathological loops where every push attracts a new comment.
MAX_TOTAL_POLLS="${MAX_TOTAL_POLLS:-30}"

while [[ $POLL_COUNT -lt $MAX_POLLS && $TOTAL_POLLS -lt $MAX_TOTAL_POLLS ]]; do
  # Check whether the branch advanced since last iteration; if so, reset the
  # "polls without progress" counter — a new push usually means a new round
  # of reviewer comments is incoming.
  git fetch origin "$PR_BRANCH" 2>/dev/null || true
  CURRENT_REMOTE_SHA=$(git rev-parse "origin/${PR_BRANCH}" 2>/dev/null || echo "")
  if [[ -n "$LAST_REMOTE_SHA" && -n "$CURRENT_REMOTE_SHA" && "$CURRENT_REMOTE_SHA" != "$LAST_REMOTE_SHA" ]]; then
    _PREV_POLL_COUNT=$POLL_COUNT
    log "Branch advanced (${LAST_REMOTE_SHA:0:7} → ${CURRENT_REMOTE_SHA:0:7}); resetting poll budget."
    POLL_COUNT=0
    emit_event "post-pr-review" "info" "post-pr-review.poll.reset" \
      "poll budget reset due to branch advance" \
      previousPollCount="$_PREV_POLL_COUNT" newPollCount="0"
  fi
  LAST_REMOTE_SHA="$CURRENT_REMOTE_SHA"

  POLL_COUNT=$((POLL_COUNT + 1))
  TOTAL_POLLS=$((TOTAL_POLLS + 1))
  log "=== Poll $POLL_COUNT/$MAX_POLLS (total: $TOTAL_POLLS/$MAX_TOTAL_POLLS) ==="
  emit_event "post-pr-review" "info" "post-pr-review.poll.started" \
    "poll ${POLL_COUNT}/${MAX_POLLS} for PR #${PR_NUMBER}" \
    prNumber="$PR_NUMBER" poll="$POLL_COUNT" maxPolls="$MAX_POLLS" totalPolls="$TOTAL_POLLS" maxTotalPolls="$MAX_TOTAL_POLLS"

  review_ec=0
  AGENT_FAILED=false
  process_reviews || review_ec=$?

  case $review_ec in
    0) log "Reviews processed and verified successfully."
       if [[ "$LAST_REVIEW_RESULT" == "ALL_DONE" || "$LAST_REVIEW_RESULT" == "NO_FIXES_NEEDED" ]] && ! $AGENT_FAILED; then
         ALL_REVIEWS_RESOLVED=true
       else
         ALL_REVIEWS_RESOLVED=false
       fi ;;
    1) log "No new reviews to process (poll $POLL_COUNT/$MAX_POLLS)."
       ALL_REVIEWS_RESOLVED=false ;;
    2) warn "Reviews processed but some verifications failed (poll $POLL_COUNT/$MAX_POLLS)."
       ALL_REVIEWS_RESOLVED=false ;;
    *) warn "process_reviews exited with unexpected code ${review_ec}"
       ALL_REVIEWS_RESOLVED=false ;;
  esac

  if $BLOCKED_EXIT; then
emit_event "post-pr-review" "error" "post-pr-review.run.failed" \
      "Agent blocked" reason="BLOCKED" lastPoll="$POLL_COUNT"
    break
  fi

  if $ALL_REVIEWS_RESOLVED; then
    : # keep polling — reviewers may add follow-up comments
  fi

  # Emit poll.completed BEFORE the branch-advance check below, so the
  # started/completed pair stays consistent on this iteration's POLL_COUNT
  # even if the reset fires immediately after.
  PROCESSED_COUNT=0
  if [[ -f "$PROCESSED_IDS_FILE" ]]; then
    PROCESSED_COUNT=$(wc -l < "$PROCESSED_IDS_FILE" | tr -d ' ')
  fi
  PENDING_COUNT=0
  if [[ -s "$REPLIED_IDS_FILE" ]]; then
    PENDING_COUNT=$(wc -l < "$REPLIED_IDS_FILE" | tr -d ' ')
  fi
  emit_event "post-pr-review" "info" "post-pr-review.poll.completed" \
    "poll ${POLL_COUNT} complete" \
    poll="$POLL_COUNT" processed="$PROCESSED_COUNT" pending="$PENDING_COUNT"

  # Intentionally do NOT update LAST_REMOTE_SHA at the top of the loop —
  # it stays pinned to the SHA observed at the *start* of this iteration.
  # If the agent pushed during process_reviews, this check sees origin
  # advanced past LAST_REMOTE_SHA and resets POLL_COUNT, giving the next
  # round of reviewer comments a fresh budget.
  #
  # The check must run BEFORE the break below, otherwise a push on the
  # final consecutive poll exits without granting the promised fresh
  # budget.
  # Snapshot the iteration's actual POLL_COUNT before any reset, so terminal
  # telemetry (e.g. lastPoll on a max_total_polls exit) reports the real
  # number even when an in-flight push triggers a reset on the same tick.
  LAST_ITERATION_POLL=$POLL_COUNT

  git fetch origin "$PR_BRANCH" 2>/dev/null || true
  CURRENT_REMOTE_SHA=$(git rev-parse "origin/${PR_BRANCH}" 2>/dev/null || echo "")
  if [[ -n "$LAST_REMOTE_SHA" && -n "$CURRENT_REMOTE_SHA" && "$CURRENT_REMOTE_SHA" != "$LAST_REMOTE_SHA" ]]; then
    _PREV_POLL_COUNT=$POLL_COUNT
    log "Branch advanced (${LAST_REMOTE_SHA:0:7} → ${CURRENT_REMOTE_SHA:0:7}) during poll; resetting poll budget."
    POLL_COUNT=0
    LAST_REMOTE_SHA="$CURRENT_REMOTE_SHA"
    emit_event "post-pr-review" "info" "post-pr-review.poll.reset" \
      "poll budget reset due to branch advance during poll" \
      previousPollCount="$_PREV_POLL_COUNT" newPollCount="0"
  fi

  if [[ $POLL_COUNT -ge $MAX_POLLS || $TOTAL_POLLS -ge $MAX_TOTAL_POLLS ]]; then
    break
  fi

  log "Sleeping ${POLL_INTERVAL}s until next poll..."
  sleep "$POLL_INTERVAL"
done

TOTAL_PROCESSED=0
if [[ -f "$PROCESSED_IDS_FILE" ]]; then
  TOTAL_PROCESSED=$(wc -l < "$PROCESSED_IDS_FILE" | tr -d ' ')
fi
if $BLOCKED_EXIT; then
  : # Already emitted run.failed above before break
elif $ALL_REVIEWS_RESOLVED; then
  emit_event "post-pr-review" "info" "post-pr-review.run.completed" \
    "PR review poll finished" \
    totalProcessed="${TOTAL_PROCESSED}" terminalReason="${LAST_REVIEW_RESULT:-ALL_DONE}"
elif [[ $TOTAL_POLLS -ge $MAX_TOTAL_POLLS ]]; then
  # Prefer the pre-reset snapshot — a same-iteration push reset POLL_COUNT
  # to 0 before this break, but the iteration that hit the hard cap had a
  # real consecutive-poll number worth reporting.
  emit_event "post-pr-review" "error" "post-pr-review.run.failed" \
    "reached MAX_TOTAL_POLLS hard ceiling (${MAX_TOTAL_POLLS})" \
    reason="max_total_polls" lastPoll="${LAST_ITERATION_POLL:-$POLL_COUNT}"
else
  # max_polls exit implies no reset fired this iteration (otherwise
  # POLL_COUNT would be 0 and we wouldn't be here), so POLL_COUNT is
  # already correct — but use the snapshot for consistency.
  emit_event "post-pr-review" "error" "post-pr-review.run.failed" \
    "PR review poll exhausted poll budget" \
    reason="max_polls" lastPoll="${LAST_ITERATION_POLL:-$POLL_COUNT}"
fi
if should_emit_compound; then
  emit_compound_doc || warn "compound doc emission failed"
else
  log "Skipping compound doc — loop produced no signal worth recording."
fi
log "=== PR review poll complete (${LAST_ITERATION_POLL:-$POLL_COUNT}/${MAX_POLLS} consecutive, ${TOTAL_POLLS}/${MAX_TOTAL_POLLS} total) ==="
