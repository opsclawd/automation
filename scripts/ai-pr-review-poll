#!/usr/bin/env bash
# ai-pr-review-poll — thin shim. The poll loop now lives in the managed
# TypeScript poller (apps/cli/src/run-pr-poll.ts, M6-04/M6-05). This script
# preserves the legacy CLI signature: <PR_NUMBER> [issue] [max_polls] [interval].
# The legacy loop is preserved at scripts/legacy/ai-pr-review-poll.legacy.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export REPO_ROOT

PR_NUMBER="${1:-}"
ISSUE_NUM="${2:-}"
MAX_POLLS="${3:-30}"
POLL_INTERVAL="${4:-300}"

if [[ -z "$PR_NUMBER" ]]; then
  echo "Usage: $0 <PR_NUMBER> [issue_num] [max_polls=30] [interval_sec=300]" >&2
  exit 1
fi
if [[ -z "$ISSUE_NUM" ]]; then
  echo "FATAL: ISSUE_NUM is required. The poller must not run from the main checkout." >&2
  exit 1
fi
# Escape hatch: USE_LEGACY_POLL=1 runs the legacy bash poller (issue #230).
# Must run before the branch-gating check below: the legacy poller has its own
# bootstrap that syncs the worktree to the PR branch
# (scripts/legacy/ai-pr-review-poll.legacy:142-145), so the shim's stricter
# preflight would otherwise block the documented recovery path.
if [[ "${USE_LEGACY_POLL:-0}" == "1" ]]; then
  exec bash "${REPO_ROOT}/scripts/legacy-poll" \
    "$PR_NUMBER" "$ISSUE_NUM" "$MAX_POLLS" "$POLL_INTERVAL"
fi

POLL_CWD="${REPO_ROOT}/.ai-worktrees/issue-${ISSUE_NUM}"
if [[ ! -d "$POLL_CWD" ]]; then
  echo "FATAL: worktree $POLL_CWD does not exist. Create it before polling." >&2
  exit 1
fi

OWNER_REPO="${OWNER_REPO:-$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo "")}"
if [[ -z "$OWNER_REPO" ]]; then
  echo "FATAL: could not determine owner/repo. Set OWNER_REPO=<owner>/<repo> and retry." >&2
  exit 1
fi

# Verify the worktree is on the PR branch before invoking agents.
# The legacy script fetched the PR branch and asserted HEAD; the shim
# restores this safety contract to prevent running from a stale or
# wrong-branch checkout.
PR_BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName' 2>/dev/null || echo "")
if [[ -z "$PR_BRANCH" ]]; then
  echo "FATAL: could not determine PR branch for #${PR_NUMBER}. Check gh auth and retry." >&2
  exit 1
fi
ACTUAL_BRANCH=$(git -C "$POLL_CWD" symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$ACTUAL_BRANCH" != "$PR_BRANCH" ]]; then
  echo "FATAL: worktree $POLL_CWD is on '${ACTUAL_BRANCH}', expected '${PR_BRANCH}'. Refusing to poll from wrong branch." >&2
  exit 1
fi

# Own our TMPDIR. The parent run (ai-run-issue-v2) injects a per-run TMPDIR
# that gets deleted in its finally block. We need a poll-owned directory so
# subprocesses (gh, git, agent) don't lose their tmp dir mid-poll.
POLL_TMPDIR="${REPO_ROOT}/ai/poll-pr-${PR_NUMBER}/tmp"
mkdir -p "$POLL_TMPDIR"
export TMPDIR="$POLL_TMPDIR"
export SQLITE_TMPDIR="$POLL_TMPDIR"

ARGS=(--pr "$PR_NUMBER" --repo "$OWNER_REPO" --cwd "$POLL_CWD"
      --max-polls "$MAX_POLLS" --interval-seconds "$POLL_INTERVAL")
[[ -n "$ISSUE_NUM" ]] && ARGS+=(--issue "$ISSUE_NUM")
[[ -n "${AI_RUN_UUID:-}" ]] && ARGS+=(--run-id "$AI_RUN_UUID")

exec env NODE_OPTIONS='--conditions=development' \
  pnpm -C "$REPO_ROOT" --filter @ai-sdlc/cli exec tsx \
  "$REPO_ROOT/apps/cli/src/run-pr-poll.ts" "${ARGS[@]}"
