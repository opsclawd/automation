{
  "validation": {
    "commands": [
      "pnpm build",
      "pnpm lint",
      "pnpm typecheck",
      "pnpm test",
      "pnpm test:bash",
      "pnpm depcruise"
    ],
    "timeout": 300
  },
  "phases": {
    "skip": [],
    "reviewFix": { "maxIterations": 10 },
    "implement": { "maxIterations": 5 },
    "wholePrFix": {
      "maxIterations": 10,
      "maxRetriesPerTask": 3,
      "maxTotalTasks": 50,
      "architectPass": { "enabled": true }
    },
    "fixValidate": { "maxIterations": 2 },
    "planReview": { "maxIterations": 5, "enabled": true },
    "postPrReview": { "maxPolls": 10, "pollIntervalSeconds": 300 }
  },
  "timeouts": {
    "readyMaxDays": 7,
    "invocationMaxMinutes": 30
  },
  "taskSplitting": {
    "maxTestFileLines": 500,
    "maxTestCases": 10,
    "blockOversizedTasks": false
  },
  "agent": {
    "defaultProfile": "builder",
    "profiles": {
      "architect": {
        "runtime": "opencode",
        "provider": "zai-coding-plan",
        "model": "glm-5.1",
        "timeoutMinutes": 30
      },
      "senior": {
        "runtime": "opencode",
        "provider": "ollama-cloud",
        "model": "glm-5.1",
        "timeoutMinutes": 30
      },
      "builder": {
        "runtime": "opencode",
        "provider": "minimax-coding-plan",
        "model": "MiniMax-M2.7",
        "timeoutMinutes": 30
      },
      "junior": {
        "runtime": "opencode",
        "provider": "opencode",
        "model": "deepseek-v4-flash-free",
        "timeoutMinutes": 30
      },
      "reviewer": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.5-flash-high",
        "timeoutMinutes": 30
      },
      "task-reviewer": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.5-flash-low",
        "timeoutMinutes": 30
      },
      "local": {
        "runtime": "pi",
        "provider": "crofai",
        "model": "qwen3.6-27b",
        "contextLimitTokens": 64000,
        "promptBudgetTokens": 40000,
        "outputBudgetTokens": 8000,
        "timeoutMinutes": 30
      },
      "qwen": {
        "runtime": "opencode",
        "provider": "crofai",
        "model": "qwen3.6-27b",
        "timeoutMinutes": 30
      },
      "claude": {
        "runtime": "claude-code",
        "provider": "anthropic",
        "model": "opus",
        "timeoutMinutes": 30
      },
      "gemini": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.5-flash-high",
        "timeoutMinutes": 30
      },
      "minimax": {
        "runtime": "opencode",
        "provider": "minimax-coding-plan",
        "model": "MiniMax-M3",
        "timeoutMinutes": 30
      },
      "glm": {
        "runtime": "opencode",
        "provider": "ollama-cloud",
        "model": "glm-5.1",
        "timeoutMinutes": 30
      },
      "deepseek": {
        "runtime": "opencode",
        "provider": "ollama-cloud",
        "model": "deepseek-v4-pro",
        "timeoutMinutes": 30
      },
      "mimo-pro": {
        "runtime": "opencode",
        "provider": "opencode-go",
        "model": "mimo-v2.5-pro",
        "timeoutMinutes": 30
      },
      "mimo": {
        "runtime": "opencode",
        "provider": "opencode",
        "model": "mimo-v2.5-free",
        "timeoutMinutes": 30
      },
      "codex-reviewer": {
        "runtime": "codex",
        "provider": "openai",
        "model": "default",
        "timeoutMinutes": 45
      },
      "codex-writer": {
        "runtime": "codex",
        "provider": "openai",
        "model": "default",
        "sandboxMode": "writable",
        "timeoutMinutes": 45
      }
    },
    "phaseProfiles": {
      "plan-design": { "profile": "architect", "fallbackProfile": "senior" },
      "plan-write": { "profile": "codex-writer", "fallbackProfile": "architect" },
      "implement": { "profile": "qwen", "fallbackProfile": "builder" },
      "quality-review": { "profile": "task-reviewer", "fallbackProfile": "junior" },
      "spec-review": {
        "profile": "task-reviewer",
        "fallbackProfile": "codex-reviewer",
        "fallbackTriggers": ["timeout", "quota_exceeded", "runtime_error"]
      },
      "fix-review": { "profile": "builder", "fallbackProfile": "junior" },
      "whole-pr-fix-review": { "profile": "builder", "fallbackProfile": "junior" },
      "fix-validate": { "profile": "builder", "fallbackProfile": "junior" },
      "whole-pr-review": { "profile": "gemini", "fallbackProfile": "junior" },
      "review-triage": { "profile": "architect", "fallbackProfile": "senior" },
      "post-pr-review": { "profile": "mimo-pro", "fallbackProfile": "junior" },
      "compound": { "profile": "junior", "fallbackProfile": "builder" },
      "extract": { "profile": "junior", "fallbackProfile": "builder" },
      "create-pr": { "profile": "junior", "fallbackProfile": "builder" },
      "arbitrate": { "profile": "architect", "fallbackProfile": "senior" },
      "plan-review": { "profile": "architect", "fallbackProfile": "senior" },
      "plan-fix": { "profile": "architect", "fallbackProfile": "senior" },
      "result-writer": { "profile": "task-reviewer", "fallbackProfile": "junior" },
      "fix-review-architect": { "profile": "architect", "fallbackProfile": "senior" },
      "commit-completion": { "profile": "junior", "fallbackProfile": "builder" },
      "verify-pr-review": { "profile": "reviewer", "fallbackProfile": "junior" }
    }
  }
}
