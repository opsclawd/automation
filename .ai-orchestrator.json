{
  "validation": {
    "commands": ["pnpm build", "pnpm lint", "pnpm typecheck", "pnpm test", "pnpm test:bash"],
    "timeout": 300
  },
  "phases": {
    "skip": [],
    "reviewFix": { "maxIterations": 10 },
    "implement": { "maxIterations": 5 }
  },
  "timeouts": {
    "readyMaxDays": 7,
    "invocationMaxMinutes": 30
  },
  "agent": {
    "defaultProfile": "builder",
    "profiles": {
      "architect": {
        "runtime": "opencode",
        "provider": "zai-coding-plan",
        "model": "glm-5.1",
        "timeoutMinutes": 60
      },
      "senior": {
        "runtime": "opencode",
        "provider": "crofai",
        "model": "glm-5.1",
        "timeoutMinutes": 60
      },
      "builder": {
        "runtime": "opencode",
        "provider": "minimax-coding-plan",
        "model": "MiniMax-M2.7",
        "timeoutMinutes": 30
      },
      "junior": {
        "runtime": "opencode",
        "provider": "opencode",
        "model": "deepseek-v4-flash-free",
        "timeoutMinutes": 30
      },
      "reviewer": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.1-pro-high",
        "timeoutMinutes": 30
      },
      "task-reviewer": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.1-pro",
        "timeoutMinutes": 30
      },
      "local": {
        "runtime": "pi",
        "provider": "crofai",
        "model": "qwen3.6-27b",
        "contextLimitTokens": 64000,
        "promptBudgetTokens": 40000,
        "outputBudgetTokens": 8000,
        "timeoutMinutes": 30
      },
      "qwen": {
        "runtime": "opencode",
        "provider": "crofai",
        "model": "qwen3.6-27b",
        "timeoutMinutes": 30
      },
      "claude": {
        "runtime": "claude-code",
        "provider": "anthropic",
        "model": "opus",
        "timeoutMinutes": 30
      },
      "gemini": {
        "runtime": "antigravity",
        "provider": "google",
        "model": "gemini-3.1-pro",
        "timeoutMinutes": 30
      }
    },
    "phaseProfiles": {
      "plan-design": { "profile": "architect", "fallbackProfile": "senior" },
      "plan-write": { "profile": "architect", "fallbackProfile": "senior" },
      "implement": { "profile": "qwen", "fallbackProfile": "builder" },
      "quality-review": { "profile": "task-reviewer", "fallbackProfile": "junior" },
      "spec-review": { "profile": "task-reviewer", "fallbackProfile": "senior" },
      "fix-review": { "profile": "senior", "fallbackProfile": "gemini" },
      "whole-pr-review": { "profile": "reviewer", "fallbackProfile": "junior" },
      "post-pr-review": { "profile": "senior", "fallbackProfile": "gemini" },
      "compound": { "profile": "junior", "fallbackProfile": "builder" },
      "extract": { "profile": "qwen", "fallbackProfile": "junior" },
      "create-pr": { "profile": "architect", "fallbackProfile": "senior" },
      "arbitrate": { "profile": "architect", "fallbackProfile": "claude" }
    }
  }
}
