{
  "name": "ai-sdlc-orchestrator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:bash": "bats scripts/lib/__tests__",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "compare-runs": "tsx scripts/compare-runs.ts",
    "depcruise": "depcruise . --config .dependency-cruiser.cjs",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,mjs,cjs}": "prettier --write",
    "*.{json,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "dependency-cruiser": "^16.0.0",
    "bats": "^1.13.0",
    "tsx": "^4.19.2",
    "better-sqlite3": "^11.5.0",
    "@types/better-sqlite3": "^7.6.11"
  }
}
